---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button';
---

<BaseLayout title="Verifikasi Email - tepak.id">
    
    <main class="min-h-screen flex flex-col items-center justify-center px-6 py-12 bg-slate-50/50 font-sans">
        
        {/* LOGO AREA */}
        <div class="mb-10">
            <h1 class="text-4xl font-black tracking-tighter text-slate-900">
                tepak.id
            </h1>
        </div>

        {/* VERIFICATION CARD */}
        <div class="w-full max-w-[480px] bg-surface-container-lowest p-10 md:p-14 rounded-[2.5rem] shadow-[0px_32px_64px_-12px_rgba(0,0,0,0.06)] border border-slate-50 relative overflow-hidden">
            
            <div class="flex flex-col items-center text-center">
                
                {/* ILLUSTRATION/ICON */}
                <div class="mb-10 relative">
                    <div class="absolute inset-0 bg-primary/10 blur-3xl rounded-full scale-150"></div>
                    <div class="relative w-28 h-28 bg-primary/5 rounded-full flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary text-6xl" style={{ fontVariationSettings: "'FILL' 1" }}>
                            mark_email_read
                        </span>
                    </div>
                </div>

                {/* TEXT CONTENT */}
                <h2 class="text-3xl font-black text-slate-900 mb-4 tracking-tight">
                    Cek Email Anda
                </h2>
                <p class="text-slate-500 font-medium leading-relaxed mb-12 text-[15px] max-w-xs">
                    Kami telah mengirimkan tautan verifikasi ke email Anda. Silakan periksa kotak masuk atau folder spam untuk melanjutkan.
                </p>

                {/* ACTION BUTTONS */}
                <div class="w-full space-y-8">
                    <Button variant="amber" size="lg" className="w-full shadow-none group">
                        <span>Buka Email Utama</span>
                        <span class="material-symbols-outlined text-lg">open_in_new</span>
                    </Button>

                    <div class="flex flex-col items-center gap-4">
                        <p class="text-sm font-medium text-slate-400">
                            Tidak menerima email? 
                            <a class="text-primary font-black hover:underline underline-offset-4 decoration-2 ml-1 transition-all" href="#">
                                Kirim ulang email
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        {/* FOOTER / BACK LINK */}
        <div class="mt-12">
            <a class="flex items-center gap-3 text-slate-400 font-black hover:text-primary transition-all group text-sm uppercase tracking-widest" href="/login">
                <span class="material-symbols-outlined text-[18px] group-hover:-translate-x-1 transition-transform">arrow_back</span>
                <span>Kembali ke Login</span>
            </a>
        </div>

        {/* SHARED FOOTER COMPONENT */}
        <footer class="flex flex-col md:flex-row justify-center items-center gap-8 py-16 w-full text-[10px] font-black text-slate-300 uppercase tracking-widest">
            <span>© 2024 tepak.id. All rights reserved.</span>
            <div class="flex gap-8">
                <a class="hover:text-primary transition-colors" href="#">Privacy Policy</a>
                <a class="hover:text-primary transition-colors" href="#">Terms of Service</a>
                <a class="hover:text-primary transition-colors" href="#">Support</a>
            </div>
        </footer>

    </main>

</BaseLayout>
