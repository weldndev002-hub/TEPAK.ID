---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CheckCircleIcon, ArrowRightIcon, HomeIcon } from '@heroicons/react/24/outline';

const orderId = Astro.url.searchParams.get('id') || 'Unknown';
const merchantId = Astro.url.searchParams.get('merchant');

// Resolve creator info to link back
let creatorLink = '/';
let creatorName = 'Beranda';

if (merchantId) {
    try {
        const origin = Astro.url.origin;
        const res = await fetch(`${origin}/api/public/profiles/${merchantId}`);
        if (res.ok) {
            const profile = await res.json();
            if (profile?.username) {
                creatorLink = `/u/${profile.username}`;
                creatorName = profile.full_name || `@${profile.username}`;
            }
        }
    } catch (e) {
        console.error('[Success Page] Failed to resolve creator:', e);
    }
}
---

<BaseLayout title="Pembayaran Berhasil | Tepak.ID">
  <main class="min-h-[80vh] flex items-center justify-center p-6 bg-slate-50">
    <div class="max-w-md w-full bg-white rounded-[3rem] p-12 shadow-2xl shadow-slate-200/50 text-center animate-in fade-in zoom-in duration-500">
      
      <!-- Icon Success -->
      <div class="w-24 h-24 rounded-full bg-emerald-100 flex items-center justify-center mx-auto mb-8 relative">
        <CheckCircleIcon className="w-12 h-12 text-emerald-600 relative z-10" />
        <div class="absolute inset-0 rounded-full bg-emerald-400 opacity-20 animate-ping"></div>
      </div>

      <!-- Text Content -->
      <div class="space-y-4 mb-10">
        <h1 class="text-3xl font-black text-slate-900 uppercase tracking-tight leading-none">
          Pembayaran<br/>Berhasil!
        </h1>
        <p class="text-slate-500 font-medium text-sm leading-relaxed px-4">
          Terima kasih! Pesanan <strong class="text-slate-900">#{orderId}</strong> telah kami terima dan pembayaran sudah terverifikasi.
        </p>
      </div>

      <!-- Instructions Card -->
      <div class="bg-slate-50 rounded-2xl p-6 mb-10 text-left border border-slate-100">
        <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Apa selanjutnya?</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-xs font-semibold text-slate-600">
            <span class="w-5 h-5 rounded-full bg-white border border-slate-200 flex items-center justify-center text-[10px] flex-shrink-0">1</span>
            Cek email Anda untuk link download produk.
          </li>
          <li class="flex items-start gap-3 text-xs font-semibold text-slate-600">
            <span class="w-5 h-5 rounded-full bg-white border border-slate-200 flex items-center justify-center text-[10px] flex-shrink-0">2</span>
            Pesanan juga muncul di riwayat transaksi.
          </li>
        </ul>
      </div>

      <!-- Actions -->
      <div class="grid grid-cols-1 gap-3">
        <a 
          href={creatorLink}
          class="flex items-center justify-center gap-2 py-4 rounded-2xl bg-primary text-white font-black uppercase text-[11px] tracking-widest hover:scale-[1.02] active:scale-[0.98] transition-all shadow-xl shadow-primary/20"
        >
          <ArrowRightIcon className="w-4 h-4" />
          Kembali ke {creatorName}
        </a>
        <a href="/" class="text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-primary transition-colors mt-2">Atau ke Beranda</a>
      </div>

      <p class="mt-8 text-[10px] font-bold text-slate-400 uppercase tracking-tighter">
        Tepak.ID &bull; Secure Digital Commerce
      </p>
    </div>
  </main>
</BaseLayout>
