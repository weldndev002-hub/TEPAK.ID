---
import { PricingFlow } from '../components/billing/PricingFlow';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button';
import ProductCard from '../components/ui/ProductCard';
import { 
    SparklesIcon, 
    ArrowRightOnRectangleIcon, 
    LinkIcon, 
    ArchiveBoxIcon, 
    TicketIcon, 
    ChartBarIcon, 
    CheckCircleIcon, 
    GlobeAltIcon,
    CheckBadgeIcon,
    CameraIcon,
    PlayCircleIcon,
    EnvelopeIcon
} from '@heroicons/react/24/outline';
import { getServerClient } from '../lib/supabase';
import { AnalyticsTracker } from '../components/analytics/AnalyticsTracker';
import { createClient } from '@supabase/supabase-js';

const supabase = Astro.locals.supabase;

let branding: any = null;
if (supabase) {
    try {
        const { data } = await supabase
            .from('platform_configs')
            .select('*')
            .eq('id', 1)
            .single();
        branding = data;
    } catch (e) {
        console.error('[Index] Branding Fetch Error:', e);
    }
}

const siteName = branding?.site_name || 'Tepak.ID';
const siteTagline = branding?.site_tagline || 'Satu Link. Semua Kebutuhan Digitalmu.';
const logoUrl = branding?.logo_url || '/logo-light.png';

// 2. Detect Hostname & Identity Logic (Dynamic Routing)
const hostname = Astro.url.hostname;
const { cookies } = Astro;
const urlParams = Astro.url.searchParams;
const testUsername = urlParams.get('u');

let merchantData = null;
let products = [];

try {
    if (!supabase) {
        console.warn('[Routing Warning] Supabase is null. Some features may not work.');
    } else {
    const isMainDomain = hostname.includes('tepak.id') || hostname.includes('workers.dev') || hostname === 'localhost' || hostname === '127.0.0.1';
    
    if (!isMainDomain) {
        // Search by Custom Domain
        const { data } = await supabase.from('user_settings').select('*, profiles(*)').eq('domain_name', hostname).eq('domain_verified', true).single();
        if (data) merchantData = data;
    } else {
        // Search by Subdomain or Test Param
        const subdomain = hostname.split('.')[0];
        const isMainSiteAlias = subdomain === 'tepak' || subdomain === 'tepakid' || subdomain === 'localhost' || subdomain === 'www';
        const identifier = (isMainDomain && !isMainSiteAlias) ? subdomain : testUsername;
        
        if (identifier) {
            // Robust Lookup
            const { data: profileByUsername } = await supabase.from('profiles').select('*, user_settings(*)').eq('username', identifier).single();
            if (profileByUsername) {
                merchantData = {
                    ...profileByUsername.user_settings,
                    profiles: { ...profileByUsername }
                };
            } else {
                // Fallback to domain_name
                const { data: profileBySubdomain } = await supabase.from('user_settings').select('*, profiles(*)').eq('domain_name', identifier).single();
                if (profileBySubdomain) merchantData = profileBySubdomain;
            }
        }
    }

    if (merchantData) {
        const { data: productList } = await supabase.from('products').select('*').eq('merchant_id', merchantData.user_id || merchantData.profiles.id).eq('status', 'published').order('created_at', { ascending: false });
        products = productList || [];
    }
    }
} catch (err) {
    console.error('[Routing Error]', err);
}

// Map the profile & products if merchant found
const profile = merchantData ? {
    name: merchantData.profiles?.full_name || "Merchant",
    username: merchantData.profiles?.username || "merchant",
    bio: merchantData.profiles?.bio || "Welcome to my digital store.",
    avatar: merchantData.profiles?.avatar_url || "https://images.unsplash.com/photo-1544006659-f0b21f04cb1b?w=400&h=400&fit=crop",
    is_verified: true,
} : null;

const seo = merchantData ? {
    title: merchantData.seo_title || `${profile?.name || 'Merchant'} | ${siteName} Ecosystem`,
    description: merchantData.seo_description || profile?.bio || ''
} : {
    title: `${siteName} - ${siteTagline}`,
    description: branding?.site_tagline || "Satu Link. Semua Kebutuhan Digitalmu. Bangun halaman profesional, jual aset digital, dan kelola event tanpa coding."
};

const socials = merchantData ? [
    { icon: CameraIcon, url: merchantData.profiles?.instagram_url ? (merchantData.profiles.instagram_url.startsWith('http') ? merchantData.profiles.instagram_url : `https://instagram.com/${merchantData.profiles.instagram_url.replace('@', '')}`) : null },
    { icon: GlobeAltIcon, url: merchantData.profiles?.twitter_url ? (merchantData.profiles.twitter_url.startsWith('http') ? merchantData.profiles.twitter_url : `https://twitter.com/${merchantData.profiles.twitter_url.replace('@', '')}`) : null },
    { icon: PlayCircleIcon, url: merchantData.profiles?.youtube_url ? (merchantData.profiles.youtube_url.startsWith('http') ? merchantData.profiles.youtube_url : `https://youtube.com/${merchantData.profiles.youtube_url}`) : null },
    { icon: EnvelopeIcon, url: merchantData.profiles?.phone ? `https://wa.me/${merchantData.profiles.phone.replace(/[^0-9]/g, '')}` : null }
].filter(s => s.url) : [];

const formatted_products = products.map(p => ({
    id: p.id,
    title: p.title,
    price: new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(p.price),
    description: p.description,
    image: p.cover_url || "https://images.unsplash.com/photo-1544006659-f0b21f04cb1b?w=400&h=400&fit=crop"
}));

const is_banned = merchantData?.plan_status === 'banned' || merchantData?.profiles?.is_banned;
---

<BaseLayout title={seo.title} description={seo.description}>
    <div class="min-h-screen bg-surface font-['Funnel_Display',sans-serif] selection:bg-primary-container selection:text-on-primary-container">
        
        {merchantData && (
            <div class="relative overflow-hidden min-h-screen bg-[#F1F5F9]">
                {/* DESIGNER BACKGROUND ELEMENTS */}
                <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/[0.03] blur-[120px] rounded-full"></div>
                <div class="absolute bottom-[20%] right-[-5%] w-[30%] h-[50%] bg-amber-200/[0.05] blur-[100px] rounded-full"></div>

                <main class="relative z-10 pt-16 md:pt-32 pb-32 max-w-5xl mx-auto px-6">
                    {is_banned ? (
                        <div class="py-32 flex flex-col items-center text-center space-y-8 animate-in zoom-in duration-500">
                            <div class="w-24 h-24 bg-rose-50 text-rose-500 rounded-[2.5rem] flex items-center justify-center shadow-sm border border-rose-100">
                                <span class="material-symbols-outlined text-5xl">block</span>
                            </div>
                            <h2 class="text-4xl font-black text-slate-900 tracking-tighter uppercase italic">Halaman Tidak Tersedia</h2>
                            <p class="text-slate-500 font-medium max-w-md mx-auto leading-relaxed mb-8">Maaf, halaman ini telah dinonaktifkan oleh sistem keamanan kami.</p>
                            <a href="/" class="px-8 py-4 bg-slate-900 text-white rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-xl shadow-slate-900/20 hover:-translate-y-1 transition-all">Kembali Beranda</a>
                        </div>
                    ) : (
                        <>
                            {/* PROFILE HERO SECTION (REFINED) */}
                            <section class="mb-24 animate-in fade-in slide-in-from-bottom-12 duration-1000 ease-out">
                                <div class="bg-white/90 backdrop-blur-3xl rounded-[3rem] p-10 md:p-20 border border-slate-100 shadow-[0_48px_80px_-16px_rgba(0,0,0,0.08)] flex flex-col items-center text-center relative overflow-hidden group">
                                    
                                    <div class="relative mb-8 md:mb-12">
                                        <div class="w-32 h-32 md:w-48 md:h-48 rounded-[3rem] overflow-hidden border-[6px] border-white shadow-2xl bg-white transition-all duration-700">
                                            <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src={profile.avatar} alt={profile.name} />
                                        </div>
                                        <div class="absolute -bottom-2 -right-2 bg-primary text-white p-2.5 rounded-2xl flex items-center justify-center border-4 border-white shadow-xl">
                                            <CheckBadgeIcon className="w-5 h-5" />
                                        </div>
                                    </div>

                                    <div class="max-w-2xl">
                                        <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-slate-900 mb-6 leading-none uppercase italic">
                                            {profile.name}
                                        </h1>
                                        <p class="text-slate-500 text-lg md:text-xl font-medium leading-relaxed mb-12 opacity-80 max-w-lg mx-auto">
                                            {profile.bio}
                                        </p>

                                        <div class="flex flex-wrap justify-center gap-4">
                                            {socials.map((social) => (
                                                <a href={social.url} target="_blank" rel="noopener noreferrer" class="w-14 h-14 flex items-center justify-center rounded-2xl bg-slate-50 text-slate-400 hover:bg-primary hover:text-white hover:-translate-y-2 transition-all duration-500 shadow-sm hover:shadow-xl hover:shadow-primary/20 border border-slate-100/50">
                                                    <social.icon className="w-6 h-6" />
                                                </a>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                            </section>

                            {/* PRODUCTS COLLECTION SECTION */}
                            <section class="animate-in fade-in slide-in-from-bottom-12 duration-1000 delay-300">
                                <div class="flex flex-col md:flex-row justify-between items-center md:items-end mb-16 gap-6">
                                    <div class="text-center md:text-left">
                                        <div class="flex items-center gap-3 mb-4 justify-center md:justify-start">
                                            <span class="w-12 h-[2px] bg-amber-400"></span>
                                            <span class="text-[10px] font-black uppercase tracking-[0.4em] text-amber-500">Premium Catalog</span>
                                        </div>
                                        <h2 class="text-4xl md:text-6xl font-black tracking-tighter text-slate-900 leading-none uppercase italic">
                                            Digital Works
                                        </h2>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="text-slate-400 text-sm font-bold uppercase tracking-widest">{products.length} Items Available</p>
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">
                                    {formatted_products.map((product) => (
                                        <ProductCard 
                                            id={product.id}
                                            image={product.image}
                                            title={product.title}
                                            price={product.price}
                                            description={product.description}
                                        />
                                    ))}
                                </div>
                            </section>
                        </>
                    )}
                </main>
            </div>
        )}

        {!merchantData && (
            <>
                {/* HERO SECTION */}
                <section class="relative px-8 pt-12 md:pt-24 pb-32 overflow-hidden bg-surface">
                    <div class="max-w-6xl mx-auto text-center relative z-10">
                        <div class="inline-flex items-center gap-2 px-6 py-2 rounded-full bg-primary/5 text-primary text-[10px] font-black mb-10 tracking-widest uppercase border border-primary/10">
                            <SparklesIcon className="w-4 h-4" />
                            Solusi Kreator Terintegrasi
                        </div>
                        
                        <h1 class="text-6xl md:text-[5.5rem] font-black tracking-tighter text-slate-900 mb-8 leading-[0.95] uppercase">
                            {siteName}. <br/>{siteTagline.split('.')[0]}. <span class="text-primary italic">{siteTagline.split('.')[1] || ''}</span>
                        </h1>
                        
                        <p class="text-lg md:text-xl text-slate-500 max-w-2xl mx-auto mb-16 font-medium leading-relaxed">
                            {branding?.seo_description || branding?.site_tagline || "Bangun halaman profesional, jual aset digital, dan kelola event tanpa coding. Platform andalan untuk kreator modern Indonesia."}
                        </p>
                        
                        <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
                            <a href="/signup" class="w-full sm:w-auto">
                                <Button variant="amber" size="lg" className="w-full px-12 py-5 text-lg shadow-2xl shadow-primary/30 transform hover:scale-105 transition-all duration-300 font-bold">
                                    Mulai Gratis Sekarang
                                </Button>
                            </a>
                            <a href="/login" class="w-full sm:w-auto">
                                <Button variant="outline" size="lg" className="w-full px-12 py-5 text-lg border-2 border-slate-200 hover:bg-white transition-all duration-300 group font-bold">
                                    <ArrowRightOnRectangleIcon className="w-5 h-5 text-slate-400 group-hover:text-primary transition-colors" />
                                    Masuk ke Akun
                                </Button>
                            </a>
                        </div>
                    </div>

                    <div class="mt-24 max-w-7xl mx-auto px-6">
                        <div class="relative rounded-[3rem] overflow-hidden shadow-[0_48px_80px_-16px_rgba(0,0,0,0.12)] bg-surface-container-low p-2 border border-white/50">
                            <img class="w-full h-auto rounded-[2.5rem] shadow-inner border border-slate-100" src="/illustrations/hero_dashboard.png" alt="Dashboard Orbit Site" />
                        </div>
                    </div>
                </section>

                <section class="py-32 px-8 bg-surface-container-low/50">
                    <div class="max-w-7xl mx-auto text-center md:text-left">
                        <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-slate-900 mb-20 uppercase">Ekosistem Kreator</h2>
                        <div class="grid grid-cols-12 gap-8">
                            <div class="col-span-12 md:col-span-8 bg-white p-12 rounded-[2.5rem]">
                                <h3 class="text-3xl font-black mb-4 uppercase">Link-in-Bio Premium</h3>
                                <p class="text-slate-500">Bangun identitas digitalmu dengan desain fleksibel.</p>
                            </div>
                            <div class="col-span-12 md:col-span-4 amber-gradient p-12 rounded-[2.5rem] text-white">
                                <h3 class="text-3xl font-black mb-4 uppercase">Produk Digital</h3>
                                <p>Jual e-book atau aset digital secara instan.</p>
                            </div>
                        </div>
                    </div>
                </section>
                <footer class="py-20 px-8 bg-white border-t border-slate-100">
                    <div class="max-w-7xl mx-auto">
                        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-16">
                            <div class="md:col-span-4">
                                <img src={logoUrl} alt={siteName} class="w-32 h-auto mb-6" />
                                <p class="text-slate-500 text-sm font-medium leading-relaxed mb-8 max-w-sm">
                                    {branding?.site_tagline || 'Satu Link. Semua Kebutuhan Digitalmu. Bangun halaman profesional, jual aset digital, dan kelola event tanpa coding.'}
                                </p>
                                <div class="flex gap-4">
                                    <a href={`mailto:${branding?.support_email}`} class="w-10 h-10 rounded-xl bg-slate-50 text-slate-400 flex items-center justify-center hover:bg-primary hover:text-white transition-all shadow-sm">
                                        <span class="material-symbols-outlined text-lg">mail</span>
                                    </a>
                                    <a href={`https://wa.me/${branding?.whatsapp_number?.replace(/[^0-9]/g, '')}`} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl bg-slate-50 text-slate-400 flex items-center justify-center hover:bg-emerald-500 hover:text-white transition-all shadow-sm">
                                        <span class="material-symbols-outlined text-lg">chat</span>
                                    </a>
                                </div>
                            </div>
                            <div class="md:col-span-2">
                                <h4 class="text-[10px] font-black text-slate-900 uppercase tracking-widest mb-6">Platform</h4>
                                <ul class="space-y-4 text-sm font-bold text-slate-500">
                                    <li><a href="/pricing" class="hover:text-primary transition-colors uppercase tracking-tight">Pricing</a></li>
                                    <li><a href="/academy" class="hover:text-primary transition-colors uppercase tracking-tight">Academy</a></li>
                                    <li><a href="/login" class="hover:text-primary transition-colors uppercase tracking-tight">Login</a></li>
                                    <li><a href="/signup" class="hover:text-primary transition-colors uppercase tracking-tight">Register</a></li>
                                </ul>
                            </div>
                            <div class="md:col-span-3">
                                <h4 class="text-[10px] font-black text-slate-900 uppercase tracking-widest mb-6">Support & Contact</h4>
                                <ul class="space-y-4 text-sm font-bold text-slate-500">
                                    <li class="flex items-center gap-3">
                                        <span class="material-symbols-outlined text-slate-300 text-lg">mail</span>
                                        <span class="lowercase opacity-80">{branding?.support_email || 'support@tepak.id'}</span>
                                    </li>
                                    <li class="flex items-center gap-3">
                                        <span class="material-symbols-outlined text-slate-300 text-lg">chat</span>
                                        <span class="opacity-80">{branding?.whatsapp_number || '+62 8xx'}</span>
                                    </li>
                                </ul>
                            </div>
                            <div class="md:col-span-3">
                                <h4 class="text-[10px] font-black text-slate-900 uppercase tracking-widest mb-6">Office</h4>
                                <p class="text-sm font-bold text-slate-500 leading-relaxed italic opacity-80">
                                    {branding?.office_address || 'Studio Nusantara Hub, 4th Floor, Jl. Sudirman No. 12, Jakarta'}
                                </p>
                            </div>
                        </div>
                        <div class="pt-8 border-t border-slate-100 flex flex-col md:flex-row justify-between items-center gap-4">
                            <p class="text-[10px] font-black text-slate-300 uppercase tracking-widest">
                                © {new Date().getFullYear()} {siteName} - Building the Future of Creator Economy
                            </p>
                            <div class="flex gap-8 text-[10px] font-black text-slate-300 uppercase tracking-widest">
                                <a href="/terms" class="hover:text-slate-900 transition-colors">Terms</a>
                                <a href="/privacy" class="hover:text-slate-900 transition-colors">Privacy</a>
                            </div>
                        </div>
                    </div>
                </footer>
            </>
        )}
    </div>
</BaseLayout>


