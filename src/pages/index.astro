---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button';
import { 
    SparklesIcon, 
    ArrowRightOnRectangleIcon, 
    LinkIcon, 
    ArchiveBoxIcon, 
    TicketIcon, 
    ChartBarIcon, 
    CheckCircleIcon, 
    GlobeAltIcon 
} from '@heroicons/react/24/outline';
---

<BaseLayout title="Tepak.id - Digital Atelier for Modern Creators">
    
    <div class="min-h-screen bg-surface font-['Plus_Jakarta_Sans',sans-serif] selection:bg-primary-container selection:text-on-primary-container">
        
        {/* TOP SPACING (Since Navbar is removed) */}
        <div class="h-12 md:h-20"></div>

        <main>
            {/* HERO SECTION */}
            <section class="relative px-8 pt-12 md:pt-24 pb-32 overflow-hidden bg-surface">
                <div class="max-w-6xl mx-auto text-center relative z-10">
                    <div class="inline-flex items-center gap-2 px-6 py-2 rounded-full bg-primary/5 text-primary text-[10px] font-black mb-10 tracking-widest uppercase border border-primary/10">
                        <SparklesIcon className="w-4 h-4" />
                        Solusi Kreator Terintegrasi
                    </div>
                    
                    <h1 class="text-6xl md:text-[5.5rem] font-black tracking-tighter text-slate-900 mb-8 leading-[0.95] uppercase">
                        Satu Link. <br/>Semua <span class="text-primary italic">Kebutuhan Digitalmu.</span>
                    </h1>
                    
                    <p class="text-lg md:text-xl text-slate-500 max-w-2xl mx-auto mb-16 font-medium leading-relaxed">
                        Bangun halaman profesional, jual aset digital, dan kelola event tanpa coding. Platform andalan untuk kreator modern Indonesia.
                    </p>
                    
                    <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
                        <a href="/signup" class="w-full sm:w-auto">
                            <Button variant="amber" size="lg" className="w-full px-12 py-5 text-lg shadow-2xl shadow-primary/30 transform hover:scale-105 transition-all duration-300 font-bold">
                                Mulai Gratis Sekarang
                            </Button>
                        </a>
                        <a href="/login" class="w-full sm:w-auto">
                            <Button variant="outline" size="lg" className="w-full px-12 py-5 text-lg border-2 border-slate-200 hover:bg-white transition-all duration-300 group font-bold">
                                <ArrowRightOnRectangleIcon className="w-5 h-5 text-slate-400 group-hover:text-primary transition-colors" />
                                Masuk ke Akun
                            </Button>
                        </a>
                    </div>
                </div>

                {/* FEATURED DASHBOARD IMAGE */}
                <div class="mt-24 max-w-7xl mx-auto px-6">
                    <div class="relative rounded-[3rem] overflow-hidden shadow-[0_48px_80px_-16px_rgba(0,0,0,0.12)] bg-surface-container-low p-2 border border-white/50">
                        <img 
                            class="w-full h-auto rounded-[2.5rem] shadow-inner border border-slate-100" 
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDBtpj5z2U8MgkSFoplBXGEROIU7a4RBWoCq63jx-ixXcgu0zZJDTJc0AEEMvpUL0N8k9mTxrL0-cv9UTrnCrY5fGYFlyHr0pDRnTmR-vdAsRlK2pKe334nkcWLHTGR58UW8OKR38wZBgIk7LyPoL1tbncBFGzAfgGORX07Roi5OLjajz8Zxy9mjb6IngENqLVDMI1GqG34dz1aIpZZJ4uL59S94CaH83uxoGBBYTmEJRmuV8Eg2QZZFf3VlwYODYQjwd51U6-Aw3vJ" 
                            alt="Dashboard Tepak.id"
                        />
                    </div>
                </div>

                {/* BACKGROUND DECORATIONS */}
                <div class="absolute top-0 right-0 -mr-24 -mt-24 w-[480px] h-[480px] bg-primary/5 blur-[120px] rounded-full"></div>
                <div class="absolute bottom-0 left-0 -ml-24 -mb-24 w-[480px] h-[480px] bg-primary-container/10 blur-[120px] rounded-full"></div>
            </section>

            {/* BENTO GRID (ECOSYSTEM) */}
            <section class="py-32 px-8 bg-surface-container-low/50">
                <div class="max-w-7xl mx-auto">
                    <div class="mb-20 text-center md:text-left">
                        <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-slate-900 mb-4 uppercase">Ekosistem Kreator</h2>
                        <p class="text-slate-500 font-medium text-lg max-w-xl">Semua alat yang Anda butuhkan untuk berkembang di satu tempat, terintegrasi sempurna.</p>
                    </div>

                    <div class="grid grid-cols-12 gap-6 md:gap-8">
                        {/* FEATURE 1: LINK-IN-BIO (8 COL) */}
                        <div class="col-span-12 md:col-span-8 bg-white p-12 rounded-[2.5rem] flex flex-col justify-between group overflow-hidden relative border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-500">
                            <div>
                                <div class="w-16 h-16 bg-primary-container/10 flex items-center justify-center rounded-2xl mb-8">
                                    <LinkIcon className="w-8 h-8 text-primary" />
                                </div>
                                <h3 class="text-3xl font-black text-slate-900 mb-4 tracking-tight">Link-in-Bio Premium</h3>
                                <p class="text-slate-500 text-lg leading-relaxed max-w-md font-medium">Bangun identitas digitalmu dengan desain yang sepenuhnya fleksibel. Portofolio hidup untuk setiap klik.</p>
                            </div>
                            <img 
                                class="absolute -right-16 -bottom-16 w-80 rotate-12 group-hover:rotate-6 group-hover:scale-105 transition-all duration-700 rounded-3xl shadow-2xl opacity-90" 
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuD77Wt-X5tK2sC8IPIBEL2ss5R4UR_64F1hdMEUhMl7xFirdbzG4Ap1egbeUePolTsXi6wxFJNMnT3AUwgJrGw76UmOoulCMKei3bjzCQkzbe1p7dp4CVqpgIbtD8Kb71PJrAMNY-I144xhAdL6DS5vl32gO1HZXbcde_iSu3TzUpEg4R7Dmt4iLUtWqJqGw_GbIdkyBoY2ScVuLR_pmgjv1BHB17GO9GvQKqG4nkK1ydlItsLg3hRQ5iCvE7JdDr7d0VUXWbLjfkVR" 
                                alt="Link in Bio"
                            />
                        </div>

                        {/* FEATURE 2: DIGITAL PRODUCTS (4 COL) */}
                        <div class="col-span-12 md:col-span-4 amber-gradient p-12 rounded-[2.5rem] text-white border border-white/5 shadow-xl flex flex-col justify-between">
                            <div>
                                <div class="w-16 h-16 bg-white/20 flex items-center justify-center rounded-2xl mb-8 backdrop-blur-md">
                                    <ArchiveBoxIcon className="w-8 h-8 text-white" />
                                </div>
                                <h3 class="text-3xl font-black mb-4 tracking-tight uppercase">Produk Digital</h3>
                                <p class="text-white/80 text-lg leading-relaxed font-medium">Jual e-book, kursus, preset, atau aset digital lainnya secara instan.</p>
                            </div>
                            <div class="mt-12 flex flex-wrap gap-2">
                                <span class="px-4 py-1.5 bg-white/15 rounded-full text-[10px] font-black uppercase tracking-widest border border-white/10">Payment Ready</span>
                                <span class="px-4 py-1.5 bg-white/15 rounded-full text-[10px] font-black uppercase tracking-widest border border-white/10">Delivery</span>
                            </div>
                        </div>

                        {/* FEATURE 3: EVENT TICKETING (4 COL) */}
                        <div class="col-span-12 md:col-span-4 bg-white p-12 rounded-[2.5rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-500">
                            <div class="w-16 h-16 bg-blue-50 flex items-center justify-center rounded-2xl mb-8">
                                <TicketIcon className="w-8 h-8 text-blue-600" />
                            </div>
                            <h3 class="text-2xl font-black text-slate-900 mb-4 tracking-tight uppercase">Tiket Event</h3>
                            <p class="text-slate-500 leading-relaxed font-medium">Kelola workshop, webinar, atau gathering dengan sistem QR pendaftaran otomatis.</p>
                        </div>

                        {/* FEATURE 4: ANALYTICS (8 COL) */}
                        <div class="col-span-12 md:col-span-8 bg-white p-12 rounded-[2.5rem] flex items-center gap-12 border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-500">
                            <div class="flex-1">
                                <div class="w-16 h-16 bg-slate-50 flex items-center justify-center rounded-2xl mb-8">
                                    <ChartBarIcon className="w-8 h-8 text-slate-800" />
                                </div>
                                <h3 class="text-3xl font-black text-slate-900 mb-4 tracking-tight uppercase">Analitik Mendalam</h3>
                                <p class="text-slate-500 text-lg leading-relaxed font-medium">Pahami audiensmu dengan data real-time. Tahu persis apa yang mereka sukai.</p>
                            </div>
                            <div class="flex-1 hidden lg:block">
                                <img 
                                    class="rounded-3xl shadow-xl border border-slate-50" 
                                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuDRB2b9qSLdUUcHPF_8PcsouV7M2N4j1UrCZi_mtk5TcLLVzXVAa16FZc5zvfZNzTc_6PIf7BZpqbbaNxiSZGiQ1kwlGc16p6Phizwu8m-AshXd8XiJ3s07ea6p-OH5TlOhLb1GRxnR31Q7WE9eK30qDKH_iHlwfLSt0goRix-3teWrHbrwVF2bYx5ogdGKukrp5XKCs752LyJE0yx0k37UqsO2agMnHBrEhN_NP5e0z8Rm1XlmPmaCuePycpKdCVL86dc2e3XETQNi" 
                                    alt="Analytics"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            {/* PRICING SECTION */}
            <section class="py-32 px-8 bg-slate-50/80">
                <div class="max-w-5xl mx-auto">
                    <div class="text-center mb-20 text-balance px-4">
                        <h2 class="text-4xl md:text-6xl font-black text-slate-900 mb-6 tracking-tighter uppercase">Pilih Langkah Suksesmu</h2>
                        <p class="text-slate-500 text-lg font-medium">Mulai gratis dan kembangkan bisnismu tanpa batas.</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        {/* STANDARD PLAN */}
                        <div class="bg-white p-12 rounded-[3.5rem] border border-slate-200/50 flex flex-col shadow-[0_32px_64px_-12px_rgba(0,0,0,0.06)] hover:shadow-[0_48px_80px_-16px_rgba(0,0,0,0.1)] transition-all duration-500">
                            <div class="mb-10">
                                <h3 class="text-xs font-black text-slate-400 uppercase tracking-[0.2em] mb-4">Standard</h3>
                                <div class="text-6xl font-black text-slate-900 tracking-tighter uppercase">$0</div>
                                <p class="text-slate-400 mt-4 font-medium leading-relaxed">Selamanya gratis tanpa biaya tersembunyi.</p>
                            </div>
                            <ul class="space-y-6 mb-16 flex-1 text-sm font-bold text-slate-600">
                                <li class="flex items-center gap-4">
                                    <CheckCircleIcon className="w-5 h-5 text-primary" />
                                    Link-in-Bio Custom
                                </li>
                                <li class="flex items-center gap-4">
                                    <CheckCircleIcon className="w-5 h-5 text-primary" />
                                    5 Produk Digital Aktif
                                </li>
                                <li class="flex items-center gap-4">
                                    <CheckCircleIcon className="w-5 h-5 text-primary" />
                                    Laporan Analitik Mingguan
                                </li>
                                <li class="flex items-center gap-4 opacity-30 line-through">
                                    <CheckCircleIcon className="w-5 h-5" />
                                    Domain Kustom (.com)
                                </li>
                            </ul>
                            <a href="/signup" class="w-full">
                                <Button variant="outline" size="lg" className="w-full py-5 rounded-2xl border-none bg-white font-black hover:bg-slate-100">
                                    Daftar Sekarang
                                </Button>
                            </a>
                        </div>

                        {/* PRO PLAN */}
                        <div class="amber-gradient p-12 rounded-[3.5rem] relative overflow-hidden shadow-[0_48px_80px_-16px_rgba(129,85,0,0.25)] flex flex-col group transform hover:-translate-y-2 transition-all duration-500">
                            <div class="absolute top-8 right-8 px-5 py-2 bg-white/20 text-white text-[10px] font-black rounded-full uppercase tracking-widest backdrop-blur-md border border-white/20">
                                Paling Populer
                            </div>
                            <div class="mb-10 text-white">
                                <h3 class="text-xs font-black text-white/60 uppercase tracking-[0.2em] mb-4">Pro Plan</h3>
                                <div class="flex items-baseline gap-2">
                                    <span class="text-6xl font-black tracking-tighter uppercase">$9.90</span>
                                    <span class="text-white/60 font-black text-sm">/bulan</span>
                                </div>
                                <p class="text-white/80 mt-4 font-medium leading-relaxed">Untuk kreator yang siap skala global bisnisnya.</p>
                            </div>
                            <ul class="space-y-6 mb-16 flex-1 text-sm font-bold text-white">
                                <li class="flex items-center gap-4">
                                    <CheckCircleIcon className="w-5 h-5 text-white/50" />
                                    Semua Fitur Standard
                                </li>
                                <li class="flex items-center gap-4">
                                    <CheckCircleIcon className="w-5 h-5 text-white/50" />
                                    Produk & Event Tanpa Batas
                                </li>
                                <li class="flex items-center gap-4">
                                    <CheckCircleIcon className="w-5 h-5 text-white/50" />
                                    Tanpa Branding Tepak.id
                                </li>
                                <li class="flex items-center gap-4">
                                    <CheckCircleIcon className="w-5 h-5 text-white/50" />
                                    Domain Kustom (.id / .com)
                                </li>
                            </ul>
                            <a href="/signup" class="w-full">
                                <Button variant="primary" size="lg" className="w-full py-5 rounded-2xl bg-white text-primary font-black hover:bg-slate-50 shadow-none border-none">
                                    Gunakan PRO Sekarang
                                </Button>
                            </a>
                            
                            {/* AMBER GLOW ELEMENTS */}
                            <div class="absolute -bottom-10 -right-10 w-48 h-48 bg-white/10 blur-[80px] rounded-full"></div>
                        </div>
                    </div>
                </div>
            </section>

            {/* FINAL CTA SECTION */}
            <section class="py-24 px-8 container-padding">
                <div class="max-w-7xl mx-auto amber-gradient rounded-[4rem] p-12 md:p-24 relative overflow-hidden flex flex-col lg:flex-row items-center gap-16 shadow-[0_64px_96px_-24px_rgba(129,85,0,0.3)]">
                    <div class="flex-1 relative z-10 text-center lg:text-left">
                        <h2 class="text-4xl md:text-6xl font-black text-white mb-8 tracking-tighter leading-tight uppercase">Siap Memulai <br/>Workshop Kreatifmu?</h2>
                        <p class="text-white/70 text-xl mb-12 max-w-lg font-medium leading-relaxed">Bergabunglah dengan ribuan kreator lain yang sudah mempercayakan bisnis digitalnya pada tepak.id.</p>
                        <div class="flex flex-col sm:flex-row gap-5 justify-center lg:justify-start">
                            <a href="/signup" class="w-full sm:w-auto">
                                <Button variant="primary" size="lg" className="px-10 py-5 bg-white text-primary font-black rounded-2xl text-lg hover:bg-slate-50 border-none shadow-none font-bold">
                                    Buat Akun Sekarang
                                </Button>
                            </a>
                            <a href="/login" class="w-full sm:w-auto">
                                <Button variant="outline" size="lg" className="px-10 py-5 bg-transparent border-2 border-white/20 text-white font-black rounded-2xl text-lg hover:bg-white/10 font-bold">
                                    Masuk ke Akun
                                </Button>
                            </a>
                        </div>
                    </div>
                    <div class="flex-1 relative hidden lg:block">
                        <div class="relative">
                            <div class="absolute -inset-4 bg-white/10 blur-3xl rounded-full"></div>
                            <img 
                                class="rounded-[3rem] shadow-2xl rotate-3 relative z-10 group-hover:rotate-0 transition-all duration-500 border-4 border-white/10" 
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuC7vmVViuHoDfJy_BnT72bT7sJwiCRmteEPB1wPyomwJZ2NCIRkz_n82qlQzuHyrRzpIVuPDJKXiCXA1uKD6BcLUwah_XrDIV8OGxBhfbEs2-O5RyS0Mienr0Uz1-AH4tMIUB_tbnwjfxeN_S6KbKV-SiX21s8z_YpcYKVTVjD1M1zkXLePEigFNjg3uirSrMQKQ0jr9GjVwsh1L8i0_x6vivLzsnmIIeZ0MoJi1cglQ4GNFwIAfM3gOEf3oM-fHItd160WSUMhtUHz" 
                                alt="Community"
                            />
                        </div>
                    </div>
                </div>
            </section>
        </main>

        {/* FOOTER SECTION */}
        <footer class="bg-surface py-24 px-8 border-t border-slate-50">
            <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16">
                <div class="col-span-1 lg:col-span-1">
                    <span class="text-3xl font-black text-slate-900 tracking-tighter block mb-8 uppercase">tepak.id</span>
                    <p class="text-slate-500 font-medium leading-relaxed max-w-xs">
                        Membangun ekosistem ekonomi kreator yang lebih inklusif dan profesional di Nusantara.
                    </p>
                </div>
                <div>
                    <h4 class="font-black text-slate-900 mb-8 uppercase tracking-[0.2em] text-[10px]">Produk</h4>
                    <ul class="space-y-5 text-slate-400 font-bold text-sm">
                        <li><a class="hover:text-primary transition-colors" href="#">Link-in-Bio</a></li>
                        <li><a class="hover:text-primary transition-colors" href="#">Produk Digital</a></li>
                        <li><a class="hover:text-secondary transition-colors" href="#">Tiket Event</a></li>
                        <li><a class="hover:text-secondary transition-colors" href="#">Analitik</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-black text-slate-900 mb-8 uppercase tracking-[0.2em] text-[10px]">Perusahaan</h4>
                    <ul class="space-y-5 text-slate-400 font-bold text-sm">
                        <li><a class="hover:text-primary transition-colors" href="#">Tentang Kami</a></li>
                        <li><a class="hover:text-primary transition-colors" href="#">Karier</a></li>
                        <li><a class="hover:text-secondary transition-colors" href="#">Keamanan</a></li>
                        <li><a class="hover:text-secondary transition-colors" href="#">Kontak</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-black text-slate-900 mb-8 uppercase tracking-[0.2em] text-[10px]">Ikuti Kami</h4>
                    <div class="flex gap-4">
                        {[1, 2, 3].map((i) => (
                            <a href="#" class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-400 hover:bg-primary hover:text-white transition-all duration-300 shadow-sm">
                                <GlobeAltIcon className="w-6 h-6" />
                            </a>
                        ))}
                    </div>
                </div>
            </div>
            
            <div class="max-w-7xl mx-auto mt-24 pt-10 border-t border-slate-50 flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] font-black text-slate-300 uppercase tracking-widest">
                <p>© 2024 tepak.id. Semua hak cipta dilindungi.</p>
                <div class="flex gap-10">
                    <a class="hover:text-primary transition-colors" href="#">Kebijakan Privasi</a>
                    <a class="hover:text-primary transition-colors" href="#">Syarat & Ketentuan</a>
                </div>
            </div>
        </footer>
    </div>

</BaseLayout>

