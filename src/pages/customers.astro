---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { CustomersDashboard } from '../components/customers/CustomersDashboard';
import { BottomNavbar } from '../components/layout/BottomNavbar';

const user = await Astro.locals.getUser();
const supabase = Astro.locals.supabase;

if (!user || !supabase) {
    return Astro.redirect('/login');
}

let hasCustomerFeature = false;
try {
    const { data: settings } = await supabase
        .from('user_settings')
        .select('plan_status')
        .eq('user_id', user.id)
        .single();
        
    const planId = settings?.plan_status || 'free';

    const { data: planDetails } = await supabase
        .from('subscription_plans')
        .select('features')
        .eq('id', planId)
        .single();
        
    if (planDetails && Array.isArray(planDetails.features) && planDetails.features.includes('Customer Management')) {
        hasCustomerFeature = true;
    }
} catch (e) {}

if (!hasCustomerFeature) {
    return Astro.redirect('/plan-info?upgrade=required');
}
---

<BaseLayout title="Customer Management - Orbit Site">
    <div class="flex h-screen bg-[#F8FAFC]">
        {/* Sidebar Desktop */}
        <LightSidebar activePage="customers" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col h-screen overflow-hidden" style="padding-top: 5rem">
            <LightTopNavbar client:load />
            {/* The Dashboard acts as the main scrollable area */}
            <main class="flex-1 overflow-y-auto pb-32">
                <CustomersDashboard client:load />
            </main>

            <!-- Bottom Navigation for Mobile -->
            <BottomNavbar activePage="customers" client:load />
        </div>
    </div>
</BaseLayout>
