---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button';
import Input from '../components/ui/Input';
import { KeyIcon, EnvelopeIcon, ArrowRightIcon, ArrowLeftIcon } from '@heroicons/react/24/outline';
---

<BaseLayout title="Lupa Kata Sandi - Orbit Site">
    
    <div class="min-h-screen bg-slate-50 flex flex-col items-center justify-center p-4 md:p-8 font-['Plus_Jakarta_Sans',sans-serif]">
        
        {/* BRAND LOGO FOR DESKTOP (TOP LEFT) */}
        <div class="fixed top-10 left-10 hidden lg:block">
            <a href="/">
                <img src="/logo-light.png" alt="Orbit Site" class="w-32 h-auto" />
            </a>
        </div>

        {/* MAIN CONTAINER */}
        <main class="w-full max-w-5xl bg-white rounded-[2.5rem] shadow-[0_32px_64px_-12px_rgba(0,0,0,0.08)] overflow-hidden flex flex-col md:flex-row min-h-[640px] border border-slate-50">
            
            {/* LEFT SECTION: ILLUSTRATION (AMBER GRADIENT) */}
            <div class="w-full md:w-5/12 amber-gradient flex flex-col items-center justify-center p-12 text-white relative overflow-hidden">
                {/* DECORATIVE ELEMENTS */}
                <div class="absolute top-0 right-0 w-40 h-40 bg-white/10 rounded-full -mr-20 -mt-20 blur-2xl"></div>
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-black/5 rounded-full -ml-32 -mb-32 blur-3xl"></div>
                
                <div class="relative z-10 flex flex-col items-center text-center">
                    <div class="w-32 h-32 bg-white/20 backdrop-blur-xl rounded-[2rem] flex items-center justify-center mb-10 shadow-2xl border border-white/30">
                        <KeyIcon className="w-16 h-16 text-white" />
                    </div>
                    <h2 class="text-3xl font-black mb-4 tracking-tight uppercase">Keamanan Akun</h2>
                    <p class="text-white/80 text-sm leading-relaxed max-w-[240px] font-medium">
                        Kami membantu Anda memulihkan akses ke akun Anda dengan sistem enkripsi tingkat tinggi.
                    </p>
                </div>
            </div>

            {/* RIGHT SECTION: FORM */}
            <div class="w-full md:w-7/12 p-10 md:p-20 flex flex-col justify-center">
                <div class="space-y-10">
                    <header class="space-y-4">
                        <h1 class="text-4xl font-black text-slate-900 tracking-tight leading-tight uppercase">
                            Lupa Kata Sandi?
                        </h1>
                        <p class="text-slate-500 text-lg leading-relaxed font-medium">
                            Masukkan email terdaftar. Kami akan mengirimkan instruksi untuk membuat password baru.
                        </p>
                    </header>

                    <form class="space-y-8" action="/reset-sent">
                        <div class="space-y-3">
                            <label class="block text-[10px] font-black text-primary tracking-[0.2em] uppercase ml-1">
                                Alamat Email Anda
                            </label>
                            <Input 
                                iconLeft={EnvelopeIcon}
                                type="email" 
                                placeholder="nama@perusahaan.com" 
                                className="h-14 text-base"
                                required
                            />
                        </div>

                        <Button variant="amber" size="lg" className="w-full py-4 shadow-xl shadow-primary/20 group">
                            <span>Kirim Instruksi Pemulihan</span>
                            <ArrowRightIcon className="w-5 h-5 group-hover:translate-x-1 transition-transform" />
                        </Button>
                    </form>

                    <div class="pt-10 border-t border-slate-50">
                        <a href="/login" class="inline-flex items-center gap-3 text-slate-400 font-black hover:text-primary transition-all group text-xs uppercase tracking-widest">
                            <ArrowLeftIcon className="w-5 h-5 group-hover:-translate-x-2 transition-transform" />
                            Kembali ke Login
                        </a>
                    </div>
                </div>
            </div>
        </main>

        {/* FOOTER COPYRIGHT */}
        <footer class="mt-12 text-slate-300 text-[10px] font-black uppercase tracking-widest">
            © 2024 Orbit Site - Precision Digital Ecosystem
        </footer>

    </div>

</BaseLayout>

