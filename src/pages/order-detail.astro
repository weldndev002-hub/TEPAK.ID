---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { OrderDetailDashboard } from '../components/orders/OrderDetailDashboard';
---

<BaseLayout title="Detail Pesanan - Tepak.id">
    <div class="flex h-screen bg-[#F8FAFC]">
        {/* Sidebar Desktop */}
        <LightSidebar activePage="orders" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col h-screen overflow-hidden">
            <main class="flex-1 overflow-y-auto">
                <OrderDetailDashboard client:load />
            </main>
        </div>
    </div>
</BaseLayout>
<style is:global>
    @media print {
        .no-print, 
        aside, 
        nav, 
        [class*="Sidebar"],
        header button,
        .fixed {
            display: none !important;
        }
        
        .flex, .flex-1, .h-screen {
            display: block !important;
            height: auto !important;
            overflow: visible !important;
        }
        
        main {
            overflow: visible !important;
            padding: 0 !important;
        }
        
        body, html {
            background-color: white !important;
            height: auto !important;
            overflow: visible !important;
        }
    }
</style>
