---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { PayoutForm } from '../components/wallet/PayoutForm';
---

<BaseLayout title="Tarik Saldo | Tepak.id">
    <div class="flex h-screen bg-[#F8FAFC]">
        {/* Sidebar Desktop */}
        <LightSidebar activePage="wallet" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col h-screen overflow-hidden">
            <LightTopNavbar client:load />
            
            {/* The Dashboard acts as the main scrollable area */}
            <main class="flex-1 overflow-y-auto p-10 flex items-center justify-center">
                <PayoutForm client:load />
            </main>
        </div>
    </div>
</BaseLayout>
