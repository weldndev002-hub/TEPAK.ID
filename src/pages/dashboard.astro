---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { IntegratedStatsGrid } from '../components/dashboard/IntegratedStatsGrid';
import { AnalyticsChart } from '../components/dashboard/AnalyticsChart';
import { DeviceBreakdown } from '../components/dashboard/DeviceBreakdown';
import { BrowserPerformance } from '../components/dashboard/BrowserPerformance';
import { TopLinksTable } from '../components/dashboard/TopLinksTable';
import { TrafficSourceAnalytics } from '../components/dashboard/TrafficSourceAnalytics';
import { ConversionFunnel } from '../components/dashboard/ConversionFunnel';
import { GeoAnalytics } from '../components/dashboard/GeoAnalytics';
import { BottomNavbar } from '../components/layout/BottomNavbar';
import Button from '../components/ui/Button';
import { 
  EyeIcon, 
  CursorArrowRaysIcon, 
  ClockIcon, 
  CurrencyDollarIcon,
  ArrowDownTrayIcon,
  ShareIcon
} from '@heroicons/react/24/outline';

const user = await Astro.locals.getUser();
if (user) {
  // Check profile first to avoid forcing admins into onboarding/redirects
  const { data: profile } = await Astro.locals.supabase
    .from('profiles')
    .select('role')
    .eq('id', user.id)
    .single();

  const isAdmin = profile?.role === 'admin';

  if (!isAdmin) {
    const { data: settings } = await Astro.locals.supabase
      .from('user_settings')
      .select('domain_name')
      .eq('user_id', user.id)
      .single();
      
    if (!settings?.domain_name) {
      return Astro.redirect('/onboarding');
    }
  }
}

---

<BaseLayout title="Atelier Dashboard — Real-time Pulse">
    <div class="flex min-h-screen bg-white font-['Plus_Jakarta_Sans',sans-serif]">
        <!-- Sidebar B (Light) -->
        <LightSidebar activePage="dashboard" client:load />

        <div class="flex-1 flex flex-col transition-all duration-300" style="padding-top: calc(var(--banner-height, 0px) + 5rem)">
            <!-- Header B (Light) -->
            <LightTopNavbar client:load />

            <!-- MAIN WORKSPACE -->
            <main class="p-8 overflow-y-auto w-full max-w-[1440px] ">
                <!-- Page Header Section -->
                <div class="flex items-end justify-between mb-10">
                    <div>
                        <span class="text-[10px] font-black text-primary uppercase tracking-[0.2em] mb-2 block">Performance Overview</span>
                        <h3 class="text-3xl font-black text-slate-900 tracking-tight uppercase">Real-time Pulse</h3>
                    </div>
                    <div class="flex gap-3 no-print">
                        <Button id="export-pdf-btn" variant="ghost" className="bg-slate-50 border-slate-100 flex items-center gap-2 font-black text-[11px] uppercase tracking-wider">
                            <ArrowDownTrayIcon className="w-4 h-4" /> Export PDF
                        </Button>
                        <Button id="share-report-btn" variant="primary" className="bg-primary hover:bg-primary/90 flex items-center gap-2 font-black text-[11px] uppercase tracking-wider shadow-sm">
                            <ShareIcon className="w-4 h-4" /> Share Report
                        </Button>
                    </div>
                </div>

                {/* Top Row: Metrics (Real-time) */}
                <div id="dashboard-content">
                    <IntegratedStatsGrid client:load />

                    <!-- Middle Section: Main Chart & Device Breakdown -->
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
                        <div class="lg:col-span-2">
                            <AnalyticsChart client:visible />
                        </div>
                        <div>
                            <DeviceBreakdown client:visible />
                        </div>
                    </div>

                    <!-- NEW: Advanced Analytics (PRO) Section -->
                    <div class="mb-12">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="h-px flex-1 bg-slate-100"></div>
                            <div class="px-6 py-2 bg-blue-50 rounded-full border border-blue-100">
                                <span class="text-[10px] font-black text-blue-600 uppercase tracking-[0.3em]">Pro Performance Insights</span>
                            </div>
                            <div class="h-px flex-1 bg-slate-100"></div>
                        </div>

                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
                            <TopLinksTable client:visible />
                            <TrafficSourceAnalytics client:visible />
                        </div>

                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <ConversionFunnel client:visible />
                            <div class="grid grid-cols-1 gap-6">
                                <BrowserPerformance client:visible />
                                <GeoAnalytics client:visible />
                            </div>
                        </div>
                    </div>
                </div>
            </main>

            <!-- Bottom Navigation Bar (Mobile only) -->
            <BottomNavbar activePage="dashboard" client:load />
        </div>
    </div>

    <style is:global>
        @media print {
            .no-print, aside, nav, button, .bottom-navbar {
                display: none !important;
            }
            body {
                background: white !important;
                padding: 0 !important;
            }
            main {
                padding: 0 !important;
                margin: 0 !important;
                max-width: 100% !important;
            }
            #dashboard-content {
                display: block !important;
            }
            .flex-1 {
                padding-top: 0 !important;
            }
        }
    </style>

    <script>
        // Handle Export PDF
        const exportBtn = document.getElementById('export-pdf-btn');
        if (exportBtn) {
            exportBtn.addEventListener('click', () => {
                window.print();
            });
        }

        // Handle Share Report
        const shareBtn = document.getElementById('share-report-btn');
        if (shareBtn) {
            shareBtn.addEventListener('click', async () => {
                const shareData = {
                    title: 'Laporan Performa Tepak.ID',
                    text: 'Lihat ringkasan performa digital saya di Tepak.ID.',
                    url: window.location.href
                };

                try {
                    if (navigator.share) {
                        await navigator.share(shareData);
                    } else {
                        // Fallback: Copy to clipboard
                        await navigator.clipboard.writeText(window.location.href);
                        // @ts-ignore
                        window.toast.success('Link laporan berhasil disalin ke clipboard!');

                    }
                } catch (err) {
                    console.error('Error sharing:', err);
                }
            });
        }
    </script>
</BaseLayout>
