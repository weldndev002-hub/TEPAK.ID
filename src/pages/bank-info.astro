---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { UnifiedSettings } from '../components/settings/UnifiedSettings';
import { BottomNavbar } from '../components/layout/BottomNavbar';
---

<BaseLayout title="Payout Method | Tepak.id">
    <div class="flex h-screen bg-slate-50">
        <!-- Sidebar Desktop -->
        <LightSidebar activePage="settings" client:load />

        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col h-screen overflow-hidden" style="padding-top: 5rem">
            <LightTopNavbar client:load />
            
            {/* The Dashboard acts as the main scrollable area */}
            <main class="flex-1 overflow-y-auto p-8">
                <UnifiedSettings defaultTab="bank" client:load />
            </main>

            <BottomNavbar activePage="settings" client:load />
        </div>
    </div>
</BaseLayout>
