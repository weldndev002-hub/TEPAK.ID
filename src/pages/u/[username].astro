---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCardWithTracking from '../../components/public/ProductCardWithTracking';
import { 
    CheckBadgeIcon, 
    ArrowRightIcon
} from '@heroicons/react/24/solid';
import { AnalyticsTracker } from '../../components/analytics/AnalyticsTracker';
import PublicCreatorProfile from '../../components/public/PublicCreatorProfile.astro';

// 1. Detect Hostname & Identity
const hostname = Astro.url.hostname;
const supabase = Astro.locals.supabase;

const { username } = Astro.params;

let merchantData = null;
let products = [];
let formatted_products = [];
let blocks = [];

try {
    if (!supabase) {
        console.error('[Public Profile Error] Supabase is null.');
        throw new Error('Database connection not initialized');
    }
    // 1. Fetch Profile Data (Robust Lookup: Username OR Subdomain)
    const { data: profileByUsername } = await supabase
        .from('profiles')
        .select('*, user_settings(*)')
        .eq('username', username)
        .single();
    
    let profileData = profileByUsername;

    // Fallback: If not found by username, search by custom subdomain in user_settings
    if (!profileData) {
        const { data: profileBySubdomain } = await supabase
            .from('user_settings')
            .select('*, profiles(*)')
            .eq('domain_name', username)
            .single();
        
        if (profileBySubdomain) {
            profileData = {
                ...profileBySubdomain.profiles,
                user_settings: Array.isArray(profileBySubdomain) ? profileBySubdomain[0] : profileBySubdomain
            };
        }
    }
    
    if (profileData) {
        const settings = Array.isArray(profileData.user_settings) ? profileData.user_settings[0] : profileData.user_settings;
        merchantData = {
            ...(settings || {}),
            profiles: { ...profileData }
        };

        // Auto-revert expired subscription for this creator
        let activePlanId = settings?.plan_status || 'free';
        if (activePlanId !== 'free' && settings?.plan_expiry) {
            const expiry = new Date(settings.plan_expiry);
            if (new Date() > expiry) {
                console.log(`[PublicProfile] Plan expired for creator ${profileData.id}. Treating as free.`);
                // Update database in background
                supabase.from('user_settings').update({ plan_status: 'free', auto_renewal: false }).eq('user_id', profileData.id);
                activePlanId = 'free';
                merchantData.plan_status = 'free';
            }
        }

        // Fetch creator's active plan features AND config
        let creatorFeatures: string[] = [];
        let allowedBlockTypes: string[] | null = null; // null = all allowed
        if (activePlanId) {
            const { data: planDetails } = await supabase
                .from('subscription_plans')
                .select('features, config')
                .eq('id', activePlanId)
                .single();
            creatorFeatures = planDetails?.features || [];
            // If config.allowed_blocks is explicitly set, use it as a filter
            if (planDetails?.config?.allowed_blocks !== undefined) {
                allowedBlockTypes = planDetails.config.allowed_blocks as string[];
            }
        }

        const hasCommerceFeature = creatorFeatures.includes('Digital Product Sales');
        const hasLandingPageFeature = creatorFeatures.includes('Landing Page Builder');

        // 2. Fetch Products (only if creator's plan allows Digital Product Sales)
        if (hasCommerceFeature) {
            const [{ data: productList }, { data: viewsData }] = await Promise.all([
                supabase
                    .from('products')
                    .select('*')
                    .eq('merchant_id', profileData.id || profileData.user_id)
                    .eq('status', 'published')
                    .order('created_at', { ascending: false }),
                supabase
                    .from('analytics_events')
                    .select('product_id, event_type')
                    .eq('merchant_id', profileData.id || profileData.user_id)
                    .in('event_type', ['view', 'page_view'])
            ]);

            products = productList || [];
            const viewCounts = viewsData || [];

            formatted_products = products.map(p => ({
                id: p.id,
                title: p.title,
                price: new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(p.price),
                sale_price: (p.sale_price !== null && p.sale_price !== undefined) ? new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(p.sale_price) : null,
                description: p.description,
                image: p.cover_url || "https://images.unsplash.com/photo-1544006659-f0b21f04cb1b?w=400&h=400&fit=crop",
                views_count: viewCounts.filter((v: any) => v.product_id === p.id).length
            }));
        }

        // 3. Blocks — only if Landing Page Builder is enabled AND block type is allowed
        if (hasLandingPageFeature) {
            const rawBlocks: any[] = merchantData.profiles?.blocks || [];
            if (allowedBlockTypes !== null) {
                // Filter: only show blocks whose type is in the allowed list
                blocks = rawBlocks.filter((b: any) => allowedBlockTypes!.includes(b.type));
            } else {
                // No restriction configured → show all
                blocks = rawBlocks;
            }
        }
    }
} catch (err) {
    console.error('[Public Profile Error]', err);
}

// Error Handling for User Not Found
if (!merchantData) {
    return new Response('Kreator dengan username "' + username + '" tidak ditemukan di database.', { status: 404 });
}

// 3. Restriction Check
if (merchantData.profiles?.is_banned) {
    return new Response(null, { 
        status: 403,
        statusText: 'Account Restricted'
    });
}

// Data Mapping
const profile = {
    name: merchantData.profiles?.full_name || "Merchant",
    bio: merchantData.profiles?.bio || "Welcome to my digital store.",
    avatar: merchantData.profiles?.avatar_url || "https://images.unsplash.com/photo-1544006659-f0b21f04cb1b?w=400&h=400&fit=crop",
    email: merchantData.profiles?.email,
    is_verified: true,
};

const seo = {
    title: merchantData.seo_title || `${profile.name} | tepakiid.weldn-dev-002.workers.dev Ecosystem`,
    description: merchantData.seo_description || profile.bio,
    image: merchantData.seo_image || profile.avatar
};


// Brand Icons as SVGs
const BrandIcons = {
