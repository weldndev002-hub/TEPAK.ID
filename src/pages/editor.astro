---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CreatorAtelierEditor } from '../components/editor/CreatorAtelierEditor';
import { createClient } from '@supabase/supabase-js';

const supabase = Astro.locals.supabase;

let branding: any = null;
if (supabase) {
    try {
        const { data } = await supabase
          .from('platform_configs')
          .select('*')
          .eq('id', 1)
          .single();
        branding = data;
    } catch (e) {
        console.error('[Editor] Branding Fetch Error:', e);
    }
}
---

<BaseLayout title="Creator Atelier Editor | Orbit Site">
  <main class="min-h-screen bg-slate-50">
    <CreatorAtelierEditor initialBranding={branding} client:load />
  </main>
</BaseLayout>
