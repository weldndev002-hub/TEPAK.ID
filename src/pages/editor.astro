---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CreatorAtelierEditor } from '../components/editor/CreatorAtelierEditor';

const user = await Astro.locals.getUser();
const supabase = Astro.locals.supabase;

if (!user || !supabase) {
    return Astro.redirect('/login');
}

let hasEditorFeature = false;
try {
    const { data: settings } = await supabase
        .from('user_settings')
        .select('plan_status')
        .eq('user_id', user.id)
        .single();
        
    const planId = settings?.plan_status || 'free';

    const { data: planDetails } = await supabase
        .from('subscription_plans')
        .select('features')
        .eq('id', planId)
        .single();
        
    if (planDetails && Array.isArray(planDetails.features) && planDetails.features.includes('Landing Page Builder')) {
        hasEditorFeature = true;
    }
} catch (e) {}

if (!hasEditorFeature) {
    return Astro.redirect('/plan-info?upgrade=required');
}

let branding: any = null;
if (supabase) {
    try {
        const { data } = await supabase
          .from('platform_configs')
          .select('*')
          .eq('id', 1)
          .single();
        branding = data;
    } catch (e) {
        console.error('[Editor] Branding Fetch Error:', e);
    }
}
---

<BaseLayout title="Creator Atelier Editor | Orbit Site">
  <main class="min-h-screen bg-slate-50">
    <CreatorAtelierEditor initialBranding={branding} client:load />
  </main>
</BaseLayout>
