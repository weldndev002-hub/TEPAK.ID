---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button';
import { 
    CheckCircleIcon, 
    SparklesIcon, 
    BoltIcon, 
    ShieldCheckIcon,
    ArrowRightIcon
} from '@heroicons/react/24/solid';
const supabase = Astro.locals.supabase;

let branding: any = null;
let plans: any[] = [];

if (supabase) {
    try {
        // 1. Fetch Branding
        const { data: bData } = await supabase
          .from('platform_configs')
          .select('*')
          .eq('id', 1)
          .single();
        branding = bData;

        // 2. Fetch Dynamic Plans
        const { data: pData } = await supabase
            .from('subscription_plans')
            .select('*')
            .eq('is_active', true)
            .order('price_monthly', { ascending: true });
        plans = pData || [];
    } catch (e) {
        console.error('[Pricing] Data Fetch Error:', e);
    }
}

const siteName = branding?.site_name || 'Tepak.ID';
const logoUrl = branding?.logo_url || '/logo-light.png';

const formattedPlans = plans.map(plan => ({
    ...plan,
    features: Array.isArray(plan.features) ? plan.features : []
}));

const seo = {
    title: `Pricing - Pilih Paket Terbaik Anda | ${siteName}`,
    description: `Pilih paket langganan ${siteName} yang sesuai dengan kebutuhan bisnis digital Anda.`
};
---

<BaseLayout title={seo.title} description={seo.description}>
    <div class="min-h-screen bg-[#F8FAFC] text-slate-900 font-sans antialiased">
        
        {/* Navigation (Simplified from index.astro style) */}
        <nav class="fixed top-0 left-0 right-0 z-[100] bg-white/80 backdrop-blur-xl border-b border-slate-100">
            <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
                <a href="/" class="flex items-center gap-3">
                    <img src={logoUrl} alt={siteName} class="h-8" />
                    <span class="text-xl font-black tracking-tighter text-slate-900 uppercase italic">{siteName}</span>
                </a>
                <div class="flex items-center gap-4">
                    <a href="/login" class="text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-primary transition-all px-4">Masuk</a>
                    <a href="/signup">
                        <Button variant="primary" className="rounded-full px-8 py-2 text-[10px] bg-primary text-white">Daftar Sekarang</Button>
                    </a>
                </div>
            </div>
        </nav>

        <main class="pt-40 pb-32 max-w-7xl mx-auto px-6">
            
            {/* Header Section */}
            <div class="text-center mb-24 animate-in fade-in slide-in-from-bottom-8 duration-700">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 text-primary mb-6 border border-primary/20">
                    <SparklesIcon className="w-4 h-4" />
                    <span class="text-[10px] font-black uppercase tracking-[0.2em]">Pilih Rencana Kesuksesanmu</span>
                </div>
                <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-slate-900 mb-6 uppercase italic">
                    Harga Transparan, <br class="hidden md:block" /> Tanpa Biaya Tersembunyi.
                </h1>
                <p class="text-slate-500 text-lg md:text-xl font-medium max-w-2xl mx-auto leading-relaxed">
                    Mulai dengan gratis dan tingkatkan paket Anda seiring pertumbuhan bisnis digital Anda di {siteName}.
                </p>
            </div>

            {/* Pricing Cards Grid */}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {formattedPlans.map((plan) => (
                    <div class={`relative group animate-in fade-in slide-in-from-bottom-12 duration-1000 ${plan.id === 'pro' ? 'delay-200' : 'delay-0'}`}>
                        <div class={`h-full bg-white rounded-[2.5rem] p-10 border transition-all duration-500 flex flex-col ${
                            plan.id === 'pro' 
                            ? 'border-primary shadow-[0_32px_64px_-16px_rgba(255,185,76,0.2)] scale-105 z-10' 
                            : 'border-slate-100 shadow-sm hover:shadow-xl hover:border-slate-200'
                        }`}>
                            
                            {plan.badge && plan.badge !== 'DEFAULT' && (
                                <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-primary text-white px-6 py-2 rounded-full text-[10px] font-black uppercase tracking-[0.2em] shadow-xl">
                                    {plan.badge}
                                </div>
                            )}

                            <div class="mb-10">
                                <h3 class="text-3xl font-black text-slate-900 mb-2 uppercase italic">{plan.name}</h3>
                                <p class="text-slate-400 text-sm font-medium leading-relaxed">{plan.description}</p>
                            </div>

                            <div class="mb-10">
                                <div class="flex items-baseline gap-1">
                                    <span class="text-5xl font-black text-slate-900 italic tracking-tighter">
                                        {plan.price_monthly === 0 ? 'Gratis' : `Rp ${Number(plan.price_monthly).toLocaleString('id-ID')}`}
                                    </span>
                                    {plan.price_monthly > 0 && <span class="text-slate-400 font-bold text-sm uppercase tracking-widest">/Bulan</span>}
                                </div>
                                {plan.price_yearly > 0 && (
                                    <p class="text-primary text-[10px] font-black uppercase tracking-widest mt-2">
                                        Hemat 20% jika bayar tahunan
                                    </p>
                                )}
                            </div>

                            <div class="flex-1 space-y-5 mb-12">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Apa yang Anda dapatkan:</p>
                                <ul class="space-y-4">
                                    {plan.features.map((feature: string) => (
                                        <li class="flex items-start gap-3">
                                            <div class="mt-1">
                                                <CheckCircleIcon className={`w-5 h-5 ${plan.id === 'pro' ? 'text-primary' : 'text-slate-300'}`} />
                                            </div>
                                            <span class="text-sm font-bold text-slate-600 leading-tight">{feature}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>

                            <a href={plan.price_monthly === 0 ? '/signup' : '/login'} class="block mt-auto">
                                <Button 
                                    variant={plan.id === 'pro' ? 'primary' : 'ghost'} 
                                    className={`w-full py-5 rounded-2xl font-black text-xs uppercase tracking-widest transition-all ${
                                        plan.id === 'pro' 
                                        ? 'bg-primary text-white shadow-xl shadow-primary/20 hover:scale-[1.02] active:scale-95' 
                                        : 'bg-slate-50 text-slate-600 hover:bg-slate-100'
                                    }`}
                                >
                                    {plan.price_monthly === 0 ? 'Mulai Gratis' : 'Pilih Paket Pro'}
                                </Button>
                            </a>
                        </div>
                    </div>
                ))}
            </div>

            {/* Feature Comparison Section (Simple) */}
            <div class="mt-32 pt-32 border-t border-slate-100">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
                    <div>
                        <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-slate-900 mb-8 uppercase italic leading-none">
                            Keamanan dan <br /> Kepercayaan <br /> Tanpa Kompromi.
                        </h2>
                        <ul class="space-y-8">
                            <li class="flex gap-6">
                                <div class="w-14 h-14 bg-white rounded-2xl shadow-sm border border-slate-100 flex items-center justify-center shrink-0">
                                    <ShieldCheckIcon className="w-6 h-6 text-primary" />
                                </div>
                                <div>
                                    <h4 class="text-lg font-black text-slate-900 uppercase italic underline underline-offset-4 decoration-primary/30">Enkripsi Data 256-bit</h4>
                                    <p class="text-slate-500 text-sm font-medium mt-1">Semua transaksi dan data pribadi Anda dilindungi dengan standar keamanan tertinggi.</p>
                                </div>
                            </li>
                            <li class="flex gap-6">
                                <div class="w-14 h-14 bg-white rounded-2xl shadow-sm border border-slate-100 flex items-center justify-center shrink-0">
                                    <BoltIcon className="w-6 h-6 text-primary" />
                                </div>
                                <div>
                                    <h4 class="text-lg font-black text-slate-900 uppercase italic underline underline-offset-4 decoration-primary/30">Infrastruktur Global</h4>
                                    <p class="text-slate-500 text-sm font-medium mt-1">Halaman Anda akan dimuat super cepat di seleruh dunia berkat jaringan Cloudflare Edge.</p>
                                </div>
                            </li>
                        </ul>
                    </div>
                    <div class="relative">
                        <div class="aspect-square bg-gradient-to-br from-primary/20 via-primary/5 to-transparent rounded-[4rem] animate-pulse"></div>
                        <div class="absolute inset-10 bg-white rounded-[3rem] shadow-2xl border border-slate-100 p-8 flex flex-col justify-between">
                            <div class="space-y-4">
                                <div class="w-12 h-1.5 bg-slate-100 rounded-full"></div>
                                <div class="w-24 h-1.5 bg-slate-100 rounded-full"></div>
                                <div class="w-20 h-1.5 bg-slate-100 rounded-full"></div>
                            </div>
                            <div class="flex items-center justify-between">
                                <div class="flex -space-x-2">
                                    {[1,2,3,4].map(i => (
                                        <div class="w-8 h-8 rounded-full border-2 border-white bg-slate-200"></div>
                                    ))}
                                </div>
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Join 4,200+ Creators</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </main>

        {/* Footer (Simplified from index.astro) */}
        <footer class="w-full py-32 bg-white border-t border-slate-100">
            <div class="max-w-7xl mx-auto px-6 text-center">
                <img src={logoUrl} alt={siteName} class="h-8 mx-auto mb-8 opacity-20 grayscale" />
                <p class="text-slate-400 text-xs font-black uppercase tracking-[0.2em] mb-12 italic">© 2024 {siteName}. Precision Built for Growth.</p>
                <div class="flex flex-wrap justify-center gap-8">
                    {['Beranda', 'Tentang Kami', 'Bantuan', 'Ketentuan'].map(link => (
                        <a href="#" class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-primary transition-all">{link}</a>
                    ))}
                </div>
            </div>
        </footer>

    </div>
</BaseLayout>
