---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { DomainSettingsDashboard } from '../components/settings/DomainSettings';

// Server-side feature gating
const { supabase } = Astro.locals;
const session = await supabase.auth.getSession();
const user = session.data.session?.user;

if (!user) {
    return Astro.redirect('/login');
}

// Fetch user settings and plan features
const { data: settings } = await supabase
    .from('user_settings')
    .select('plan_status')
    .eq('user_id', user.id)
    .single();

const planId = settings?.plan_status || 'free';

const { data: plan } = await supabase
    .from('subscription_plans')
    .select('features')
    .eq('id', planId)
    .single();

const features = plan?.features || [];
const hasDomainFeature = features.includes('Custom Domain (CNAME)');

if (!hasDomainFeature) {
    return Astro.redirect('/dashboard?error=feature_locked');
}
---

<BaseLayout title="Domain Settings | Creator Hub">
    <div class="flex h-screen bg-[#F8FAFC]">
        {/* Sidebar Desktop */}
        <LightSidebar activePage="settings" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col h-screen overflow-hidden">
            <LightTopNavbar client:load />
            
            {/* The Dashboard acts as the main scrollable area */}
            <main class="flex-1 overflow-y-auto">
                <DomainSettingsDashboard client:load />
            </main>
        </div>
    </div>
</BaseLayout>
