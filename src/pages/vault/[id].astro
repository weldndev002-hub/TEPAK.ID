---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentViewer from '../../components/vault/ContentViewer';
import { ArrowLeftIcon } from '@heroicons/react/24/outline';

export function getStaticPaths() {
  return [
    { params: { id: 'ebook-01' } },
    { params: { id: 'course-01' } },
  ];
}

const { id } = Astro.params;

// Mock database lookup
const products = {
    'ebook-01': {
        title: 'The Creator Blueprint (E-Book)',
        type: 'ebook' as const,
        content: `
            <h2>Bab 1: Menemukan Niche Anda</h2>
            <p>Banyak kreator pemula merasa kesulitan untuk menentukan apa yang harus mereka bagikan di media sosial. Rahasianya bukan pada apa yang sedang tren, tapi pada irisian antara apa yang Anda kuasai dan apa yang dibutuhkan audiens...</p>
            <p>Dalam bab ini, kita akan mempelajari framework 'The Triad of Influence' yang telah digunakan oleh ribuan kreator sukses untuk membangun otoritas sejak hari pertama.</p>
            <h3>Tugas Bab 1:</h3>
            <ul>
                <li>Tuliskan 3 topik yang Anda kuasai.</li>
                <li>Riset volume pencarian untuk setiap topik tersebut.</li>
                <li>Pilih satu 'Micro-Niche' untuk dieksplorasi selama 30 hari ke depan.</li>
            </ul>
        `
    },
    'course-01': {
        title: 'Cinematic Urban Presets & Masterclass',
        type: 'video' as const,
        content: 'video_source_url_here'
    }
};

const product = products[id as keyof typeof products];
---

<BaseLayout title={`${product?.title || 'Protected Content'} | tepak.id Ecosystem`}>
    <div class="min-h-screen bg-[#F8F9FB] font-['Plus_Jakarta_Sans',sans-serif] antialiased">
        
        {/* SECURE HEADER */}
        <nav class="h-20 bg-white border-b border-slate-100 px-8 flex items-center justify-between sticky top-0 z-50">
            <div class="flex items-center gap-6">
                <a href="/library" class="w-10 h-10 rounded-xl border border-slate-100 flex items-center justify-center text-slate-400 hover:text-primary transition-all active:scale-95">
                    <ArrowLeftIcon className="w-5 h-5" />
                </a>
                <span class="text-xs font-black tracking-[0.2em] text-slate-900 uppercase">Secure Viewer</span>
            </div>
            <div class="flex items-center gap-4">
               <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
               <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Akses Stabil</span>
            </div>
        </nav>

        <main class="max-w-5xl mx-auto px-8 py-12">
            {product ? (
                <ContentViewer 
                    client:load 
                    title={product.title} 
                    type={product.type} 
                    content={product.content} 
                    buyerEmail="user@tepak.id"
                />
            ) : (
                <div class="text-center py-32">
                    <h2 class="text-2xl font-bold text-slate-400">Konten tidak ditemukan atau akses ditolak.</h2>
                </div>
            )}
        </main>

    </div>
</BaseLayout>
