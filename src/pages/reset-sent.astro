---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button';
---

<BaseLayout title="Cek Email Anda - tepak.id">
    
    <div class="min-h-screen bg-slate-50 flex flex-col items-center justify-center p-4 md:p-8 font-sans">
        
        {/* BRAND LOGO FOR DESKTOP (TOP LEFT) */}
        <div class="fixed top-10 left-10 hidden lg:block">
            <a href="/" class="text-primary font-black text-2xl tracking-tighter">tepak.id</a>
        </div>

        {/* MAIN CONTAINER */}
        <main class="w-full max-w-5xl bg-white rounded-[2.5rem] shadow-[0_32px_64px_-12px_rgba(0,0,0,0.08)] overflow-hidden flex flex-col md:flex-row min-h-[640px] border border-slate-50">
            
            {/* LEFT SECTION: ILLUSTRATION (CONSISTENCY WITH FORGOT PASSWORD) */}
            <div class="w-full md:w-5/12 amber-gradient flex flex-col items-center justify-center p-12 text-white relative overflow-hidden">
                <div class="absolute top-0 right-0 w-40 h-40 bg-white/10 rounded-full -mr-20 -mt-20 blur-2xl"></div>
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-black/5 rounded-full -ml-32 -mb-32 blur-3xl"></div>
                
                <div class="relative z-10 flex flex-col items-center text-center">
                    <div class="w-32 h-32 bg-white/20 backdrop-blur-xl rounded-[2rem] flex items-center justify-center mb-10 shadow-2xl border border-white/30">
                        <span class="material-symbols-outlined text-white text-[72px]" style={{ fontVariationSettings: "'FILL' 1" }}>
                            check_circle
                        </span>
                    </div>
                    <h2 class="text-3xl font-black mb-4 tracking-tight">Tautan Terkirim</h2>
                    <p class="text-white/80 text-sm leading-relaxed max-w-[240px] font-medium">
                        Keamanan Anda adalah prioritas kami. Instruksi pemulihan telah dikirimkan dengan aman.
                    </p>
                </div>
            </div>

            {/* RIGHT SECTION: SUCCESS MESSAGE */}
            <div class="w-full md:w-7/12 p-10 md:p-20 flex flex-col justify-center">
                <div class="space-y-12">
                    <div class="flex flex-col items-center md:items-start text-center md:text-left">
                        <div class="w-20 h-20 bg-success/10 rounded-full flex items-center justify-center mb-8 border border-success/20">
                            <span class="material-symbols-outlined text-success text-[48px]" style={{ fontVariationSettings: "'FILL' 1" }}>
                                check_circle
                            </span>
                        </div>
                        <h1 class="text-4xl font-black text-slate-900 tracking-tight leading-tight mb-4">
                            Cek Email Anda
                        </h1>
                        <p class="text-slate-500 text-lg leading-relaxed font-medium max-w-sm">
                            Kami telah mengirimkan tautan pemulihan kata sandi ke email Anda. Silakan periksa kotak masuk atau folder spam.
                        </p>
                    </div>

                    <div class="space-y-10 group">
                        <Button variant="amber" size="lg" className="w-full py-4 shadow-xl shadow-primary/20">
                            <span class="material-symbols-outlined text-xl">open_in_new</span>
                            <span>Buka Email Utama</span>
                        </Button>
                        
                        <div class="text-center md:text-left flex flex-col md:flex-row items-center gap-4 text-sm font-medium text-slate-400">
                            Tidak menerima email? 
                            <a href="#" class="text-primary font-black hover:underline underline-offset-4 decoration-2 transition-all">
                                Kirim ulang instruksi
                            </a>
                        </div>
                    </div>

                    <div class="pt-10 border-t border-slate-50">
                        <a href="/login" class="inline-flex items-center gap-3 text-slate-400 font-black hover:text-primary transition-all group text-xs uppercase tracking-widest">
                            <span class="material-symbols-outlined text-[20px] group-hover:-translate-x-2 transition-transform">
                                arrow_back
                            </span>
                            Kembali ke Login
                        </a>
                    </div>
                </div>
            </div>
        </main>

        {/* FOOTER COPYRIGHT */}
        <footer class="mt-12 text-slate-300 text-[10px] font-black uppercase tracking-widest">
            © 2024 tepak.id - Precision Digital Ecosystem
        </footer>

    </div>

</BaseLayout>
