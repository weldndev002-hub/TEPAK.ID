---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ResetPasswordForm } from '../components/auth/ResetPasswordForm';

// Pass Env to Client Component
const runtime = (Astro.locals as any).runtime;
const supabaseUrl = runtime?.env?.PUBLIC_SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = runtime?.env?.PUBLIC_SUPABASE_ANON_KEY || import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<BaseLayout title="Reset Password - tepak.id">
    <div class="bg-surface-container-lowest min-h-screen flex items-center justify-center p-4">
        
        {/* Main Content Area */}
        <ResetPasswordForm 
            client:load 
            supabaseUrl={supabaseUrl} 
            supabaseAnonKey={supabaseAnonKey} 
        />

        {/* Invisible Global Footer component shell (hidden as per page intent) */}
        <footer class="fixed bottom-0 left-0 right-0 py-8 opacity-0 pointer-events-none">
            <div class="flex flex-col md:flex-row items-center justify-center space-y-4 md:space-y-0 md:space-x-8 w-full font-funnel text-sm">
                <span class="text-slate-500">© 2024 tepak.id. All rights reserved.</span>
                <div class="flex gap-4">
                    <a class="text-slate-500 hover:text-slate-900 underline" href="#">Privacy Policy</a>
                    <a class="text-slate-500 hover:text-slate-900 underline" href="#">Terms of Service</a>
                    <a class="text-slate-500 hover:text-slate-900 underline" href="#">Support</a>
                </div>
            </div>
        </footer>
    </div>
</BaseLayout>
