---
import BaseLayout from '../layouts/BaseLayout.astro';
import LibraryGrid from '../components/vault/LibraryGrid';
---

<BaseLayout title="My Library | tepak.id Ecosystem">
    <div class="min-h-screen bg-[#F8F9FB] text-[#191C1E] font-['Plus_Jakarta_Sans',sans-serif] antialiased">
        
        {/* NAV BAR (Simple) */}
        <nav class="bg-white border-b border-slate-100 flex items-center h-20 px-8 sticky top-0 z-50">
            <div class="max-w-7xl mx-auto w-full flex justify-between items-center">
                <div class="flex items-center gap-8">
                    <span class="text-2xl font-bold tracking-tighter text-[#162138]">tepak.id</span>
                    <div class="h-6 w-px bg-slate-200 hidden md:block"></div>
                    <span class="text-sm font-bold text-slate-400 hidden md:block">Library Pembeli</span>
                </div>
                <div class="flex items-center gap-6">
                    <a href="/public" class="text-sm font-bold text-slate-500 hover:text-primary transition-colors">Telusuri Kreator</a>
                    <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center">
                        <span class="material-symbols-outlined text-slate-400">person</span>
                    </div>
                </div>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto px-8 py-16">
            <header class="mb-12">
                <span class="text-[10px] font-black text-primary uppercase tracking-[0.4em] mb-3 block">Dashboard Akses</span>
                <h1 class="text-4xl font-extrabold tracking-tighter text-[#162138] mb-4">Koleksi Digital Saya</h1>
                <p class="text-slate-500 max-w-xl font-medium leading-relaxed">
                    Semua produk digital yang Anda beli tersimpan aman di sini. Klik "Buka Produk" untuk mengakses konten secara eksklusif.
                </p>
            </header>

            <LibraryGrid client:load />

            {/* PROTECTION INFO */}
            <div class="mt-20 p-8 rounded-3xl bg-primary/5 border border-primary/10 flex flex-col md:flex-row items-center gap-8">
                <div class="w-16 h-16 rounded-2xl bg-primary flex items-center justify-center text-white shrink-0">
                    <span class="material-symbols-outlined text-3xl">lock</span>
                </div>
                <div class="flex-grow">
                    <h3 class="text-lg font-bold text-primary mb-1">Akses Digital Terproteksi</h3>
                    <p class="text-sm text-slate-600 leading-relaxed font-medium">
                        Konten di platform ini dilindungi oleh hak cipta. Anda hanya dapat mengakses produk melalui viewer resmi Tepak.ID. Pengunduhan tidak tersedia untuk menjaga kualitas dan keamanan karya kreator.
                    </p>
                </div>
                <div class="shrink-0">
                    <a href="#" class="text-sm font-bold text-primary hover:underline">Pelajari Selengkapnya</a>
                </div>
            </div>
        </main>

        <footer class="py-12 border-t border-slate-100 bg-white">
            <div class="max-w-7xl mx-auto px-8 flex flex-col items-center gap-4 text-center">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">© 2024 THE DIGITAL ATELIER • ALL RIGHTS RESERVED</p>
            </div>
        </footer>

    </div>
</BaseLayout>
