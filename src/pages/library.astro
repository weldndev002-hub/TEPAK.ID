---
import BaseLayout from '../layouts/BaseLayout.astro';
import LibraryGrid from '../components/vault/LibraryGrid';
import { UserIcon, LockClosedIcon } from '@heroicons/react/24/solid';

---

<BaseLayout title="My Library | tepak.id Ecosystem">
    <div class="min-h-screen bg-[#F8F9FB] text-[#191C1E] font-['Plus_Jakarta_Sans',sans-serif] antialiased">
        
        {/* NAV BAR (Simple) */}
        <nav class="bg-white border-b border-slate-100 flex items-center h-20 px-8 sticky top-0 z-50">
            <div class="max-w-7xl mx-auto w-full flex justify-between items-center">
                <div class="flex items-center gap-8">
                    <span class="text-2xl font-black tracking-tighter text-[#162138] uppercase">tepak.id</span>
                    <div class="h-6 w-px bg-slate-200 hidden md:block"></div>
                    <span class="text-[10px] font-black uppercase text-slate-400 tracking-[0.2em] hidden md:block">Buyer Library</span>
                </div>
                <div class="flex items-center gap-6">
                    <a href="/public" class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-primary transition-colors">Telusuri Kreator</a>
                    <div class="w-10 h-10 rounded-2xl bg-slate-50 flex items-center justify-center text-slate-400 group cursor-pointer hover:bg-primary/5 transition-all">
                        <UserIcon className="w-5 h-5 group-hover:text-primary transition-colors" />
                    </div>
                </div>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto px-8 py-20">
            <header class="mb-16">
                <span class="text-[10px] font-black text-primary uppercase tracking-[0.4em] mb-4 block">Access Hub</span>
                <h1 class="text-5xl font-black tracking-tighter text-[#162138] mb-6 uppercase">My Digital Collection</h1>
                <p class="text-slate-500 max-w-xl font-medium leading-relaxed italic text-sm">
                    Semua produk digital yang Anda beli tersimpan aman di sini. Klik "Buka Produk" untuk mengakses konten secara eksklusif.
                </p>
            </header>

            <LibraryGrid client:load />

            {/* PROTECTION INFO */}
            <div class="mt-24 p-10 rounded-[2.5rem] bg-white border border-slate-100 shadow-sm flex flex-col md:flex-row items-center gap-10">
                <div class="w-20 h-20 rounded-3xl bg-primary flex items-center justify-center text-white shrink-0 shadow-lg shadow-primary/20">
                    <LockClosedIcon className="w-10 h-10" />
                </div>
                <div class="flex-grow">
                    <h3 class="text-xl font-black text-[#162138] mb-2 uppercase tracking-tight">Protected Digital Access</h3>
                    <p class="text-[11px] text-slate-400 leading-relaxed font-black uppercase tracking-wide">
                        Konten di platform ini dilindungi oleh hak cipta. Anda hanya dapat mengakses produk melalui viewer resmi Tepak.ID. Pengunduhan tidak tersedia untuk menjaga kualitas dan keamanan karya kreator.
                    </p>
                </div>
                <div class="shrink-0">
                    <a href="#" class="text-[10px] font-black text-primary uppercase tracking-[0.2em] hover:underline underline-offset-8">Learn More</a>
                </div>
            </div>
        </main>

        <footer class="py-16 border-t border-slate-50 bg-white">
            <div class="max-w-7xl mx-auto px-8 flex flex-col items-center gap-4 text-center">
                <p class="text-[10px] font-black text-slate-300 uppercase tracking-[0.4em]">© 2024 THE DIGITAL ATELIER • ALL RIGHTS RESERVED</p>
            </div>
        </footer>

    </div>
</BaseLayout>

