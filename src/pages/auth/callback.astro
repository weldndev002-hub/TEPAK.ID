---
import { getServerClient } from '../../lib/supabase';

const { code, error, error_description } = Astro.url.searchParams;

// Handle error cases
if (error) {
  console.error('[Auth Callback] Error:', error, error_description);
  
  if (error === 'access_denied' && error_description?.includes('otp_expired')) {
    return Astro.redirect('/verify-email?error=link_expired');
  }
  
  return Astro.redirect(`/login?error=${error}`);
}

// Handle verification code
if (code) {
  const supabase = getServerClient(Astro.cookies, Astro.request);
  
  try {
    // Exchange verification code for session
    const { data, error } = await supabase.auth.exchangeCodeForSession(code);
    
    if (error) {
      console.error('[Auth Callback] Exchange code error:', error);
      return Astro.redirect('/login?error=verification_failed');
    }

    if (data.session) {
      // Set session cookies
      Astro.cookies.set('sb-session', JSON.stringify(data.session), {
        path: '/',
        secure: true,
        httpOnly: true,
        sameSite: 'lax'
      });

      // Check if user has completed onboarding
      const { data: profile } = await supabase
        .from('profiles')
        .select('onboarding_completed, username')
        .eq('id', data.session.user.id)
        .single();

      const hasCompletedOnboarding = profile?.onboarding_completed === true && !!profile?.username;

      if (hasCompletedOnboarding) {
        console.log('[Auth Callback] Session verified, redirecting to dashboard');
        return Astro.redirect('/dashboard');
      } else {
        console.log('[Auth Callback] New user, redirecting to onboarding');
        return Astro.redirect('/onboarding');
      }
    }
  } catch (err: any) {
    console.error('[Auth Callback] Unexpected error:', err);
    return Astro.redirect('/login?error=callback_error');
  }
}

// No code or error provided, redirect to login
return Astro.redirect('/login');
---
