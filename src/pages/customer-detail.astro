---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { CustomerDetailDashboard } from '../components/customers/CustomerDetailDashboard';
---

<BaseLayout title="Customer Profile - Tepak.id">
    <div class="flex h-screen bg-[#F8FAFC]">
        {/* Sidebar Desktop */}
        <LightSidebar activePage="customers" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col h-screen overflow-hidden">
            <main class="flex-1 overflow-y-auto">
                <CustomerDetailDashboard client:load />
            </main>
        </div>
    </div>
</BaseLayout>
