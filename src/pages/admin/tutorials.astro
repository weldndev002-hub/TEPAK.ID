---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Sidebar } from '../../components/layout/Sidebar';
import { Header } from '../../components/layout/Header';
import { TutorialManagementDashboard } from '../../components/admin/TutorialManagementDashboard';
---

<BaseLayout title="Tutorial Management | Orbit Site Admin">
    <div class="flex h-screen bg-[#F8FAFC]">
        {/* Sidebar Desktop (Sidebar A - Dark) */}
        <Sidebar activePage="tutorials" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden">
            <Header client:load />
            
            {/* The Dashboard acts as the main scrollable area */}
            <main class="flex-1 overflow-y-auto mt-20 p-8 ml-64">
                <TutorialManagementDashboard client:load />
            </main>
        </div>
    </div>
</BaseLayout>
