---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Sidebar } from '../../components/layout/Sidebar';
import { Header } from '../../components/layout/Header';
import { DomainManagementDashboard } from '../../components/admin/DomainManagementDashboard';
import { BottomNavbar } from '../../components/layout/BottomNavbar';

// Require admin access
const isAdmin = Astro.locals.isAdmin || false;
if (!isAdmin) {
  return Astro.redirect('/login');
}
---

<BaseLayout title="Custom Domain Management | Orbit Site">
    <div class="flex h-screen bg-[#F8FAFC]">
        {/* Sidebar Desktop */}
        <Sidebar activePage="domains" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden">
            <Header client:load />
            
            <main class="flex-1 overflow-y-auto mt-20 p-8 md:ml-64 ml-0 pb-32">
                <DomainManagementDashboard client:load />
            </main>

            {/* Bottom Navigation for Mobile */}
            <BottomNavbar variant="admin" activePage="domains" client:load />
        </div>
    </div>
</BaseLayout>
