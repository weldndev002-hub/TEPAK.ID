---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { ProductsDashboard } from '../components/products/ProductsDashboard';
---

<BaseLayout title="Digital Products - Tepak.id">
    <div class="flex h-screen bg-[#f8f9fb]">
        {/* Sidebar Desktop */}
        <LightSidebar activePage="products" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col h-screen overflow-hidden">
            <LightTopNavbar client:load />
            {/* The Dashboard acts as the main scrollable area, containing its own sticky TopHeader */}
            <main class="flex-1 overflow-y-auto">
                <ProductsDashboard client:load />
            </main>
        </div>
    </div>
</BaseLayout>
