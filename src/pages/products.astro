---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { ProductsDashboard } from '../components/products/ProductsDashboard';
import { BottomNavbar } from '../components/layout/BottomNavbar';
---

<BaseLayout title="Digital Products - Orbit Site">
    <div class="flex h-screen bg-[#f8f9fb]">
        {/* Sidebar Desktop */}
        <LightSidebar activePage="products" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col h-screen overflow-hidden" style="padding-top: 5rem">
            <LightTopNavbar client:load />
            <main class="flex-1 overflow-y-auto pb-32">
                <ProductsDashboard client:load />
            </main>

            <!-- Bottom Navigation for Mobile -->
            <BottomNavbar activePage="products" client:load />
        </div>
    </div>
</BaseLayout>
