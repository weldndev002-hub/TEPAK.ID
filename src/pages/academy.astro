---

<BaseLayout title="Academy — Creator Studio">
    <div class="flex min-h-screen bg-white">
        <!-- Sidebar B (Light) -->
        <LightSidebar activePage="academy" client:load />

        <div class="flex-1 flex flex-col">
            <!-- Header B (Light) -->
            <LightTopNavbar client:load />

            <!-- MAIN WORKSPACE -->
            <main class="p-10 overflow-y-auto w-full">
                <!-- Academy Header Section -->
                <AcademyHero client:load />

                <!-- Tutorials Explorer (Search, Filters, Grid) -->
                <TutorialsExplorer client:load tutorials={tutorials} />

                <!-- Load More Section -->
                <div class="mt-16 flex flex-col items-center gap-4">
                    <Button variant="primary" className="px-10 py-5 bg-primary rounded-2xl font-black flex items-center gap-3 hover:bg-primary/90 shadow-xl shadow-primary/20 active:scale-95 uppercase tracking-widest text-xs">
                        Muat Lebih Banyak
                        <ChevronDownIcon className="w-5 h-5" />
                    </Button>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-[0.2em]">Showing 6 of 24 Tutorials</p>
                </div>

                <!-- Footer Support -->
                <footer class="bg-slate-50 border-t border-slate-100 mt-24 -mx-10 p-12">
                   <div class="flex flex-col md:flex-row justify-between items-center gap-8">
                       <div>
                           <h4 class="text-lg font-bold text-slate-900 mb-2">Butuh bantuan lebih lanjut?</h4>
                           <p class="text-slate-500 text-sm">Tim support kami tersedia 24/7 untuk membantu perjalanan kreator Anda.</p>
                       </div>
                       <div class="flex gap-4">
                           <Button variant="ghost" className="bg-white border-slate-200">Documentation</Button>
                           <Button variant="primary" className="bg-blue-600 hover:bg-blue-700">Hubungi Kami</Button>
                       </div>
                   </div>
                   <div class="mt-12 pt-8 border-t border-slate-100 flex justify-between items-center text-slate-400">
                       <p class="text-[10px] font-bold uppercase tracking-widest">© 2024 Orbit Site Creator Studio. All rights reserved.</p>
                       <div class="flex gap-6">
                           <a href="#" class="text-[10px] font-bold hover:text-blue-500 transition-colors">PRIVACY</a>
                           <a href="#" class="text-[10px] font-bold hover:text-blue-500 transition-colors">TERMS</a>
                           <a href="#" class="text-[10px] font-bold hover:text-blue-500 transition-colors">API STATUS</a>
                       </div>
                   </div>
                </footer>
            </main>

            <!-- Bottom Navigation Bar (Mobile only) -->
            <BottomNavbar activePage="academy" client:load />
        </div>
    </div>
</BaseLayout>
