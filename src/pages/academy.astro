---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { AcademyHero } from '../components/academy/AcademyHero';
import { TutorialsExplorer } from '../components/academy/TutorialsExplorer';
import { BottomNavbar } from '../components/layout/BottomNavbar';
import Button from '../components/ui/Button';
import { ChevronDownIcon } from '@heroicons/react/24/outline';
---

<BaseLayout title="Academy — Creator Studio">
    <div class="flex min-h-screen bg-white">
        <!-- Sidebar B (Light) -->
        <LightSidebar activePage="academy" client:load />

        <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
            <!-- Header B (Light) -->
            <LightTopNavbar client:load />

            <!-- MAIN WORKSPACE -->
            <main class="flex-1 p-6 md:p-10 overflow-y-auto overflow-x-hidden w-full">
                <!-- Academy Header Section -->
                <AcademyHero client:load />

                <!-- Tutorials Explorer (Search, Filters, Grid) -->
                <TutorialsExplorer client:load />

                <!-- Load More Section -->
                <div class="mt-20 flex flex-col items-center gap-6 text-center">
                    <Button variant="primary" className="w-full sm:w-auto px-12 py-5 bg-primary rounded-2xl font-black flex items-center justify-center gap-3 hover:bg-primary/90 shadow-xl shadow-primary/20 active:scale-95 uppercase tracking-[0.2em] text-[10px]">
                        Muat Lebih Banyak
                        <ChevronDownIcon className="w-5 h-5" />
                    </Button>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.3em] opacity-60">Sertifikasi & Kurikulum • 6 dari 24 Materi</p>
                </div>

                <!-- Footer Support -->
                <footer class="bg-slate-50 border-t border-slate-100 mt-24 -mx-6 md:-mx-10 p-8 md:p-12">
                   <div class="flex flex-col md:flex-row justify-between items-center gap-8 text-center md:text-left">
                       <div>
                           <h4 class="text-lg font-bold text-slate-900 mb-2">Butuh bantuan lebih lanjut?</h4>
                           <p class="text-slate-500 text-sm">Tim support kami tersedia 24/7 untuk membantu perjalanan kreator Anda.</p>
                       </div>
                       <div class="flex gap-4">
                           <Button variant="ghost" className="bg-white border-slate-200 text-xs px-4">Documentation</Button>
                           <Button variant="primary" className="bg-blue-600 hover:bg-blue-700 text-xs px-4">Hubungi Kami</Button>
                       </div>
                   </div>
                   <div class="mt-12 pt-8 border-t border-slate-100 flex flex-col md:flex-row justify-between items-center gap-6 text-slate-400">
                       <p class="text-[10px] font-bold uppercase tracking-widest text-center">© 2024 Orbit Site Creator Studio. All rights reserved.</p>
                       <div class="flex gap-6">
                           <a href="#" class="text-[10px] font-bold hover:text-blue-500 transition-colors">PRIVACY</a>
                           <a href="#" class="text-[10px] font-bold hover:text-blue-500 transition-colors">TERMS</a>
                           <a href="#" class="text-[10px] font-bold hover:text-blue-500 transition-colors">API STATUS</a>
                       </div>
                   </div>
                </footer>
            </main>

            <!-- Bottom Navigation Bar (Mobile only) -->
            <BottomNavbar activePage="academy" client:load />
        </div>
    </div>
</BaseLayout>
