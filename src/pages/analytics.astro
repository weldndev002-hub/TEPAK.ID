---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { AnalyticsDashboard } from '../components/analytics/AnalyticsDashboard';
import { AnalyticsTracker } from '../components/analytics/AnalyticsTracker';
import { BottomNavbar } from '../components/layout/BottomNavbar';

import { 
  ArrowDownTrayIcon,
  ShareIcon
} from '@heroicons/react/24/outline';
import Button from '../components/ui/Button';

// Require authentication
const user = await Astro.locals.getUser?.();
if (!user) {
  return Astro.redirect('/login');
}

const supabase = Astro.locals.supabase;

let hasAnalyticsFeature = false;
try {
    const { data: settings } = await supabase
        .from('user_settings')
        .select('plan_status')
        .eq('user_id', user.id)
        .single();
        
    const planId = settings?.plan_status || 'free';

    const { data: planDetails } = await supabase
        .from('subscription_plans')
        .select('features')
        .eq('id', planId)
        .single();
        
    if (planDetails && Array.isArray(planDetails.features) && planDetails.features.includes('Analytics')) {
        hasAnalyticsFeature = true;
    }
} catch (e) {}

if (!hasAnalyticsFeature) {
    return Astro.redirect('/plan-info?upgrade=required');
}
---

<BaseLayout title="Performance Insights — Orbit Site Analytics">
    <div class="flex min-h-screen bg-white font-['Plus_Jakarta_Sans',sans-serif]">
        <!-- Sidebar B (Light) -->
        <LightSidebar activePage="analytics" client:load />

        <div class="flex-1 flex flex-col min-w-0 overflow-hidden" style="padding-top: 5rem">
            <!-- Header B (Light) -->
            <LightTopNavbar client:load />

            <!-- MAIN WORKSPACE -->
            <main class="flex-1 p-6 md:p-8 overflow-y-auto overflow-x-hidden w-full max-w-[1440px]">
                <!-- Page Header Section -->
                <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4 transition-all">
                    <div>
                        <span class="text-[10px] font-black text-primary uppercase tracking-[0.2em] mb-2 block">Data Intelligence</span>
                        <h3 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tighter uppercase leading-tight">Performance Insights</h3>
                        <p class="text-slate-500 mt-2 text-sm font-medium">Analyze your audience growth, device segmentation, and conversion behavior.</p>
                    </div>
                    <div class="flex gap-3 no-print">
                        <Button id="export-pdf-btn" variant="ghost" className="bg-slate-50 border-slate-100 flex items-center gap-2 font-black text-[11px] uppercase tracking-wider">
                            <ArrowDownTrayIcon className="w-4 h-4" /> Export PDF
                        </Button>
                        <Button id="share-report-btn" variant="primary" className="bg-primary hover:bg-primary/90 flex items-center gap-2 font-black text-[11px] uppercase tracking-wider shadow-sm">
                            <ShareIcon className="w-4 h-4" /> Share Report
                        </Button>
                    </div>
                </div>

                {/* Main Analytics Engine */}
                <div id="analytics-content">
                    <AnalyticsDashboard client:load />
                </div>

                <div class="h-32"></div>
            </main>

            <!-- Bottom Navigation Bar (Mobile only) -->
            <BottomNavbar activePage="analytics" client:load />
        </div>
    </div>

    <style is:global>
        @media print {
            .no-print, aside, nav, button, .bottom-navbar {
                display: none !important;
            }
            body {
                background: white !important;
                padding: 0 !important;
            }
            main {
                padding: 0 !important;
                margin: 0 !important;
                max-width: 100% !important;
            }
            #analytics-content {
                display: block !important;
            }
            .flex-1 {
                padding-top: 0 !important;
            }
        }
    </style>

    <script>
        // Handle Export PDF
        const exportBtn = document.getElementById('export-pdf-btn');
        if (exportBtn) {
            exportBtn.addEventListener('click', () => {
                window.print();
            });
        }

        // Handle Share Report
        const shareBtn = document.getElementById('share-report-btn');
        if (shareBtn) {
            shareBtn.addEventListener('click', async () => {
                const shareData = {
                    title: 'Laporan Analitik Tepak.ID',
                    text: 'Lihat wawasan performa digital saya di Tepak.ID.',
                    url: window.location.href
                };

                try {
                    if (navigator.share) {
                        await navigator.share(shareData);
                    } else {
                        await navigator.clipboard.writeText(window.location.href);
                        // @ts-ignore
                        window.toast.success('Link laporan analitik berhasil disalin ke clipboard!');
                    }

                } catch (err) {
                    console.error('Error sharing:', err);
                }
            });
        }
    </script>
</BaseLayout>
