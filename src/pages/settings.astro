---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { EditProfileForm } from '../components/profile/EditProfileForm';
import { BottomNavbar } from '../components/layout/BottomNavbar';
---

<BaseLayout title="Edit Profile | Creator Studio">
    <div class="flex min-h-screen bg-slate-50">
        <!-- Sidebar B (Light) -->
        <LightSidebar activePage="profile" client:load />
        <div class="flex-1 flex flex-col h-screen overflow-hidden" style="padding-top: 5rem">
            <LightTopNavbar client:load />
            <!-- MAIN WORKSPACE -->
            <main class="flex-1 overflow-y-auto overflow-x-hidden p-6 md:p-10 bg-[#e8e9eb] pb-32">
                <EditProfileForm client:load />
            </main>

            <!-- Bottom Navigation for Mobile -->
            <BottomNavbar activePage="profile" client:load />
        </div>
    </div>
</BaseLayout>
