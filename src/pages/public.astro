---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button';
import ProductCard from '../components/ui/ProductCard';
import { 
    CheckBadgeIcon, 
    ArrowRightIcon, 
    VideoCameraIcon, 
    AcademicCapIcon,
    CameraIcon,
    PlayCircleIcon,
    EnvelopeIcon,
    GlobeAltIcon
} from '@heroicons/react/24/solid';
import { AnalyticsTracker } from '../components/analytics/AnalyticsTracker';
import { getServerClient } from '../lib/supabase';

// 1. Detect Hostname & Identity
const hostname = Astro.url.hostname;
const { cookies } = Astro;
const supabase = getServerClient(cookies, Astro.request);

// Priority identity mapping:
// - Custom Domain (e.g., mysite.com)
// - Subdomain (e.g., user.tepak.id)
// - Fallback for Dev/Main Site Testing via URL Search Params (e.g., localhost:4321/?u=acep)

const urlParams = Astro.url.searchParams;
const testUsername = urlParams.get('u');

let merchantData = null;
let products = [];
let queryError = null;

try {
    // A. Detect based on Custom Domain first (if it's not a tepak.id subdomain)
    const isMainDomain = hostname.includes('tepak.id') || hostname === 'localhost' || hostname === '127.0.0.1';
    
    let userQuery = supabase.from('user_settings').select('*, profiles(*)');
    
    if (!isMainDomain) {
        // Search by Custom Domain
        const { data, error } = await userQuery.eq('domain_name', hostname).eq('domain_verified', true).single();
        if (data) merchantData = data;
    } else {
        // Search by Subdomain or Test Param
        const subdomain = hostname.split('.')[0];
        const identifier = (isMainDomain && subdomain !== 'tepak' && subdomain !== 'localhost') ? subdomain : testUsername;
        
        if (identifier) {
            const { data, error } = await supabase
                .from('profiles')
                .select('*, user_settings(*)')
                .eq('username', identifier)
                .single();
            
            if (data) {
                // Formatting into a unified merchant object
                merchantData = {
                    ...data.user_settings,
                    profiles: {
                        id: data.id,
                        full_name: data.full_name,
                        username: data.username,
                        avatar_url: data.avatar_url,
                        bio: data.bio
                    }
                };
            }
        }
    }

    // B. If merchant found, fetch their products
    if (merchantData) {
        const { data: productList } = await supabase
            .from('products')
            .select('*')
            .eq('merchant_id', merchantData.user_id || merchantData.profiles.id)
            .eq('status', 'published')
            .order('created_at', { ascending: false });
        
        products = productList || [];
    }
} catch (err) {
    console.error('[Public Page Error]', err);
    queryError = err;
}

// 404 / Not Found / Banned Handling
if (!merchantData && !testUsername) {
    return Astro.redirect('/');
}

// Map the data to the UI structure (Dynamic from Database)
const profile = {
    name: merchantData?.profiles?.full_name || "Merchant",
    username: merchantData?.profiles?.username || "merchant",
    bio: merchantData?.profiles?.bio || "Welcome to my digital store.",
    avatar: merchantData?.profiles?.avatar_url || "https://images.unsplash.com/photo-1544006659-f0b21f04cb1b?w=400&h=400&fit=crop",
    is_verified: true,
};

// SEO Config
const seo = {
    title: merchantData?.user_settings?.seo_title || `${profile.name} | tepak.id Ecosystem`,
    description: merchantData?.user_settings?.seo_description || profile.bio
};

// Dynamic Social Links
const socials = [
    { 
        icon: CameraIcon, 
        url: merchantData?.profiles?.instagram_url ? (merchantData.profiles.instagram_url.startsWith('http') ? merchantData.profiles.instagram_url : `https://instagram.com/${merchantData.profiles.instagram_url.replace('@', '')}`) : null 
    },
    { 
        icon: GlobeAltIcon, 
        url: merchantData?.profiles?.twitter_url ? (merchantData.profiles.twitter_url.startsWith('http') ? merchantData.profiles.twitter_url : `https://twitter.com/${merchantData.profiles.twitter_url.replace('@', '')}`) : null 
    },
    { 
        icon: PlayCircleIcon, 
        url: merchantData?.profiles?.youtube_url ? (merchantData.profiles.youtube_url.startsWith('http') ? merchantData.profiles.youtube_url : `https://youtube.com/${merchantData.profiles.youtube_url}`) : null 
    },
    { 
        icon: EnvelopeIcon, 
        url: merchantData?.profiles?.phone ? `https://wa.me/${merchantData.profiles.phone.replace(/[^0-9]/g, '')}` : null 
    }
].filter(s => s.url);

// Map the products into UI format
const formatted_products = products.map(p => ({
    id: p.id,
    title: p.title,
    price: new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(p.price),
    description: p.description,
    image: p.cover_url || "https://images.unsplash.com/photo-1544006659-f0b21f04cb1b?w=400&h=400&fit=crop"
}));

const is_banned = merchantData?.plan_status === 'banned' || merchantData?.profiles?.is_banned;
const merchant_id = merchantData?.user_id || merchantData?.profiles?.id;
---

<BaseLayout title={seo.title} description={seo.description}>
    <AnalyticsTracker client:only="react" merchantId={merchant_id || "00000000-0000-0000-0000-000000000000"} />
    <div class="min-h-screen bg-[#F8F9FB] text-[#191C1E] font-['Funnel_Display',sans-serif] antialiased">
        
        <main class="pt-20 pb-20 max-w-4xl mx-auto px-6">
            {is_banned ? (
                <div class="py-32 flex flex-col items-center text-center space-y-8 animate-in zoom-in duration-500">
                    <div class="w-24 h-24 bg-rose-50 text-rose-500 rounded-[2rem] flex items-center justify-center shadow-sm border border-rose-100">
                        <span class="material-symbols-outlined text-5xl">block</span>
                    </div>
                    <div class="space-y-3">
                        <h2 class="text-4xl font-black text-slate-900 tracking-tighter uppercase">Halaman Tidak Tersedia</h2>
                        <p class="text-slate-500 font-medium max-w-md mx-auto leading-relaxed">
                            Maaf, halaman ini telah dinonaktifkan sementara karena melanggar <span class="font-black text-slate-900 border-b-2 border-slate-900">Ketentuan Layanan</span> platform kami.
                        </p>
                    </div>
                    <a href="/" class="px-8 py-3 bg-slate-900 text-white rounded-xl text-[10px] font-black uppercase tracking-widest hover:scale-105 active:scale-95 transition-all">
                        Kembali Beranda
                    </a>
                </div>
            ) : (
                <>
                    {/* Profile Section */}
                    <section class="flex flex-col items-center text-center mb-16 animate-in fade-in slide-in-from-bottom-8 duration-700">
                        <div class="relative mb-6">
                            <div class="w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden border-4 border-white shadow-sm bg-white">
                                <img 
                                    class="w-full h-full object-cover" 
                                    src={profile.avatar} 
                                    alt={profile.name}
                                />
                            </div>
                            {profile.is_verified && (
                                <div class="absolute bottom-2 right-2 bg-[#465f89] text-white p-1.5 rounded-full flex items-center justify-center border-2 border-white shadow-sm">
                                    <CheckBadgeIcon className="w-4 h-4" />
                                </div>
                            )}
                        </div>
                        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tighter text-[#005ab4] mb-3">{profile.name}</h1>
                        <p class="text-[#414753] max-w-lg leading-relaxed text-lg mb-8">
                            {profile.bio}
                        </p>

                        {/* Social Links */}
                        <div class="flex gap-4 mb-12">
                            {socials.map((social) => (
                                <a href={social.url} target="_blank" rel="noopener noreferrer" class="w-12 h-12 flex items-center justify-center rounded-full bg-slate-100 text-slate-500 hover:bg-[#0873df] hover:text-white transition-all duration-300">
                                    <social.icon className="w-6 h-6" />
                                </a>
                            ))}
                        </div>
                    </section>

                    {/* Digital Products Section */}
                    <section class="mb-20" id="shop">
                        <div class="flex justify-between items-end mb-10">
                            <div>
                                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-[#00458d] mb-2 block">Premium Assets</span>
                                <h2 class="text-3xl font-bold tracking-tighter text-[#005ab4]">Digital Products</h2>
                            </div>
                            <a class="text-[#465f89] font-bold text-sm hover:underline" href="#">Lihat Semua</a>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            {formatted_products.map((product) => (
                                <ProductCard 
                                    image={product.image}
                                    title={product.title}
                                    price={product.price}
                                    description={product.description}
                                />
                            ))}
                        </div>
                    </section>
                </>
            )}
        </main>


        {/* Footer */}
        <footer class="w-full py-20 bg-white border-t border-slate-100">
            <div class="flex flex-col items-center gap-8 text-center max-w-5xl mx-auto px-6">
                <div class="flex flex-col items-center gap-3">
                    <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-300">Dibuat Dengan tepak.id</span>
                    <p class="text-[11px] font-black text-slate-400 tracking-tight">© 2024 THE DIGITAL ATELIER. PRECISION CRAFTED FOR CREATORS.</p>
                </div>
                
                <div class="flex flex-wrap justify-center gap-8 md:gap-12">
                    <a class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-[#005ab4] transition-all" href="#">Kebijakan Privasi</a>
                    <a class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-[#005ab4] transition-all" href="#">Syarat & Ketentuan</a>
                    <a class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-[#005ab4] transition-all" href="#">Kontak Kami</a>
                </div>
            </div>
        </footer>

    </div>
</BaseLayout>
