---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button';
import ProductCard from '../components/ui/ProductCard';
import { 
    CheckBadgeIcon, 
    ArrowRightIcon, 
    AcademicCapIcon
} from '@heroicons/react/24/solid';
import { AnalyticsTracker } from '../components/analytics/AnalyticsTracker';
import { getServerClient } from '../lib/supabase';

// 1. Detect Hostname & Identity
const hostname = Astro.url.hostname;
const supabase = Astro.locals.supabase;

// Priority identity mapping:
// - Custom Domain (e.g., mysite.com)
// - Subdomain (e.g., user.tepak.id)
// - Fallback for Dev/Main Site Testing via URL Search Params (e.g., localhost:4321/?u=acep)

const urlParams = Astro.url.searchParams;
const testUsername = urlParams.get('u');

let merchantData = null;
let products = [];
let queryError = null;

try {
    if (!supabase) {
        console.error('[Public Page Error] Supabase is null.');
        throw new Error('Database connection not initialized');
    }
    // A. Detect based on Custom Domain first (if it's not a tepak.id subdomain)
    const isMainDomain = hostname.includes('tepak.id') || hostname === 'localhost' || hostname === '127.0.0.1';
    
    let userQuery = supabase.from('user_settings').select('*, profiles(*)');
    
    if (!isMainDomain) {
        // Search by Custom Domain
        const { data, error } = await userQuery.eq('domain_name', hostname).eq('domain_verified', true).single();
        if (data) merchantData = data;
    } else {
        // Search by Subdomain or Test Param
        const subdomain = hostname.split('.')[0];
        const identifier = (isMainDomain && subdomain !== 'tepak' && subdomain !== 'localhost') ? subdomain : testUsername;
        
        if (identifier) {
            const { data, error } = await supabase
                .from('profiles')
                .select('*, user_settings(*)')
                .eq('username', identifier)
                .single();
            
            if (data) {
                // Formatting into a unified merchant object
                const settings = Array.isArray(data.user_settings) ? data.user_settings[0] : data.user_settings;
                merchantData = {
                    ...(settings || {}),
                    profiles: {
                        ...data
                    }
                };
            }
        }
    }

    // B. If merchant found, fetch their products
    if (merchantData) {
        const { data: productList } = await supabase
            .from('products')
            .select('*')
            .eq('merchant_id', merchantData.user_id || merchantData.profiles.id)
            .eq('status', 'published')
            .order('created_at', { ascending: false });
        
        products = productList || [];
    }
} catch (err) {
    console.error('[Public Page Error]', err);
    queryError = err;
}

// 404 / Not Found / Banned Handling
if (!merchantData && !testUsername) {
    return Astro.redirect('/');
}

// Map the data to the UI structure (Dynamic from Database)
const profile = {
    name: merchantData?.profiles?.full_name || "Merchant",
    username: merchantData?.profiles?.username || "merchant",
    bio: merchantData?.profiles?.bio || "Welcome to my digital store.",
    avatar: merchantData?.profiles?.avatar_url || "https://images.unsplash.com/photo-1544006659-f0b21f04cb1b?w=400&h=400&fit=crop",
    is_verified: true,
};

// SEO Config
const seo = {
    title: merchantData?.user_settings?.seo_title || `${profile.name} | tepak.id Ecosystem`,
    description: merchantData?.user_settings?.seo_description || profile.bio
};

// Dynamic Social Links from Profile
// Brand Icons as SVGs
const BrandIcons = {
    instagram: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.332 3.608 1.308.975.975 1.247 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.332 2.633-1.308 3.608-.975.975-2.242 1.247-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.332-3.608-1.308-.975-.975-1.247-2.242-1.308-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.332-2.633 1.308-3.608.975-.975 2.242-1.247 3.608-1.308 1.266-.058 1.646-.07 4.85-.07zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,
    tiktok: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-4.17.07-8.33.07-12.5z"/></svg>`,
    twitter: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.045 4.126H5.078z"/></svg>`,
    youtube: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
    whatsapp: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`
};

// Dynamic Social Links from Profile
const socials = [
    { 
        icon: BrandIcons.instagram, 
        url: merchantData?.profiles?.instagram_url ? `https://instagram.com/${merchantData.profiles.instagram_url.replace('@', '')}` : null 
    },
    { 
        icon: BrandIcons.tiktok, 
        url: merchantData?.profiles?.tiktok_url ? `https://tiktok.com/@${merchantData.profiles.tiktok_url.replace('@', '')}` : null 
    },
    { 
        icon: BrandIcons.twitter, 
        url: merchantData?.profiles?.twitter_url ? `https://twitter.com/${merchantData.profiles.twitter_url.replace('@', '')}` : null 
    },
    { 
        icon: BrandIcons.youtube, 
        url: merchantData?.profiles?.youtube_url ? (merchantData.profiles.youtube_url.startsWith('http') ? merchantData.profiles.youtube_url : `https://youtube.com/${merchantData.profiles.youtube_url}`) : null 
    },
    { 
        icon: BrandIcons.whatsapp, 
        url: merchantData?.profiles?.phone ? `https://wa.me/${merchantData.profiles.phone.replace(/[^0-9]/g, '')}` : null 
    }
].filter(s => s.url);

// Get blocks from database
const blocks = merchantData?.profiles?.blocks || [];

// Map the products into UI format
const formatted_products = products.map(p => ({
    id: p.id,
    title: p.title,
    price: new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(p.price),
    description: p.description,
    image: p.cover_url || "https://images.unsplash.com/photo-1544006659-f0b21f04cb1b?w=400&h=400&fit=crop"
}));

const is_banned = merchantData?.plan_status === 'banned' || merchantData?.profiles?.is_banned;
const merchant_id = merchantData?.user_id || merchantData?.profiles?.id;

if (is_banned) {
    Astro.response.status = 404;
}
---

<BaseLayout title={seo.title} description={seo.description}>
    <AnalyticsTracker client:only="react" merchantId={merchant_id || "00000000-0000-0000-0000-000000000000"} />
    <div class="min-h-screen bg-[#F8F9FB] text-[#191C1E] font-['Funnel_Display',sans-serif] antialiased">
        
        <main class="pt-20 pb-20 max-w-4xl mx-auto px-6">
            {is_banned ? (
                <div class="py-32 flex flex-col items-center text-center space-y-8 animate-in zoom-in duration-500">
                    <div class="w-24 h-24 bg-rose-50 text-rose-500 rounded-[2rem] flex items-center justify-center shadow-sm border border-rose-100">
                        <span class="material-symbols-outlined text-5xl">block</span>
                    </div>
                    <div class="space-y-3">
                        <h2 class="text-4xl font-black text-slate-900 tracking-tighter uppercase">Halaman Tidak Tersedia</h2>
                        <p class="text-slate-500 font-medium max-w-md mx-auto leading-relaxed">
                            Maaf, halaman ini telah dinonaktifkan sementara karena melanggar <span class="font-black text-slate-900 border-b-2 border-slate-900">Ketentuan Layanan</span> platform kami.
                        </p>
                    </div>
                    <a href="/" class="px-8 py-3 bg-slate-900 text-white rounded-xl text-[10px] font-black uppercase tracking-widest hover:scale-105 active:scale-95 transition-all">
                        Kembali Beranda
                    </a>
                </div>
            ) : (
                <>
                    {/* Profile Section */}
                    <section class="flex flex-col items-center text-center mb-16 animate-in fade-in slide-in-from-bottom-8 duration-700">
                        <div class="relative mb-6">
                            <div class="w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden border-4 border-white shadow-sm bg-white">
                                <img 
                                    class="w-full h-full object-cover" 
                                    src={profile.avatar} 
                                    alt={profile.name}
                                />
                            </div>
                            {profile.is_verified && (
                                <div class="absolute bottom-2 right-2 bg-primary text-white p-1.5 rounded-full flex items-center justify-center border-2 border-white shadow-sm">
                                    <CheckBadgeIcon className="w-4 h-4" />
                                </div>
                            )}
                        </div>
                        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tighter text-primary mb-3">{profile.name}</h1>
                        <p class="text-[#414753] max-w-lg leading-relaxed text-lg mb-8">
                            {profile.bio}
                        </p>

                        {/* Social Links */}
                        <div class="flex flex-wrap justify-center gap-4 mb-12">
                            {socials.map((social) => (
                                <a href={social.url} target="_blank" rel="noopener noreferrer" class="w-12 h-12 flex items-center justify-center rounded-full bg-primary/10 text-primary hover:bg-primary hover:text-white transition-all duration-300">
                                    <Fragment set:html={social.icon} />
                                </a>
                            ))}
                        </div>
                    </section>

                    {/* Digital Products Section */}
                    {formatted_products.length > 0 && (
                        <section class="mb-20" id="shop">
                            <div class="flex justify-between items-end mb-10">
                                <div>
                                    <span class="text-[10px] font-black uppercase tracking-[0.2em] text-primary/80 mb-2 block">Premium Assets</span>
                                    <h2 class="text-3xl font-bold tracking-tighter text-primary">Digital Products</h2>
                                </div>
                                <a class="text-primary font-bold text-sm hover:underline" href="#">Lihat Semua</a>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                {formatted_products.map((product) => (
                                    <ProductCard 
                                        imageSrc={product.image}
                                        title={product.title}
                                        price={product.price}
                                        description={product.description}
                                    />
                                ))}
                            </div>
                        </section>
                    )}

                    {/* Custom Blocks Rendering */}
                    <section class="space-y-6 mb-20">
                        {blocks.map((block: any) => (
                            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-md transition-all group">
                                <div class="flex items-center gap-6">
                                    <div class="w-12 h-12 rounded-2xl bg-primary/5 text-primary flex items-center justify-center shrink-0">
                                        <span class="material-symbols-outlined">{
                                            block.type === 'link' ? 'link' : 
                                            block.type === 'video' ? 'play_circle' : 
                                            block.type === 'social' ? 'share' : 'info'
                                        }</span>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <h3 class="text-lg font-bold text-slate-900 truncate uppercase tracking-tight">{block.title}</h3>
                                        <p class="text-sm text-slate-500 truncate">{block.subtitle}</p>
                                    </div>
                                    <a href={block.url || '#'} target="_blank" class="w-10 h-10 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
                                        <ArrowRightIcon className="w-5 h-5" />
                                    </a>
                                </div>
                            </div>
                        ))}
                    </section>
                </>
            )}
        </main>


        {/* Footer */}
        <footer class="w-full py-20 bg-white border-t border-slate-100">
            <div class="flex flex-col items-center gap-8 text-center max-w-5xl mx-auto px-6">
                <div class="flex flex-col items-center gap-3">
                    <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-300">Dibuat Dengan tepak.id</span>
                    <p class="text-[11px] font-black text-slate-400 tracking-tight">© 2024 THE DIGITAL ATELIER. PRECISION CRAFTED FOR CREATORS.</p>
                </div>
                
                <div class="flex flex-wrap justify-center gap-8 md:gap-12">
                    <a class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-primary transition-all" href="#">Kebijakan Privasi</a>
                    <a class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-primary transition-all" href="#">Syarat & Ketentuan</a>
                    <a class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-primary transition-all" href="#">Kontak Kami</a>
                </div>
            </div>
        </footer>

    </div>
</BaseLayout>
