---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button";
import ProductCard from "../components/ui/ProductCard";
import {
    CheckBadgeIcon,
    ArrowRightIcon,
    AcademicCapIcon,
} from "@heroicons/react/24/solid";
import { AnalyticsTracker } from "../components/analytics/AnalyticsTracker";
import { getServerClient } from "../lib/supabase";

// Helper to extract domain from URL
const extractDomain = (url: string) => {
    try {
        const parsed = new URL(url);
        return parsed.hostname.replace("www.", "");
    } catch {
        return null;
    }
};

// 1. Detect Hostname & Identity
const hostname = Astro.url.hostname;
const supabase = Astro.locals.supabase;

// Priority identity mapping:
// - Custom Domain (e.g., mysite.com)
// - Subdomain (e.g., user.tepak.id)
// - Fallback for Dev/Main Site Testing via URL Search Params (e.g., localhost:4321/?u=acep)

const urlParams = Astro.url.searchParams;
const testUsername = urlParams.get("u");

let merchantData = null;
let products = [];
let blocks = [];
let queryError = null;

try {
    if (!supabase) {
        console.error("[Public Page Error] Supabase is null.");
        throw new Error("Database connection not initialized");
    }
    // A. Detect based on Custom Domain first (if it's not a tepak.id subdomain)
    const isMainDomain =
        hostname.includes("tepak.id") ||
        hostname === "localhost" ||
        hostname === "127.0.0.1";

    let userQuery = supabase.from("user_settings").select("*, profiles(*)");

    if (!isMainDomain) {
        // Search by Custom Domain
        const { data, error } = await userQuery
            .eq("domain_name", hostname)
            .eq("domain_verified", true)
            .single();
        if (data) merchantData = data;
    } else {
        // Search by Subdomain or Test Param
        const subdomain = hostname.split(".")[0];
        const identifier =
            isMainDomain && subdomain !== "tepak" && subdomain !== "localhost"
                ? subdomain
                : testUsername;

        if (identifier) {
            const { data, error } = await supabase
                .from("profiles")
                .select("*, user_settings(*)")
                .eq("username", identifier)
                .single();

            if (data) {
                // Formatting into a unified merchant object
                const settings = Array.isArray(data.user_settings)
                    ? data.user_settings[0]
                    : data.user_settings;
                merchantData = {
                    ...(settings || {}),
                    profiles: {
                        ...data,
                    },
                };
            }
        }
    }

    // B. If merchant found, fetch their products
    if (merchantData) {
        const { data: productList } = await supabase
            .from("products")
            .select("*")
            .eq("merchant_id", merchantData.user_id || merchantData.profiles.id)
            .eq("status", "published")
            .order("created_at", { ascending: false });

        products = productList || [];
        blocks = merchantData?.profiles?.blocks || [];
    }
} catch (err) {
    console.error("[Public Page Error]", err);
    queryError = err;
}

// 404 / Not Found / Banned Handling
if (!merchantData && !testUsername) {
    return Astro.redirect("/");
}

// Map the data to the UI structure (Dynamic from Database)
const profile = {
    name: merchantData?.profiles?.full_name || "Merchant",
    username: merchantData?.profiles?.username || "merchant",
    bio: merchantData?.profiles?.bio || "Welcome to my digital store.",
    avatar:
        merchantData?.profiles?.avatar_url ||
        "https://images.unsplash.com/photo-1544006659-f0b21f04cb1b?w=400&h=400&fit=crop",
    email: merchantData?.profiles?.email,
    is_verified: true,
};

// SEO Config
const seo = {
    title:
        merchantData?.user_settings?.seo_title ||
        `${profile.name} | tepak.id Ecosystem`,
    description: merchantData?.user_settings?.seo_description || profile.bio,
    image: profile.avatar,
};

// Dynamic Social Links from Profile
// Brand Icons as SVGs
const BrandIcons = {
    instagram: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.332 3.608 1.308.975.975 1.247 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.332 2.633-1.308 3.608-.975.975-2.242 1.247-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.332-3.608-1.308-.975-.975-1.247-2.242-1.308-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.332-2.633 1.308-3.608.975-.975 2.242-1.247 3.608-1.308 1.266-.058 1.646-.07 4.85-.07zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,
    tiktok: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-4.17.07-8.33.07-12.5z"/></svg>`,
    twitter: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.045 4.126H5.078z"/></svg>`,
    youtube: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
    whatsapp: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
    facebook: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"/></svg>`,
    threads: `<svg viewBox="0 0 192 192" fill="currentColor" class="w-6 h-6"><path d="M141.537 88.9883C140.71 88.5919 139.87 88.2104 139.019 87.8451C137.537 60.5382 122.616 44.905 97.5619 44.745C97.4484 44.7443 97.3355 44.7443 97.222 44.7443C82.2364 44.7443 69.7731 51.1409 62.102 62.7807L75.881 72.2328C81.6116 63.5383 90.6052 61.6848 97.2286 61.6848C97.3051 61.6848 97.3819 61.6848 97.4576 61.6855C105.707 61.7381 111.932 64.1366 115.961 68.814C118.893 72.2193 120.854 76.925 121.825 82.8638C114.511 81.6207 106.601 81.2385 98.145 81.7233C74.3247 83.0954 59.0111 96.9879 60.0396 116.292C60.5615 126.084 65.4397 134.508 73.775 140.011C80.8224 144.663 89.899 146.938 99.3323 146.423C111.79 145.74 121.563 140.987 128.381 132.296C133.559 125.696 136.834 117.143 138.28 106.366C144.217 109.949 148.617 114.664 151.047 120.332C155.179 129.967 155.42 145.8 142.501 158.708C131.182 170.016 117.576 174.908 97.0135 175.059C74.2042 174.89 56.9538 167.575 45.7381 153.317C35.2355 139.966 29.8077 120.682 29.6052 96C29.8077 71.3178 35.2355 52.0336 45.7381 38.6827C56.9538 24.4249 74.2039 17.11 97.0132 16.9405C119.988 17.1113 137.539 24.4614 149.184 38.788C154.894 45.8136 159.199 54.6488 162.037 64.9503L178.184 60.6422C174.744 47.9622 169.331 37.0357 161.965 27.974C147.036 9.60668 125.202 0.195148 97.0695 0H96.9569C68.8816 0.19447 47.2921 9.6418 32.7883 28.0793C19.8819 44.4864 13.2244 67.3157 13.0007 95.9325L13 96L13.0007 96.0675C13.2244 124.684 19.8819 147.514 32.7883 163.921C47.2921 182.358 68.8816 191.806 96.9569 192H97.0695C122.03 191.827 139.624 185.292 154.118 170.811C173.081 151.866 172.51 128.119 166.26 113.541C161.776 103.087 153.227 94.5962 141.537 88.9883ZM98.4405 129.507C88.0005 130.095 77.1544 125.409 76.6196 115.372C76.2232 107.93 81.9158 99.626 99.0812 98.6368C101.047 98.5234 102.976 98.468 104.871 98.468C111.106 98.468 116.939 99.0737 122.242 100.233C120.264 124.935 108.662 128.946 98.4405 129.507Z"/></svg>`,
};

// Extract social data from blocks
const socialBlock = blocks.find((b: any) => b.type === "social");
const socialData = socialBlock?.data || {};

const socials = [
    {
        icon: BrandIcons.instagram,
        url: socialData.instagram
            ? `https://instagram.com/${socialData.instagram.replace("@", "")}`
            : null,
    },
    {
        icon: BrandIcons.tiktok,
        url: socialData.tiktok
            ? `https://tiktok.com/@${socialData.tiktok.replace("@", "")}`
            : null,
    },
    {
        icon: BrandIcons.twitter,
        url: socialData.twitter
            ? `https://twitter.com/${socialData.twitter.replace("@", "")}`
            : null,
    },
    {
        icon: BrandIcons.threads,
        url: socialData.threads
            ? `https://threads.net/@${socialData.threads.replace("@", "")}`
            : null,
    },
    {
        icon: BrandIcons.facebook,
        url: socialData.facebook
            ? `https://facebook.com/${socialData.facebook}`
            : null,
    },
].filter((s) => s.url);

// blocks already initialized above

// Map the products into UI format
const formatted_products = products.map((p) => ({
    id: p.id,
    title: p.title,
    price: new Intl.NumberFormat("id-ID", {
        style: "currency",
        currency: "IDR",
        maximumFractionDigits: 0,
    }).format(p.price),
    sale_price: (p.sale_price !== null && p.sale_price !== undefined) ? new Intl.NumberFormat("id-ID", {
        style: "currency",
        currency: "IDR",
        maximumFractionDigits: 0,
    }).format(p.sale_price) : null,
    description: p.description,
    image:
        p.cover_url ||
        "https://images.unsplash.com/photo-1544006659-f0b21f04cb1b?w=400&h=400&fit=crop",
}));

const is_banned =
    merchantData?.plan_status === "banned" || merchantData?.profiles?.is_banned;
const merchant_id = merchantData?.user_id || merchantData?.profiles?.id;

if (is_banned) {
    Astro.response.status = 404;
}
---

<BaseLayout title={seo.title} description={seo.description} image={seo.image}>
    <AnalyticsTracker
        client:only="react"
        merchantId={merchant_id || "00000000-0000-0000-0000-000000000000"}
    />
    <div
        class="min-h-screen bg-background text-on-background font-['Funnel_Display',sans-serif] antialiased"
    >
        <main class="pt-20 pb-20 max-w-4xl mx-auto px-6">
            {
                is_banned ? (
                    <div class="py-32 flex flex-col items-center text-center space-y-8 animate-in zoom-in duration-500">
                        <div class="w-24 h-24 bg-rose-50 text-rose-500 rounded-[2rem] flex items-center justify-center shadow-sm border border-rose-100">
                            <span class="material-symbols-outlined text-5xl">
                                block
                            </span>
                        </div>
                        <div class="space-y-3">
                            <h2 class="text-4xl font-black text-slate-900 tracking-tighter uppercase">
                                Halaman Tidak Tersedia
                            </h2>
                            <p class="text-slate-500 font-medium max-w-md mx-auto leading-relaxed">
                                Maaf, halaman ini telah dinonaktifkan sementara
                                karena melanggar{" "}
                                <span class="font-black text-slate-900 border-b-2 border-slate-900">
                                    Ketentuan Layanan
                                </span>{" "}
                                platform kami.
                            </p>
                        </div>
                        <a
                            href="/"
                            class="px-8 py-3 bg-slate-900 text-white rounded-xl text-[10px] font-black uppercase tracking-widest hover:scale-105 active:scale-95 transition-all"
                        >
                            Kembali Beranda
                        </a>
                    </div>
                ) : (
                    <>
                        {/* Profile Section */}
                        <section class="flex flex-col items-center text-center mb-16 animate-in fade-in slide-in-from-bottom-8 duration-700">
                            <div class="relative mb-6">
                                <div class="w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden border-4 border-surface shadow-2xl bg-surface">
                                    <img
                                        class="w-full h-full object-cover"
                                        src={profile.avatar}
                                        alt={profile.name}
                                    />
                                </div>
                                {profile.is_verified && (
                                    <div class="absolute bottom-2 right-2 bg-primary text-on-primary p-1.5 rounded-full flex items-center justify-center border-4 border-background shadow-sm">
                                        <CheckBadgeIcon className="w-4 h-4" />
                                    </div>
                                )}
                            </div>
                            <h1 class="text-5xl md:text-6xl font-black tracking-tighter text-on-surface mb-4">
                                {profile.name}
                            </h1>
                            <p class="text-on-surface/70 max-w-lg leading-relaxed text-lg mb-10">
                                {profile.bio}
                            </p>

                            {/* Social Links */}
                            <div class="flex flex-wrap justify-center gap-5 mb-12">
                                {socials.map((social) => (
                                    <a
                                        href={social.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="w-14 h-14 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-on-surface hover:bg-primary hover:text-white hover:scale-110 transition-all duration-500 shadow-xl backdrop-blur-md"
                                    >
                                        <Fragment set:html={social.icon} />
                                    </a>
                                ))}
                            </div>

                            {/* Custom Blocks — ditampilkan di bawah social icons */}
                            {blocks.length > 0 && (
                                <div class="w-full max-w-4xl mx-auto px-4 md:px-0 grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
                                    {blocks.map((block: any) => {
                                        if (block.type === "social")
                                            return null;
                                        if (block.type === "text")
                                            return (
                                                <div class="md:col-span-2 w-full bg-white/5 backdrop-blur-md p-10 rounded-[2.5rem] border border-white/10 shadow-sm text-center space-y-4 animate-in fade-in duration-700">
                                                    {block.data?.title && (
                                                        <h4 class="text-3xl font-black text-on-surface tracking-tighter uppercase leading-tight">
                                                            {block.data.title}
                                                        </h4>
                                                    )}
                                                    {block.data?.content && (
                                                        <p class="text-lg text-on-surface/70 font-medium leading-relaxed italic opacity-80">
                                                            {block.data.content}
                                                        </p>
                                                    )}
                                                </div>
                                            );
                                        if (block.type === "image")
                                            return (
                                                <div class="md:col-span-2 w-full bg-white/5 p-4 rounded-[2.5rem] border border-white/10 shadow-sm space-y-4 animate-in fade-in zoom-in-95 duration-700">
                                                    {block.data?.imageUrl && (
                                                        <div class="w-full aspect-video rounded-[1.8rem] overflow-hidden border border-white/5 shadow-inner">
                                                            <img
                                                                src={
                                                                    block.data
                                                                        .imageUrl
                                                                }
                                                                class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000"
                                                                alt={
                                                                    block.data
                                                                        ?.title ||
                                                                    ""
                                                                }
                                                            />
                                                        </div>
                                                    )}
                                                    {block.data?.title && (
                                                        <p class="text-[11px] font-black text-on-surface/50 uppercase tracking-[0.2em] text-center italic pb-2">
                                                            {block.data.title}
                                                        </p>
                                                    )}
                                                </div>
                                            );
                                        if (
                                            block.type === "video" &&
                                            block.data?.isYouTube &&
                                            block.data?.videoId
                                        )
                                            return (
                                                <div class="md:col-span-2 w-full bg-white/5 p-4 rounded-[2.5rem] border border-white/10 shadow-sm space-y-4 animate-in fade-in zoom-in-95 duration-700">
                                                    <div class="w-full aspect-video rounded-[1.8rem] overflow-hidden shadow-inner">
                                                        <iframe
                                                            width="100%"
                                                            height="100%"
                                                            src={`https://www.youtube.com/embed/${block.data.videoId}`}
                                                            title={
                                                                block.title ||
                                                                "Video"
                                                            }
                                                            class="w-full h-full"
                                                            frameborder="0"
                                                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                            allowfullscreen
                                                        />
                                                    </div>
                                                    {block.title && (
                                                        <p class="text-[11px] font-black text-on-surface/50 uppercase tracking-[0.2em] text-center italic pb-2">
                                                            {block.title}
                                                        </p>
                                                    )}
                                                </div>
                                            );
                                        // 1. Get real-time data from database for products
                                        const product = block.data?.product_id ? products.find(p => p.id === block.data?.product_id) : null;
                                        
                                        const url = product ? `/checkout?product_id=${product.id}` : (block.data?.url || block.url || (block.subtitle?.startsWith("http") ? block.subtitle : "#"));
                                        const domain = extractDomain(url);
                                        const thumbnail = product?.cover_url || block.data?.thumbnailUrl;
                                        const title = product?.title || block.data?.title || block.title;
                                        const description = product?.description || block.data?.description || block.subtitle;

                                        // 2. Format prices (always use product data if available)
                                        const rawPrice = product?.price || 0;
                                        const rawSalePrice = product?.sale_price;

                                        const formattedPrice = new Intl.NumberFormat("id-ID", {
                                            style: "currency",
                                            currency: "IDR",
                                            maximumFractionDigits: 0,
                                        }).format(rawPrice);

                                        const formattedSalePrice = rawSalePrice !== null && rawSalePrice !== undefined ? new Intl.NumberFormat("id-ID", {
                                            style: "currency",
                                            currency: "IDR",
                                            maximumFractionDigits: 0,
                                        }).format(rawSalePrice) : null;
                                        return (
                                            <a
                                                href={url}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="group relative flex flex-col w-full bg-white/5 backdrop-blur-md rounded-[2.5rem] border border-white/10 shadow-sm hover:shadow-2xl hover:shadow-primary/20 hover:-translate-y-2 transition-all duration-700 overflow-hidden"
                                            >
                                                {/* Hero Image */}
                                                <div class="aspect-[4/3] w-full overflow-hidden bg-white/5 relative">
                                                    {thumbnail ? (
                                                        <img
                                                            src={thumbnail}
                                                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000"
                                                            alt=""
                                                        />
                                                    ) : (
                                                        <div class="w-full h-full flex items-center justify-center text-primary/20">
                                                            <span class="material-symbols-outlined text-6xl">
                                                                link
                                                            </span>
                                                        </div>
                                                    )}
                                                    {domain && (
                                                        <div class="absolute top-4 right-4 z-10 px-3 py-1.5 bg-background/80 backdrop-blur-md rounded-full border border-white/10 shadow-sm">
                                                            <span class="text-[10px] font-black text-primary uppercase tracking-widest">{domain}</span>
                                                        </div>
                                                    )}
                                                </div>

                                                <div class="p-8 flex flex-col flex-1">
                                                    <div class="flex items-center gap-2 mb-4">
                                                        <span class="w-8 h-[1px] bg-primary/40"></span>
                                                        <span class="text-[9px] font-black text-on-surface/40 uppercase tracking-[0.3em]">Featured Item</span>
                                                    </div>
                                                    
                                                    <h3 class="text-2xl font-black text-on-surface leading-tight tracking-tight mb-4 group-hover:text-primary transition-colors">
                                                        {title}
                                                    </h3>
                                                    
                                                    {description && (
                                                        <p class="text-[13px] text-on-surface/60 leading-relaxed line-clamp-4 font-medium opacity-80 mb-8">
                                                            {description}
                                                        </p>
                                                    )}

                                                    <div class="mt-auto pt-6 border-t border-white/5 flex items-center justify-between">
                                                        <div class="flex flex-col">
                                                            <span class="text-[9px] font-black text-primary/60 uppercase tracking-widest mb-1">Dapatkan Sekarang</span>
                                                            <div class="flex items-baseline gap-2">
                                                                {formattedSalePrice ? (
                                                                    <>
                                                                        <span class="text-2xl font-black text-on-surface tracking-tighter">
                                                                            {formattedSalePrice}
                                                                        </span>
                                                                        <span class="text-sm font-bold text-on-surface/40 line-through tracking-tight">
                                                                            {formattedPrice}
                                                                        </span>
                                                                    </>
                                                                ) : (
                                                                    <span class="text-2xl font-black text-on-surface tracking-tighter">
                                                                        {formattedPrice}
                                                                    </span>
                                                                )}
                                                            </div>
                                                        </div>
                                                        <div class="w-12 h-12 rounded-full bg-white/5 text-on-surface/20 flex items-center justify-center group-hover:bg-primary group-hover:text-white group-hover:scale-110 transition-all duration-500 shadow-sm">
                                                            <ArrowRightIcon className="w-5 h-5 group-hover:translate-x-1 transition-transform" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </a>
                                        );
                                    })}
                                </div>
                            )}
                        </section>

                        {/* Digital Products Section */}
                        {formatted_products.length > 0 && (
                            <section class="mb-20" id="shop">
                                <div class="flex justify-between items-end mb-10">
                                    <div>
                                        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-primary/80 mb-2 block">
                                            Premium Assets
                                        </span>
                                        <h2 class="text-3xl font-bold tracking-tighter text-primary">
                                            Digital Products
                                        </h2>
                                    </div>
                                    <a
                                        class="text-primary font-bold text-sm hover:underline"
                                        href="#"
                                    >
                                        Lihat Semua
                                    </a>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                    {formatted_products.map((product) => (
                                        <ProductCard
                                            id={product.id}
                                            image={product.image}
                                            title={product.title}
                                            price={product.price}
                                            salePrice={product.sale_price}
                                            description={product.description}
                                        />
                                    ))}
                                </div>
                            </section>
                        )}

                        {/* Custom Blocks dipindah ke atas, di bawah social icons */}
                    </>
                )
            }
        </main>

        {/* Footer */}
        <footer class="w-full py-20 bg-white border-t border-slate-100">
            <div
                class="flex flex-col items-center gap-8 text-center max-w-5xl mx-auto px-6"
            >
                <div class="flex flex-col items-center gap-3">
                    <span
                        class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-300"
                        >Dibuat Dengan tepak.id</span
                    >
                    <p
                        class="text-[11px] font-black text-slate-400 tracking-tight"
                    >
                        © 2024 THE DIGITAL ATELIER. PRECISION CRAFTED FOR
                        CREATORS.
                    </p>
                </div>

                <div class="flex flex-wrap justify-center gap-8 md:gap-12">
                    <a
                        class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-primary transition-all"
                        href="#">Kebijakan Privasi</a
                    >
                    <a
                        class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-primary transition-all"
                        href="#">Syarat & Ketentuan</a
                    >
                    <a
                        class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-primary transition-all"
                        href="#">Kontak Kami</a
                    >
                </div>
            </div>
        </footer>
    </div>
</BaseLayout>
