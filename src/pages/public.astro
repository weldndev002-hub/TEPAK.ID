---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button';
import Avatar from '../components/ui/Avatar';
import Badge from '../components/ui/Badge';
import ProductCard from '../components/ui/ProductCard';
---

<BaseLayout title="Santi Nusantara | Creator Hub">
    <div class="min-h-screen bg-[#F8F9FB] text-[#191C1E] font-['Plus_Jakarta_Sans',sans-serif] antialiased">
        
        <main class="pt-20 pb-20 max-w-4xl mx-auto px-6">
            {/* Profile Section */}
            <section class="flex flex-col items-center text-center mb-16 animate-in fade-in slide-in-from-bottom-8 duration-700">
                <div class="relative mb-6">
                    <div class="w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden border-4 border-white shadow-sm bg-white">
                        <img 
                            class="w-full h-full object-cover" 
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuAqV1zxjaeYU4PqjHJ3aHlRH0Cet90XlqjfaBq_QX8rbhfInOCt9lXOMBVY6Wh0QS_a3NuhaPLVkomBJtp7niS0RLZ3KzmwQn9B0CUz5lmx600R69GfqNvQuJ2OLVZgYSP-PAuQbg_vdZJXlRnEw9VT2YgjEz-hQnQdrm6MVyR_Q1MfIQFyZsjvJCfSs9v3DavHdHii5JdEsEsQFPvEIqu0DLN0XlkOPYdoTLopXeoKM_myV2p8wuR6koPzdDYrVjEkU_3UA27WyGEJ" 
                            alt="Santi Nusantara"
                        />
                    </div>
                    <div class="absolute bottom-2 right-2 bg-[#465f89] text-white p-1.5 rounded-full flex items-center justify-center border-2 border-white shadow-sm">
                        <span class="material-symbols-outlined text-sm" style={{ fontVariationSettings: "'FILL' 1" }}>verified</span>
                    </div>
                </div>
                <h1 class="text-4xl md:text-5xl font-extrabold tracking-tighter text-[#005ab4] mb-3">Santi Nusantara</h1>
                <p class="text-[#414753] max-w-lg leading-relaxed text-lg mb-8">
                    Membantu kreator Indonesia membangun brand digital yang bermakna. Designer, Educator, & Digital Strategist.
                </p>

                {/* Social Links */}
                <div class="flex gap-4 mb-12">
                    {['camera', 'play_circle', 'mail', 'public'].map((icon) => (
                        <a href="#" class="w-12 h-12 flex items-center justify-center rounded-full bg-slate-100 text-slate-500 hover:bg-[#0873df] hover:text-white transition-all duration-300">
                            <span class="material-symbols-outlined">{icon}</span>
                        </a>
                    ))}
                </div>
            </section>

            {/* Main Action Links */}
            <section class="space-y-4 mb-20" id="portfolio">
                <a href="#" class="flex items-center justify-between group w-full p-8 rounded-3xl bg-[#0873df] text-white hover:bg-[#005ab4] transition-all duration-300 shadow-lg shadow-blue-500/10">
                    <div class="flex items-center gap-6">
                        <div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center backdrop-blur-md">
                            <span class="material-symbols-outlined">video_chat</span>
                        </div>
                        <span class="text-lg font-bold tracking-tight">Konsultasi Kreatif (1-on-1)</span>
                    </div>
                    <span class="material-symbols-outlined transform group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </a>
                <a href="#" class="flex items-center justify-between group w-full p-8 rounded-3xl bg-[#0873df] text-white hover:bg-[#005ab4] transition-all duration-300 shadow-lg shadow-blue-500/10">
                    <div class="flex items-center gap-6">
                        <div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center backdrop-blur-md">
                            <span class="material-symbols-outlined">school</span>
                        </div>
                        <span class="text-lg font-bold tracking-tight">Workshop Branding Intensif</span>
                    </div>
                    <span class="material-symbols-outlined transform group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </a>
            </section>

            {/* Digital Products Section */}
            <section class="mb-20" id="shop">
                <div class="flex justify-between items-end mb-10">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-[#00458d] mb-2 block">Premium Assets</span>
                        <h2 class="text-3xl font-bold tracking-tighter text-[#005ab4]">Digital Products</h2>
                    </div>
                    <a class="text-[#465f89] font-bold text-sm hover:underline" href="#">Lihat Semua</a>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <ProductCard 
                        image="https://lh3.googleusercontent.com/aida-public/AB6AXuCjjyluzSxIJ5m-78CwTFr1titoEU8JGT-PqmwcEF-21PHJ6cqH04cc3__Q37EJcF_rDYTOGM8loDPhEI5dF3mUKBzumESfBpcChiPS50-YTG33SduZrSvcaCOUwzjQkC3G808320Q3u9LUzcgQCziaSC6it3Uyi5Gw24ZA67TP36T3gJasAxoblawtCJnAOAdNfh5PFa2P9gPHYimVHxiuuN-MNrEX86JMagD4hQ-at05QqRa29rEoSu8qcRVDTEpxUqdQOt4V6G-x"
                        title="The Creator Blueprint (E-Book)"
                        price="Rp 149rb"
                        description="Panduan lengkap membangun personal brand dari nol hingga menghasilkan pendapatan konsisten."
                    />
                    <ProductCard 
                        image="https://lh3.googleusercontent.com/aida-public/AB6AXuAr07NKIXEP2HaT46rcrRfslmZae_DeX5iXM36noVPM6sa3cSqe7EOf6qXgBXY7SUatW22NE0QJZn97uJ0CVU4rP-bxhKGm9nOfCwt_VqEDRCX93WcxM6TEYfmMQwlHocS6MUk-88gjjKUm96CjXjG9_70H2LAvwYtq47kCg2ahlBeH67N81JDi2M96RqXBwX0yoF4j7uaQgOhJf2naT9YT-m5fW7BH01YotLgDs8Wt3BDEXouZB3DHQpjJEZrOi8oxSD7OvlkcJKNh"
                        title="Cinematic Urban Presets"
                        price="Rp 89rb"
                        description="12 preset Lightroom kustom untuk memberikan nuansa premium pada foto konten media sosial Anda."
                    />
                </div>
            </section>

        </main>

        {/* Footer */}
        <footer class="w-full py-20 bg-white border-t border-slate-100">
            <div class="flex flex-col items-center gap-8 text-center max-w-5xl mx-auto px-6">
                <div class="flex flex-col items-center gap-3">
                    <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-300">Dibuat Dengan tepak.id</span>
                    <p class="text-[11px] font-black text-slate-400 tracking-tight">© 2024 THE DIGITAL ATELIER. PRECISION CRAFTED FOR CREATORS.</p>
                </div>
                
                <div class="flex flex-wrap justify-center gap-8 md:gap-12">
                    <a class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-[#005ab4] transition-all" href="#">Kebijakan Privasi</a>
                    <a class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-[#005ab4] transition-all" href="#">Syarat & Ketentuan</a>
                    <a class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-[#005ab4] transition-all" href="#">Kontak Kami</a>
                </div>
            </div>
        </footer>

    </div>
</BaseLayout>
