---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button';
import ProductCard from '../components/ui/ProductCard';
import { 
    CheckBadgeIcon, 
    ArrowRightIcon, 
    VideoCameraIcon, 
    AcademicCapIcon,
    CameraIcon,
    PlayCircleIcon,
    EnvelopeIcon,
    GlobeAltIcon
} from '@heroicons/react/24/solid';

