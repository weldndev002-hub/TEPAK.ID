---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { WalletDashboard } from '../components/wallet/WalletDashboard';
import { BottomNavbar } from '../components/layout/BottomNavbar';

const user = await Astro.locals.getUser();
const supabase = Astro.locals.supabase;

if (!user || !supabase) {
    return Astro.redirect('/login');
}

let hasCommerceFeature = false;
try {
    const { data: settings } = await supabase
        .from('user_settings')
        .select('plan_status')
        .eq('user_id', user.id)
        .single();
        
    const planId = settings?.plan_status || 'free';

    const { data: planDetails } = await supabase
        .from('subscription_plans')
        .select('features')
        .eq('id', planId)
        .single();
        
    if (planDetails && Array.isArray(planDetails.features) && planDetails.features.includes('Digital Product Sales')) {
        hasCommerceFeature = true;
    }
} catch (e) {}

if (!hasCommerceFeature) {
    return Astro.redirect('/plan-info?upgrade=required');
}
---

<BaseLayout title="Earnings & Wallet | The Digital Atelier">
    <div class="flex min-h-screen bg-slate-50">
        <!-- Sidebar B (Light) -->
        <LightSidebar activePage="wallet" client:load />

        <div class="flex-1 flex flex-col h-screen overflow-hidden" style="padding-top: 5rem">
            <!-- Header B (Light) -->
            <LightTopNavbar client:load />

            <!-- MAIN WORKSPACE -->
            <main class="flex-1 overflow-y-auto p-10 bg-slate-50 pb-32">
                <WalletDashboard client:load />
            </main>

            <!-- Bottom Navigation for Mobile -->
            <BottomNavbar activePage="wallet" client:load />
        </div>
    </div>
</BaseLayout>
