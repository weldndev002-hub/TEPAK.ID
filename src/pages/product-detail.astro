---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { ProductDetailDashboard } from '../components/products/ProductDetailDashboard';
---

<BaseLayout title="Product Detail - Tepak.id">
    <div class="flex h-screen bg-[#F8FAFC]">
        {/* Sidebar Desktop */}
        <LightSidebar activePage="products" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col h-screen overflow-hidden">
            <main class="flex-1 overflow-y-auto">
                <ProductDetailDashboard client:load />
            </main>
        </div>
    </div>
</BaseLayout>
