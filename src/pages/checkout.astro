---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CheckoutForm } from '../components/checkout/CheckoutForm';
import { ShieldCheckIcon, LockClosedIcon, FingerPrintIcon } from '@heroicons/react/24/solid';
import { AnalyticsTracker } from '../components/analytics/AnalyticsTracker';
import { getServerClient } from '../lib/supabase';

const productId = Astro.url.searchParams.get('product_id');
let merchantId = '';

if (productId) {
    const supabase = getServerClient(Astro.cookies, Astro.request);
    const { data: product } = await supabase
        .from('products')
        .select('merchant_id')
        .eq('id', productId)
        .single();
    
    if (product) {
        merchantId = product.merchant_id;
    }
}
---

<BaseLayout title="Checkout Aman | tepak.id Ecosystem">
    {merchantId && <AnalyticsTracker client:only="react" merchantId={merchantId} productId={productId || undefined} eventType="page_view" />}
    <div class="min-h-screen bg-[#F8F9FB] text-[#191C1E] font-['Funnel_Display',sans-serif] antialiased flex flex-col">
        
        {/* MAIN CHECKOUT FORM AREA */}
        <main class="flex-grow">
            <CheckoutForm client:load />
        </main>

        {/* Improved Footer */}
        <footer class="bg-[#f0edef] w-full mt-auto">
            <div class="w-full px-8 py-12 flex flex-col md:flex-row justify-between items-center max-w-screen-2xl mx-auto text-center md:text-left gap-8">
                <div class="space-y-4">
                    <span class="text-lg font-bold text-[#162138]">tepak.id</span>
                    <p class="text-[12px] text-[#45464d] max-w-xs">
                        Platform kurasi digital terbaik untuk konten kreator di Indonesia. Bangun karya tanpa batas.
                    </p>
                </div>
                <div class="flex flex-col items-center md:items-end gap-6">
                    <div class="flex flex-wrap justify-center gap-6">
                        <a class="text-[#45464d] text-xs font-bold uppercase tracking-wider hover:text-[#005ab4]" href="#">Kebijakan Privasi</a>
                        <a class="text-[#45464d] text-xs font-bold uppercase tracking-wider hover:text-[#005ab4]" href="#">Syarat & Ketentuan</a>
                        <a class="text-[#45464d] text-xs font-bold uppercase tracking-wider hover:text-[#005ab4]" href="#">Info Layanan</a>
                    </div>
                    <div class="flex items-center gap-4 opacity-50 grayscale hover:grayscale-0 hover:opacity-100 transition-all">
                        <span class="text-[10px] font-bold text-[#191C1E]">CHECKOUT AMAN OLEH</span>
                        <div class="flex gap-4">
                            <ShieldCheckIcon className="w-6 h-6" />
                            <LockClosedIcon className="w-6 h-6" />
                            <FingerPrintIcon className="w-6 h-6" />
                        </div>
                    </div>
                    <p class="text-[10px] text-[#45464d] font-medium tracking-tight">
                        © 2024 The Digital Atelier. All rights reserved. Crafted in Indonesia.
                    </p>
                </div>
            </div>
        </footer>

    </div>
</BaseLayout>

