---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CheckoutForm } from '../components/checkout/CheckoutForm';
import { 
    ArrowLeftIcon, 
    ShieldCheckIcon, 
    LockClosedIcon, 
    FingerPrintIcon 
} from '@heroicons/react/24/solid';
---

<BaseLayout title="Checkout Aman | tepak.id Ecosystem">
    <div class="min-h-screen bg-[#F8F9FB] text-[#191C1E] font-['Plus_Jakarta_Sans',sans-serif] antialiased flex flex-col">
        
        {/* MAIN CHECKOUT FORM AREA */}
        <main class="flex-grow">
            <div class="max-w-screen-2xl mx-auto px-8 pt-8 -mb-4">
                <a href="/public" class="inline-flex items-center gap-2 text-slate-500 hover:text-primary transition-colors font-bold text-sm group">
                    <ArrowLeftIcon className="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" />
                    Kembali
                </a>
            </div>
            <CheckoutForm client:load />
        </main>

        {/* Improved Footer */}
        <footer class="bg-[#f0edef] w-full mt-auto">
            <div class="w-full px-8 py-12 flex flex-col md:flex-row justify-between items-center max-w-screen-2xl mx-auto text-center md:text-left gap-8">
                <div class="space-y-4">
                    <span class="text-lg font-bold text-[#162138]">tepak.id</span>
                    <p class="text-[12px] text-[#45464d] max-w-xs">
                        Platform kurasi digital terbaik untuk konten kreator di Indonesia. Bangun karya tanpa batas.
                    </p>
                </div>
                <div class="flex flex-col items-center md:items-end gap-6">
                    <div class="flex flex-wrap justify-center gap-6">
                        <a class="text-[#45464d] text-xs font-bold uppercase tracking-wider hover:text-[#005ab4]" href="#">Privacy Policy</a>
                        <a class="text-[#45464d] text-xs font-bold uppercase tracking-wider hover:text-[#005ab4]" href="#">Terms of Service</a>
                        <a class="text-[#45464d] text-xs font-bold uppercase tracking-wider hover:text-[#005ab4]" href="#">Shipping Info</a>
                    </div>
                    <div class="flex items-center gap-4 opacity-50 grayscale hover:grayscale-0 hover:opacity-100 transition-all">
                        <span class="text-[10px] font-bold text-[#191C1E]">SECURE CHECKOUT BY</span>
                        <div class="flex gap-4">
                            <ShieldCheckIcon className="w-6 h-6" />
                            <LockClosedIcon className="w-6 h-6" />
                            <FingerPrintIcon className="w-6 h-6" />
                        </div>
                    </div>
                    <p class="text-[10px] text-[#45464d] font-medium tracking-tight">
                        © 2024 The Digital Atelier. All rights reserved. Crafted in Indonesia.
                    </p>
                </div>
            </div>
        </footer>

    </div>
</BaseLayout>

