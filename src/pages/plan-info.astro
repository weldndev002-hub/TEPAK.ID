---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { PlanInfoDashboard } from '../components/profile/PlanInfoDashboard';
import { BottomNavbar } from '../components/layout/BottomNavbar';
---

<BaseLayout title="Informasi Paket | Orbit Site Premium">
    <div class="flex min-h-screen bg-slate-50">
        <!-- Sidebar B (Light) -->
        <LightSidebar activePage="plan-info" client:load />

        <div class="flex-1 flex flex-col h-screen overflow-hidden" style="padding-top: 5rem">
            <!-- Header B (Light) -->
            <LightTopNavbar client:load />

            <!-- MAIN WORKSPACE -->
            <main class="flex-1 overflow-y-auto p-10 bg-[#f8fafc] pb-32">
                <PlanInfoDashboard client:load />
            </main>

            <!-- Bottom Navigation for Mobile -->
            <BottomNavbar activePage="plan-info" client:load />
        </div>
    </div>
</BaseLayout>
