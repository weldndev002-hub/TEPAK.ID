---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { LightTopNavbar } from '../components/layout/LightTopNavbar';
import { OrdersDashboard } from '../components/orders/OrdersDashboard';
import { BottomNavbar } from '../components/layout/BottomNavbar';
---

<BaseLayout title="Pesanan Saya - Tepak ID">
    <div class="flex h-screen bg-[#F8FAFC]">
        {/* Sidebar Desktop */}
        <LightSidebar activePage="orders" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col h-screen overflow-hidden" style="padding-top: 5rem">
            <LightTopNavbar client:load />
            {/* The Dashboard acts as the main scrollable area */}
            <main class="flex-1 overflow-y-auto pb-32">
                <OrdersDashboard client:load />
            </main>

            <!-- Bottom Navigation for Mobile -->
            <BottomNavbar activePage="orders" client:load />
        </div>
    </div>
</BaseLayout>
