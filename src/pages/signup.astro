---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignupForm from '../components/auth/SignupForm';
import { RocketLaunchIcon } from '@heroicons/react/24/outline';
import { createClient } from '@supabase/supabase-js';

// Fetch Branding
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseAnonKey);

const { data: branding } = await supabase
  .from('platform_configs')
  .select('*')
  .eq('id', 1)
  .single();

const siteName = branding?.site_name || 'Tepak.ID';
const logoUrl = branding?.logo_url || '/logo-light.png';
---

<BaseLayout title={`Daftar Gratis | ${siteName}`}>
    
    <div class="min-h-screen bg-slate-50 flex flex-col items-center justify-center p-4 md:p-8 font-['Plus_Jakarta_Sans',sans-serif]">
        
        {/* BRAND LOGO TOP LEFT */}
        <div class="fixed top-10 left-10 hidden lg:block">
            <a href="/">
                <img src={logoUrl} alt={siteName} class="w-32 h-auto" />
            </a>
        </div>

        {/* MAIN CONTAINER */}
        <main class="w-full max-w-6xl bg-white rounded-[2.5rem] shadow-[0_32px_64px_-12px_rgba(0,0,0,0.08)] overflow-hidden flex flex-col lg:flex-row min-h-[700px] border border-white">
            
            {/* LEFT SECTION: ILLUSTRATION (AMBER GRADIENT) */}
            <div class="w-full lg:w-5/12 amber-gradient flex flex-col items-center justify-center p-12 text-white relative overflow-hidden">
                <div class="absolute top-0 right-0 w-40 h-40 bg-white/10 rounded-full -mr-20 -mt-20 blur-2xl"></div>
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-black/5 rounded-full -ml-32 -mb-32 blur-3xl"></div>
                
                <div class="relative z-10 flex flex-col items-center text-center">
                    <div class="w-32 h-32 bg-white/20 backdrop-blur-xl rounded-[2.5rem] flex items-center justify-center mb-10 shadow-2xl border border-white/30">
                        <RocketLaunchIcon className="w-16 h-16 text-white" />
                    </div>
                    <h2 class="text-4xl font-black mb-4 tracking-tighter uppercase">Mulai Langkahmu</h2>
                    <p class="text-white/80 text-sm leading-relaxed max-w-[260px] font-medium">
                        Bergabunglah dengan ribuan kreator modern dan UMKM yang telah bertransformasi secara digital.
                    </p>
                </div>
            </div>

            {/* RIGHT SECTION: SIGNUP FORM */}
            <div class="w-full lg:w-7/12 p-10 lg:p-20 flex flex-col justify-center bg-white">
                <div class="max-w-md w-full mx-auto space-y-12">
                    <header class="space-y-4">
                        <h1 class="text-5xl font-black text-slate-900 tracking-tighter leading-tight uppercase">
                            Buat Akun <span class="text-primary italic">Gratis</span>
                        </h1>
                        <p class="text-slate-400 text-lg leading-relaxed font-medium">
                            Isi formulir di bawah ini untuk memulai ekosistem bisnis digital Anda dalam hitungan detik.
                        </p>
                    </header>

                    {/* INTERACTIVE COMPONENT */}
                    {branding?.registration_enabled !== false ? (
                        <SignupForm client:load />
                    ) : (
                        <div class="bg-rose-50 border border-rose-100 p-8 rounded-3xl text-center space-y-6 animate-in fade-in zoom-in duration-500">
                            <div class="w-16 h-16 bg-rose-500 text-white rounded-2xl flex items-center justify-center mx-auto shadow-lg shadow-rose-500/20">
                                <span class="material-symbols-outlined text-3xl">lock</span>
                            </div>
                            <div>
                                <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight mb-2">Pendaftaran Ditutup</h3>
                                <p class="text-slate-500 text-sm font-medium leading-relaxed">
                                    Maaf, saat ini pendaftaran pengguna baru sedang ditutup sementara oleh sistem. Silakan coba lagi beberapa saat lagi atau hubungi dukungan kami.
                                </p>
                            </div>
                            <a href="/" class="inline-block px-6 py-3 bg-slate-900 text-white text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-slate-800 transition-all">Kembali Beranda</a>
                        </div>
                    )}

                    <div class="pt-10 border-t border-slate-50">
                        <p class="text-slate-400 font-bold text-[10px] uppercase tracking-[0.2em] text-center">
                            Sudah punya akun? 
                            <a href="/login" class="text-primary hover:underline ml-2">Masuk Sekarang</a>
                        </p>
                    </div>
                </div>
            </div>
        </main>

        {/* FOOTER */}
        <footer class="mt-12 text-[10px] font-black text-slate-300 uppercase tracking-widest text-center">
            © {new Date().getFullYear()} {siteName} - {branding?.site_tagline || 'Building the Future of Creator Economy'}
        </footer>

    </div>

</BaseLayout>

