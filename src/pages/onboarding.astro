---
import BaseLayout from '../layouts/BaseLayout.astro';
import { OnboardingForm } from '../components/onboarding/OnboardingForm';
import { QuestionMarkCircleIcon } from '@heroicons/react/24/outline';
const supabase = Astro.locals.supabase;

let branding: any = null;
if (supabase) {
    try {
        const { data } = await supabase
          .from('platform_configs')
          .select('*')
          .eq('id', 1)
          .single();
        branding = data;
    } catch (e) {
        console.error('[Onboarding] Branding Fetch Error:', e);
    }
}
---

<BaseLayout title="Onboarding - tepak.id Ecosystem">
    
    <div class="min-h-screen bg-slate-50 font-['Plus_Jakarta_Sans',sans-serif] selection:bg-primary/20 selection:text-primary">
        
        {/* MINIMALIST HEADER */}
        <header class="w-full py-16 px-12 flex justify-between items-center max-w-7xl mx-auto">
            <a href="/" class="text-3xl font-black text-slate-900 tracking-tighter hover:text-primary transition-all active:scale-95">
                tepak.id
            </a>
            <div class="flex items-center gap-3 text-slate-400 group cursor-pointer hover:text-primary transition-all">
                <span class="text-[10px] font-black uppercase tracking-[0.2em] group-hover:underline underline-offset-[12px] decoration-2">Need Help?</span>
                <QuestionMarkCircleIcon className="w-6 h-6" />
            </div>
        </header>

        {/* MAIN ONBOARDING AREA */}
        <main class="pb-32 px-6">
            <OnboardingForm initialBranding={branding} client:load />
        </main>

        {/* COMPACT FOOTER */}
        <footer class="w-full py-20 bg-white border-t border-slate-100">
            <div class="flex flex-col items-center gap-8 text-center max-w-7xl mx-auto px-6">
                <div class="flex flex-col items-center gap-4">
                    <span class="text-[9px] font-black uppercase tracking-[0.5em] text-slate-200">The Creator Economy Standard</span>
                    <p class="text-[10px] font-black text-slate-300 tracking-[0.1em] uppercase">© 2024 TEPAK.ID — THE DIGITAL ATELIER. PRECISION CRAFTED IN INDONESIA.</p>
                </div>
            </div>
        </footer>

        {/* DECORATIVE BACKGROUND BLURS */}
        <div class="fixed top-1/4 -right-24 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px] -z-10 animate-pulse duration-[10s]"></div>
        <div class="fixed bottom-0 -left-24 w-[400px] h-[400px] bg-primary/5 rounded-full blur-[100px] -z-10 animate-pulse duration-[8s]"></div>

    </div>

</BaseLayout>

