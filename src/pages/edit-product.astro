---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LightSidebar } from '../components/layout/LightSidebar';
import { EditProductDashboard } from '../components/products/EditProductDashboard';
---

<BaseLayout title="Edit Digital Product - Tepak.id">
    <div class="flex h-screen bg-[#F8FAFC]">
        {/* Sidebar Desktop */}
        <LightSidebar activePage="products" client:load />

        {/* Main Content Area */}
        <div class="flex-1 flex flex-col h-screen overflow-hidden">
            {/* The Dashboard acts as the main scrollable area, containing its own sticky Contextual TopHeader */}
            <main class="flex-1 overflow-y-auto">
                <EditProductDashboard client:load />
            </main>
        </div>
    </div>
</BaseLayout>
