                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        xmlns="http://www.w3.org/2000/svg"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                        />
                                    </svg>
                                </div>
                                <h1 class="text-3xl font-bold text-gray-900 mb-2">
                                    Akses Diberikan
                                </h1>
                                <p class="text-gray-600 mb-8">
                                    Anda dapat mengunduh file produk digital
                                    Anda di bawah ini.
                                </p>

                                {/* Buyer Protection Banner - ALWAYS SHOWN */}
                                <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-xl p-5 mb-8 text-left">
                                    <div class="flex items-start gap-4">
                                        <div class="flex-shrink-0">
                                            <div class="p-2 bg-blue-100 rounded-lg">
                                                <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                                </svg>
                                            </div>
                                        </div>
                                        <div class="flex-1">
                                            <h4 class="text-sm font-bold text-blue-900 mb-1 flex items-center gap-2">
                                                🛡️ Konten Terlindungi
                                            </h4>
                                            <p class="text-sm text-blue-700 leading-relaxed">
                                                File ini dilisensikan secara eksklusif untuk: <strong class="font-mono bg-blue-100 px-2 py-0.5 rounded border border-blue-200">{email}</strong>
                                            </p>
                                            <div class="flex items-center gap-4 mt-2">
                                                <span class="text-[10px] uppercase font-bold tracking-wider text-blue-500 bg-white/50 px-2 py-0.5 rounded border border-blue-100">
                                                    Akses #{accessCount + 1}
                                                </span>
                                                <span class="text-[10px] uppercase font-bold tracking-wider text-blue-500 bg-white/50 px-2 py-0.5 rounded border border-blue-100">
                                                    Order: {orderId?.substring(0, 8)}...
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                {isPdf ? (
                                    <div class="mb-10">
                                        <div class="mb-4 text-left">
                                            <p class="text-gray-600 text-sm mb-4">
                                                📄 Pratinjau dokumen tersedia di bawah.
                                            </p>
                                        </div>
                                        <PDFViewer client:load pdfUrl={signedUrl || fileUrl} fileName={fileName} />
                                    </div>
                                ) : isImage ? (
                                    <div class="mb-10 text-left">
                                        <div class="mb-4">
                                            <p class="text-gray-600 text-sm">
                                                🖼️ Pratinjau gambar tersedia di bawah.
                                            </p>
                                        </div>
                                        <div class="bg-gray-50 rounded-2xl p-4 flex justify-center overflow-hidden border border-gray-200 shadow-inner">
                                            <img 
                                                src={signedUrl || fileUrl} 
                                                alt={fileName} 
                                                class="max-w-full h-auto rounded-lg shadow-xl hover:scale-[1.01] transition-transform duration-500"
                                            />
                                        </div>
                                    </div>
                                ) : null}

                                {/* Primary Download Action - ALWAYS VISIBLE */}
                                <div class="bg-blue-600/5 border border-blue-100 rounded-2xl p-8 mb-10 shadow-sm">
                                    <div class="flex flex-col md:flex-row items-center justify-between gap-6 text-left">
                                        <div class="flex items-center gap-4">
                                            <div class="p-3 bg-blue-600 rounded-xl text-white shadow-lg shadow-blue-200">
