---
import { createClient } from "@supabase/supabase-js";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PDFViewer from "../../components/PDFViewer.tsx";
import { type ClientDirective } from "astro";

const { token } = Astro.params;
const email = Astro.url.searchParams.get("email") || "";

// Initialize Supabase client
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseKey);

let isValid = false;
let errorMessage = "";
let signedUrl = "";
let fileUrl = "";
let fileName = "";
let isPdf = false;

if (token && email) {
    try {
        // Verify token access
        const { data: delivery, error } = await supabase
            .from("digital_deliveries")
            .select("*, orders!inner(customers!inner(email))")
            .eq("token", token)
            .single();

        if (error || !delivery) {
            errorMessage = "Token tidak valid atau telah kadaluarsa.";
        } else {
            // Check expiry
            const expiresAt = new Date(delivery.expires_at);
            const now = new Date();

            if (now > expiresAt) {
                errorMessage = "Token telah kadaluarsa.";
            } else if (
                delivery.orders?.customers?.email?.toLowerCase() !==
                email.toLowerCase()
            ) {
                // Email mismatch - redirect to error page
                return Astro.redirect(
                    "/digital-delivery/error?reason=email_mismatch",
                );
            } else {
                // Valid access
                isValid = true;
                signedUrl = delivery.signed_url;
                fileUrl = delivery.file_url;
                fileName = fileUrl.split("/").pop() || "download.pdf";
                isPdf = fileName.toLowerCase().endsWith(".pdf");

                // Update access count
                await supabase
                    .from("digital_deliveries")
                    .update({
                        access_count: delivery.access_count + 1,
                        last_accessed_at: now.toISOString(),
                    })
                    .eq("id", delivery.id);
            }
        }
    } catch (err) {
        errorMessage = "Terjadi kesalahan saat memverifikasi token.";
        console.error(err);
    }
} else {
    errorMessage = "Token dan email diperlukan.";
}

// If invalid, redirect to error page
if (!isValid && errorMessage && errorMessage !== "EMAIL_MISMATCH") {
    return Astro.redirect("/digital-delivery/error?reason=invalid");
}
---

<BaseLayout title="Unduhan Produk Digital - Tepak.ID">
    <div
        class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 py-12 px-4 sm:px-6 lg:px-8"
    >
        <div class="max-w-4xl mx-auto">
            {
                isValid ? (
                    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
                        <div class="px-8 py-10">
                            <div class="text-center mb-10">
                                <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-green-100 mb-6">
