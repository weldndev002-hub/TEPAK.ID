import { createClient } from "@supabase/supabase-js";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PDFViewer from "../../components/PDFViewer.tsx";
import { type ClientDirective } from "astro";

// Helper to safely get environment variables (compatible with Cloudflare Workers)
const getEnv = (key: string) => {
    try {
        // 1. Try passed runtime env (Cloudflare v6+)
        if (typeof Astro !== 'undefined' && Astro.locals && Astro.locals.runtime && Astro.locals.runtime.env) {
            const val = Astro.locals.runtime.env[key];
            if (val) return val;
        }

        // 2. Vite / Astro Build-time (PUBLIC_ vars)
        if (typeof import.meta !== 'undefined' && import.meta.env && import.meta.env[key]) {
            return import.meta.env[key];
        }

        // 3. Global Fallback
        if (typeof globalThis !== 'undefined') {
            if ((globalThis as any)[key]) return (globalThis as any)[key];
            if ((globalThis as any).env && (globalThis as any).env[key]) return (globalThis as any).env[key];
        }
    } catch (e) {
        console.error(`[Digital Delivery] Error getting env ${key}:`, e);
    }

    return null;
};

const { token } = Astro.params;
const email = Astro.url.searchParams.get("email") || "";

// Initialize Supabase client with service role for signed URL generation
const supabaseUrl = getEnv('PUBLIC_SUPABASE_URL');
const supabaseKey = getEnv('SUPABASE_SERVICE_ROLE_KEY') || getEnv('PUBLIC_SUPABASE_ANON_KEY');

console.log("[Digital Delivery] Init:", { 
    hasToken: !!token, 
    hasEmail: !!email, 
    hasUrl: !!supabaseUrl, 
    hasKey: !!supabaseKey 
});

// Initialize Supabase client
let supabase: any = null;

try {
    if (supabaseUrl && supabaseKey) {
        supabase = createClient(supabaseUrl, supabaseKey);
    } else {
        console.error("[Digital Delivery] Missing Supabase config:", { supabaseUrl: !!supabaseUrl, supabaseKey: !!supabaseKey });
    }
} catch (e) {
    console.error("[Digital Delivery] Supabase init error:", e);
}

let isValid = false;
let errorMessage = "";
let signedUrl = "";
let fileUrl = "";
let downloadUrl = "";
let fileName = "";
let isPdf = false;
let isImage = false;
let buyerEmail = "";
let orderId = "";
let accessCount = 0;

if (token && email && supabase) {
    try {
        // Verify token access - use left join (remove !inner) to handle cases without order links
        const { data: delivery, error } = await supabase
            .from("digital_deliveries")
            .select("*, orders(id, customer_id, customers(email, name))")
            .eq("token", token)
            .single();

        if (error || !delivery) {
            errorMessage = "Token tidak valid atau telah kadaluarsa.";
            console.error("[Digital Delivery] Token verification error:", error || "No delivery record found");
            isValid = false;
        } else {
            // Get buyer email from multiple possible sources
            const orderCustomerEmail = delivery.orders?.customers?.email;
            const accessedEmail = delivery.accessed_email;
            
            buyerEmail = orderCustomerEmail || accessedEmail || "";
            
            console.log("[Digital Delivery] Email Check:", {
                provided: email,
                expected_from_order: orderCustomerEmail,
                expected_from_record: accessedEmail,
                final_expected: buyerEmail
            });

            // Check expiry
            const expiresAt = new Date(delivery.expires_at);
            const now = new Date();
            
            orderId = delivery.orders?.id || "MANUAL";
            accessCount = delivery.access_count || 0;

            if (now > expiresAt) {
                errorMessage = "Token telah kadaluarsa.";
                console.log("[Digital Delivery] Token expired:", token);
            } else if (
                buyerEmail.toLowerCase() !== email.toLowerCase()
            ) {
                // Email mismatch - redirect to error page
                console.warn(`[Digital Delivery] Email mismatch. Expected: ${buyerEmail}, Got: ${email}`);
                return Astro.redirect(
                    "/digital-delivery/error?reason=email_mismatch",
                );
            } else {
                // Valid access - generate fresh signed URL if needed
                isValid = true;
                fileUrl = delivery.file_url;
                fileName = fileUrl.split("/").pop() || "download.pdf";
                isPdf = fileName.toLowerCase().endsWith(".pdf");
                isImage = /\.(jpg|jpeg|png|gif|webp|avif)$/i.test(fileName);

                // Generate fresh signed URL if file is from Supabase Storage
                if (fileUrl.includes('supabase.co/storage')) {
                    try {
                        // Extract bucket and path from file_url
                        const url = new URL(fileUrl);
                        const pathParts = url.pathname.split('/');
                        const bucketIndex = pathParts.findIndex((p: string) => p === 'public' || p === 'object');
                        if (bucketIndex !== -1 && pathParts[bucketIndex + 1]) {
                            const bucket = pathParts[bucketIndex + 1];
                            const filePath = pathParts.slice(bucketIndex + 2).join('/');

                            // Generate signed URL (valid for 1 hour)
                            const { data: signedData, error: signError } = await supabase
                                .storage
                                .from(bucket)
                                .createSignedUrl(filePath, 3600);

                            if (!signError && signedData) {
                                signedUrl = signedData.signedUrl;
                                console.log("[Digital Delivery] Generated fresh signed URL for:", filePath);
                            } else {
                                // Fallback to stored signed_url or original fileUrl
                                signedUrl = delivery.signed_url || fileUrl;
                                console.warn("[Digital Delivery] Failed to generate signed URL, using fallback");
                            }
                        } else {
                            signedUrl = delivery.signed_url || fileUrl;
                        }
                    } catch (signErr) {
                        console.error("[Digital Delivery] Error generating signed URL:", signErr);
                        signedUrl = delivery.signed_url || fileUrl;
                    }
                } else {
                    // External URL or direct download
                    signedUrl = fileUrl;
                }

                // Update access count
                await supabase
                    .from("digital_deliveries")
                    .update({
                        access_count: delivery.access_count + 1,
                        last_accessed_at: now.toISOString(),
                    })
                    .eq("id", delivery.id);

                // Create a separate download URL with the forced download parameter
                downloadUrl = signedUrl || fileUrl;
                if (downloadUrl.includes('supabase.co/storage')) {
                    const downloadParam = `download=${encodeURIComponent(fileName)}`;
                    downloadUrl = downloadUrl.includes('?') ? `${downloadUrl}&${downloadParam}` : `${downloadUrl}?${downloadParam}`;
                }

                console.log("[Digital Delivery] Valid access granted:", {
                    token,
                    orderId,
                    buyerEmail: buyerEmail.substring(0, 3) + "...",
                    accessCount: accessCount + 1,
                    isPdf,
                    hasDownloadParam: downloadUrl.includes('download=')
                });
            }
        }
    } catch (err) {
        errorMessage = "Terjadi kesalahan saat memverifikasi token.";
        console.error("[Digital Delivery] Unexpected error:", err);
    }
} else {
    errorMessage = "Token dan email diperlukan untuk mengakses file.";
    console.warn("[Digital Delivery] Missing token or email");
}

// If invalid, redirect to error page with more specific reason
if (!isValid) {
    let reason = "invalid";
    if (errorMessage && errorMessage.includes("email")) reason = "email_mismatch";
    if (errorMessage && errorMessage.includes("kadaluarsa")) reason = "expired";
    
    // Create a sanitized delivery object for debugging
    const deliveryDebug = delivery ? {
        id: delivery.id,
        has_order: !!delivery.orders,
        has_customer: !!delivery.orders?.customers,
        accessed_email: delivery.accessed_email ? "PRESENT" : "MISSING",
        accessed_email_val: delivery.accessed_email || "N/A"
    } : "NULL";

    const debugParam = `&debug_provided=${encodeURIComponent(email)}&debug_expected=${encodeURIComponent(buyerEmail)}&debug_data=${encodeURIComponent(JSON.stringify(deliveryDebug))}`;
    console.log(`[Digital Delivery] Redirecting. Reason: ${reason}, Msg: ${errorMessage}`);
    return Astro.redirect(`/digital-delivery/error?reason=${reason}${debugParam}`);
}
