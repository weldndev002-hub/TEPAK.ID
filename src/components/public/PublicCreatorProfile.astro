---
import ProductCardWithTracking from './ProductCardWithTracking';
import { CheckBadgeIcon } from '@heroicons/react/24/solid';
import { AnalyticsTracker } from '../analytics/AnalyticsTracker';

interface Props {
    merchantData: any;
    products: any[];
    formatted_products: any[];
    blocks: any[];
    profile: any;
    socials: any[];
    is_banned: boolean;
    showProductsSection: boolean;
}

const { 
    merchantData, 
    products, 
    formatted_products, 
    blocks, 
    profile, 
    socials, 
    is_banned, 
    showProductsSection 
} = Astro.props;
---

<AnalyticsTracker client:only="react" merchantId={merchantData.profiles.id} />

<div class="min-h-screen bg-[#F1F5F9] text-[#191C1E] font-['Funnel_Display',sans-serif] antialiased relative overflow-hidden">
    
    {/* DESIGNER BACKGROUND ELEMENTS */}
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/[0.03] blur-[120px] rounded-full"></div>
    <div class="absolute bottom-[20%] right-[-5%] w-[30%] h-[50%] bg-amber-200/[0.05] blur-[100px] rounded-full"></div>

    <main class="relative z-10 pt-16 md:pt-32 pb-32 max-w-5xl mx-auto px-6">
        {is_banned ? (
            <div class="py-32 flex flex-col items-center text-center space-y-8 animate-in zoom-in duration-500">
                <div class="w-24 h-24 bg-rose-50 text-rose-500 rounded-[2.5rem] flex items-center justify-center shadow-sm border border-rose-100">
                    <span class="material-symbols-outlined text-5xl">block</span>
                </div>
                <h2 class="text-4xl font-black text-slate-900 tracking-tighter uppercase italic">Halaman Tidak Tersedia</h2>
                <p class="text-slate-500 font-medium max-w-md mx-auto leading-relaxed">Maaf, halaman ini telah dinonaktifkan oleh sistem keamanan kami.</p>
            </div>
        ) : (
            <>
                {/* PROFILE HERO SECTION */}
                <section class="mb-24 flex flex-col items-center text-center relative animate-in fade-in slide-in-from-bottom-12 duration-1000 ease-out group">
                        
                        <div class="relative mb-8 md:mb-12">
                            <div class="w-32 h-32 md:w-48 md:h-48 rounded-[3rem] overflow-hidden border-[6px] border-white shadow-2xl bg-white transition-all duration-700">
                                <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src={profile.avatar} alt={profile.name} />
                            </div>
                            <div class="absolute -bottom-2 -right-2 bg-primary text-white p-2.5 rounded-2xl flex items-center justify-center border-4 border-white shadow-xl">
                                <CheckBadgeIcon className="w-5 h-5" />
                            </div>
                        </div>

                        <div class="max-w-xl w-full px-4 md:px-0">
                            <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-slate-900 mb-6 leading-none uppercase italic">
                                {profile.name}
                            </h1>
                            <p class="text-slate-500 text-lg md:text-xl font-medium leading-relaxed mb-12 opacity-80 max-w-lg mx-auto">
                                {profile.bio}
                            </p>

                            <div class="flex flex-wrap justify-center gap-4">
                                {socials.map((social) => (
                                    <a href={social.url} target="_blank" rel="noopener noreferrer" class="w-14 h-14 flex items-center justify-center rounded-2xl bg-slate-50 text-slate-400 hover:bg-primary hover:text-white hover:-translate-y-2 transition-all duration-500 shadow-sm hover:shadow-xl hover:shadow-primary/20 border border-slate-100/50">
                                        <Fragment set:html={social.icon} />
                                    </a>
                                ))}
                            </div>

                            {/* Custom Blocks */}
                            {blocks.length > 0 && (
                                <div class="w-full mt-8 space-y-3 text-left">
                                    {blocks.map((block: any) => {
                                        if (block.type === 'social') return null;
                                        if (block.type === 'text') return (
                                            <div class="py-3 px-2 text-center space-y-2">
                                                {block.data?.title && <h4 class="text-lg font-black text-slate-900 tracking-tighter uppercase">{block.data.title}</h4>}
                                                {block.data?.content && <p class="text-sm text-slate-500 font-medium leading-relaxed italic">{block.data.content}</p>}
                                            </div>
                                        );
                                        if (block.type === 'image') return (
                                            <div class="w-full space-y-2">
                                                {block.data?.imageUrl && (
                                                    <div class="w-full aspect-video rounded-3xl overflow-hidden border border-slate-100 shadow-sm">
                                                        <img src={block.data.imageUrl} class="w-full h-full object-cover" alt={block.data?.title || ''} />
                                                    </div>
                                                )}
                                                {block.data?.title && <p class="text-[11px] font-black text-slate-400 uppercase tracking-widest text-center italic">{block.data.title}</p>}
                                            </div>
                                        );
                                        if (block.type === 'video' && block.data?.isYouTube && block.data?.videoId) return (
                                            <div class="w-full space-y-2">
                                                <div class="w-full aspect-video rounded-3xl overflow-hidden shadow-lg">
                                                    <iframe
                                                        width="100%" height="100%"
                                                        src={`https://www.youtube.com/embed/${block.data.videoId}`}
                                                        title={block.title || 'Video'}
                                                        frameborder="0"
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                        allowfullscreen
                                                    />
                                                </div>
                                                {block.title && <p class="text-[11px] font-black text-slate-400 uppercase tracking-widest text-center italic">{block.title}</p>}
                                            </div>
                                        );
                                        return (
                                            <a
                                                href={block.data?.url || block.url || (block.subtitle?.startsWith('http') ? block.subtitle : '#')}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="flex items-center gap-4 w-full bg-slate-50 hover:bg-white px-5 py-4 rounded-2xl border border-slate-100 hover:shadow-md hover:scale-[1.01] transition-all group"
                                            >
                                                <div class="w-9 h-9 rounded-xl bg-primary/5 text-primary flex items-center justify-center shrink-0">
                                                    <span class="material-symbols-outlined text-base">{block.type === 'link' ? 'link' : block.type === 'article' ? 'article' : 'info'}</span>
                                                </div>
                                                <div class="flex-1 min-w-0 text-left">
                                                    <p class="text-sm font-black text-slate-900 uppercase tracking-tight truncate">{block.title || block.data?.title}</p>
                                                    {block.subtitle && <p class="text-[11px] text-slate-400 truncate mt-0.5">{block.subtitle}</p>}
                                                </div>
                                                <span class="material-symbols-outlined text-slate-300 group-hover:text-primary transition-colors text-base shrink-0">arrow_forward</span>
                                            </a>
                                        );
                                    })}
                                </div>
                            )}
                        </div>
                </section>

                {/* PRODUCTS COLLECTION SECTION */}
                {showProductsSection && (
                <section class="animate-in fade-in slide-in-from-bottom-12 duration-1000 delay-300">
                     <div class="flex flex-col md:flex-row justify-between items-center md:items-end mb-16 gap-6">
                        <div class="text-center md:text-left">
                            <div class="flex items-center gap-3 mb-4 justify-center md:justify-start">
                                <span class="w-12 h-[2px] bg-amber-400"></span>
                                <span class="text-[10px] font-black uppercase tracking-[0.4em] text-amber-500">Premium Catalog</span>
                            </div>
                            <h2 class="text-4xl md:text-6xl font-black tracking-tighter text-slate-900 leading-none uppercase italic">
                                Digital Works
                            </h2>
                        </div>
                        <div class="hidden md:block">
                            <p class="text-slate-400 text-sm font-bold uppercase tracking-widest">{products.length} Items Available</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">
                        {formatted_products.map((product) => (
                            <ProductCardWithTracking 
                                client:load
                                id={product.id}
                                image={product.image}
                                title={product.title}
                                price={product.price}
                                description={product.description}
                                merchantId={merchantData.profiles.id}
                                viewsCount={product.views_count}
                            />
                        ))}
                    </div>
                </section>
                )}
            </>
        )}
    </main>

    <footer class="w-full py-20 bg-white border-t border-slate-100">
        <div class="flex flex-col items-center gap-8 text-center max-w-5xl mx-auto px-6">
            <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-300">Created with tepak.id</span>
        </div>
    </footer>
</div>
