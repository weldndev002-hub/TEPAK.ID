---
import ProductCardWithTracking from './ProductCardWithTracking';
import { CheckBadgeIcon, ArrowRightIcon } from '@heroicons/react/24/solid';
import { AnalyticsTracker } from '../analytics/AnalyticsTracker';

interface Props {
    merchantData: any;
    products: any[];
    formatted_products: any[];
    blocks: any[];
    profile: any;
    socials: any[];
    is_banned: boolean;
    showProductsSection: boolean;
}

const { 
    merchantData, 
    products, 
    formatted_products, 
    blocks, 
    profile, 
    socials, 
    is_banned, 
    showProductsSection 
} = Astro.props;

const themeId = merchantData?.theme || 'atelier-dark';

const ThemeConfig: Record<string, any> = {
    'atelier-dark': {
        containerClass: 'bg-slate-900 text-white',
        heroTitleClass: 'text-white',
        heroBioClass: 'text-slate-400',
        cardClass: 'bg-slate-800/50 border-slate-700 hover:bg-slate-800 hover:shadow-2xl hover:shadow-primary/10',
        cardTitleClass: 'text-white',
        cardSubtitleClass: 'text-slate-500',
        socialBtnClass: 'bg-slate-800 text-slate-400 border-slate-700',
        productTitleClass: 'text-white',
        productSubClass: 'text-amber-500',
        bgElements: `
            <div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] bg-primary/[0.08] blur-[150px] rounded-full"></div>
            <div class="absolute bottom-[20%] right-[-5%] w-[40%] h-[40%] bg-indigo-500/[0.05] blur-[120px] rounded-full"></div>
        `
    },
    'clean-minimal': {
        containerClass: 'bg-white text-slate-900',
        heroTitleClass: 'text-slate-900',
        heroBioClass: 'text-slate-500',
        cardClass: 'bg-slate-50 border-slate-100 hover:bg-white hover:shadow-xl',
        cardTitleClass: 'text-slate-900',
        cardSubtitleClass: 'text-slate-400',
        socialBtnClass: 'bg-slate-50 text-slate-400 border-slate-100',
        productTitleClass: 'text-slate-900',
        productSubClass: 'text-amber-500',
        bgElements: ''
    },
    'sunrise-glow': {
        containerClass: 'bg-gradient-to-br from-amber-50 to-rose-100 text-slate-900',
        heroTitleClass: 'text-slate-900',
        heroBioClass: 'text-slate-600',
        cardClass: 'bg-white/60 backdrop-blur-md border-white hover:bg-white/90 hover:shadow-2xl hover:shadow-rose-500/10',
        cardTitleClass: 'text-slate-900',
        cardSubtitleClass: 'text-slate-500',
        socialBtnClass: 'bg-white/50 text-rose-400 border-white',
        productTitleClass: 'text-slate-900',
        productSubClass: 'text-rose-500',
        bgElements: `
            <div class="absolute top-[-10%] right-[-5%] w-[50%] h-[50%] bg-rose-200/40 blur-[120px] rounded-full animate-pulse"></div>
            <div class="absolute bottom-[-5%] left-[-5%] w-[40%] h-[40%] bg-amber-200/30 blur-[100px] rounded-full"></div>
        `
    }
};

const currentTheme = ThemeConfig[themeId] || ThemeConfig['atelier-dark'];
---

<AnalyticsTracker client:only="react" merchantId={merchantData.profiles.id} />

<div class={`min-h-screen ${currentTheme.containerClass} font-['Funnel_Display',sans-serif] antialiased relative overflow-hidden transition-colors duration-1000`}>
    
    <Fragment set:html={currentTheme.bgElements} />

    <main class="relative z-10 pt-16 md:pt-32 pb-32 max-w-5xl mx-auto px-6">
        {is_banned ? (
            <div class="py-32 flex flex-col items-center text-center space-y-8 animate-in zoom-in duration-500">
                <div class="w-24 h-24 bg-rose-50 text-rose-500 rounded-[2.5rem] flex items-center justify-center shadow-sm border border-rose-100">
                    <span class="material-symbols-outlined text-5xl">block</span>
                </div>
                <h2 class="text-4xl font-black text-slate-900 tracking-tighter">Halaman Tidak Tersedia</h2>
                <p class="text-slate-500 font-medium max-w-md mx-auto leading-relaxed">Maaf, halaman ini telah dinonaktifkan oleh sistem keamanan kami.</p>
            </div>
        ) : (
            <>
                {/* PROFILE HERO SECTION */}
                <section class="mb-24 flex flex-col items-center text-center relative animate-in fade-in slide-in-from-bottom-12 duration-1000 ease-out group">
                        
                        <div class="relative mb-8 md:mb-12">
                            <div class="w-32 h-32 md:w-48 md:h-48 rounded-3xl overflow-hidden border-[6px] border-white shadow-2xl bg-white transition-all duration-700">
                                <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src={profile.avatar} alt={profile.name} />
                            </div>
                            <div class="absolute -bottom-2 -right-2 bg-primary text-white p-2.5 rounded-2xl flex items-center justify-center border-4 border-white shadow-xl">
                                <CheckBadgeIcon class="w-5 h-5" />
                            </div>
                        </div>

                        <div class="max-w-xl w-full px-4 md:px-0">
                            <h1 class={`text-5xl md:text-7xl font-black tracking-tighter ${currentTheme.heroTitleClass} mb-6 leading-none`}>
                                {profile.name}
                            </h1>

                            <p class={`${currentTheme.heroBioClass} text-lg md:text-xl font-medium leading-relaxed mb-6 opacity-80 max-w-lg mx-auto`}>
                                {profile.bio}
                            </p>

                            {profile.email && (
                                <div class="flex items-center justify-center gap-2 mb-12 animate-in fade-in slide-in-from-top-4 duration-1000 delay-300">
                                    <span class={`text-[10px] font-black uppercase tracking-[0.3em] ${currentTheme.heroBioClass} opacity-40`}>Connect:</span>
                                    <a href={`mailto:${profile.email}`} class={`text-[11px] font-black uppercase tracking-widest ${currentTheme.heroTitleClass} hover:text-primary transition-colors border-b border-transparent hover:border-primary pb-1`}>
                                        {profile.email}
                                    </a>
                                </div>
                            )}

                            <div class="flex flex-wrap justify-center gap-4">
                                {socials.map((social) => (
                                    <a href={social.url} target="_blank" rel="noopener noreferrer" class={`w-14 h-14 flex items-center justify-center rounded-2xl ${currentTheme.socialBtnClass} hover:bg-primary hover:text-white hover:-translate-y-2 transition-all duration-500 shadow-sm hover:shadow-xl hover:shadow-primary/20 border transition-all`}>
                                        <Fragment set:html={social.icon} />
                                    </a>
                                ))}
                            </div>

                            {/* Custom Blocks */}
                            {blocks.length > 0 && (
                                <div class="w-full mt-12 space-y-10 text-left">
                                    {blocks.map((block: any) => {
                                        if (block.type === 'social') return null;
                                        
                                        if (block.type === 'text') return (
                                            <div class={`w-full ${currentTheme.cardClass} p-8 rounded-3xl border text-center space-y-3 animate-in fade-in duration-700 shadow-lg`}>
                                                {block.data?.title && <h4 class={`text-2xl font-black ${currentTheme.cardTitleClass} tracking-tighter uppercase`}>{block.data.title}</h4>}
                                                {block.data?.content && <p class={`text-sm ${currentTheme.cardSubtitleClass} font-medium leading-relaxed italic opacity-80`}>{block.data.content}</p>}
                                            </div>
                                        );

                                        if (block.type === 'image') return (
                                            <div class={`w-full ${currentTheme.cardClass} p-4 rounded-3xl border space-y-4 animate-in fade-in zoom-in-95 duration-700 shadow-lg`}>
                                                {block.data?.imageUrl && (
                                                    <div class="w-full aspect-video rounded-2xl overflow-hidden shadow-inner">
                                                        <img src={block.data.imageUrl} class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000" alt={block.data?.title || ''} />
                                                    </div>
                                                )}
                                                {block.data?.title && <p class={`text-[11px] font-black ${currentTheme.cardSubtitleClass} tracking-[0.2em] text-center italic pb-2`}>{block.data.title}</p>}
                                            </div>
                                        );

                                        if (block.type === 'video' && block.data?.isYouTube && block.data?.videoId) return (
                                             <div class={`w-full ${currentTheme.cardClass} p-4 rounded-3xl border space-y-4 animate-in fade-in zoom-in-95 duration-700 shadow-lg`}>
                                                <div class="w-full aspect-video rounded-2xl overflow-hidden shadow-inner bg-black/20">
                                                    <iframe
                                                        width="100%" height="100%"
                                                        src={`https://www.youtube.com/embed/${block.data.videoId}`}
                                                        title={block.title || 'Video'}
                                                        class="w-full h-full"
                                                        frameborder="0"
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                        allowfullscreen
                                                    />
                                                </div>
                                                {block.title && <p class={`text-[11px] font-black ${currentTheme.cardSubtitleClass} tracking-[0.2em] text-center italic pb-2`}>{block.title}</p>}
                                            </div>
                                        );

                                        // Default: link / article block (Affiliate Card)
                                        const url = block.data?.url || block.url || (block.subtitle?.startsWith('http') ? block.subtitle : '#');
                                        const thumbnail = block.data?.thumbnailUrl;
                                        const description = block.subtitle || block.data?.description;
                                        const displayDomain = url?.toLowerCase().includes('shopee') ? 'shopee.co.id' : 
                                                            url?.toLowerCase().includes('tokopedia') ? 'tokopedia.com' : 'tepak.id';
                                        
                                        return (
                                            <a
                                                href={url}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class={`group relative flex flex-col w-full max-w-sm mx-auto bg-[#16302B] rounded-[2rem] overflow-hidden shadow-2xl transition-all duration-500 mb-8 border border-white/5 hover:shadow-primary/10 hover:-translate-y-1`}
                                            >
                                                {/* Top: Thumbnail */}
                                                <div class="w-full aspect-square overflow-hidden bg-black/20 relative">
                                                    {thumbnail ? (
                                                        <img
                                                            src={thumbnail}
                                                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                                            alt=""
                                                        />
                                                    ) : (
                                                        <div class="w-full h-full flex items-center justify-center opacity-20">
                                                            <span class="material-symbols-outlined text-4xl text-white">link</span>
                                                        </div>
                                                    )}
                                                </div>

                                                {/* Bottom: Content */}
                                                <div class="p-6 md:p-8 flex flex-col flex-1 text-left min-w-0">
                                                    <div class="flex items-center gap-2 mb-4 opacity-50">
                                                        <span class="w-4 h-[1px] bg-primary"></span>
                                                        <span class={`text-[8px] font-black uppercase tracking-[0.2em] text-white/50`}>Link Details</span>
                                                    </div>
                                                    
                                                    <h3 class={`text-xl md:text-2xl font-black text-white leading-tight tracking-tight mb-3 group-hover:text-primary transition-colors line-clamp-2`}>
                                                        {block.title || block.data?.title}
                                                    </h3>
                                                    
                                                    {description && (
                                                        <p class={`text-[12px] text-white/60 leading-relaxed line-clamp-3 font-medium mb-6`}>
                                                            {description}
                                                        </p>
                                                    )}

                                                    <div class="mt-auto flex items-center justify-between gap-4 pt-6 border-t border-white/5">
                                                        <div class="flex flex-col">
                                                            <span class="text-[9px] font-black text-white/30 uppercase tracking-[0.2em] mb-1">{displayDomain}</span>
                                                            <span class="text-[11px] font-black text-primary uppercase tracking-[0.1em] group-hover:tracking-[0.2em] transition-all">Lihat Produk</span>
                                                        </div>
                                                        <div class="w-10 h-10 rounded-2xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all duration-300">
                                                            <span class="material-symbols-outlined text-lg">arrow_forward</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </a>
                                        );
                                    })}
                                </div>
                            )}
                        </div>
                </section>

                {/* PRODUCTS COLLECTION SECTION */}
                {showProductsSection && formatted_products.length > 0 && (
                <section class="mt-32 animate-in fade-in slide-in-from-bottom-16 duration-1000 delay-300">
                     <div class="flex flex-col md:flex-row justify-between items-center md:items-end mb-16 md:mb-24 gap-8">
                        <div class="text-center md:text-left">
                            <div class="flex items-center gap-3 mb-4 justify-center md:justify-start">
                                <span class={`w-12 h-[2px] ${themeId === 'sunrise-glow' ? 'bg-rose-400' : 'bg-amber-400'}`}></span>
                                <span class={`text-[10px] font-black uppercase tracking-[0.4em] ${currentTheme.productSubClass}`}>Premium Collections</span>
                            </div>
                            <h2 class={`text-5xl md:text-8xl font-black tracking-tighter ${currentTheme.productTitleClass} leading-none uppercase italic`}>
                                Featured Products
                            </h2>
                        </div>
                        <div class="hidden md:block pb-4">
                            <p class={`${currentTheme.cardSubtitleClass} text-[11px] font-black uppercase tracking-[0.3em] opacity-40`}>{products.length} Exclusive Items</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 justify-items-center">
                        {formatted_products.map((product) => (
                            <ProductCardWithTracking 
                                client:load
                                id={product.id}
                                image={product.image}
                                title={product.title}
                                price={product.price}
                                description={product.description}
                                merchantId={merchantData.profiles.id}
                                viewsCount={product.views_count}
                            />
                        ))}
                    </div>
                </section>
                )}
            </>
        )}
    </main>

    <footer class="w-full py-20 bg-white border-t border-slate-100">
        <div class="flex flex-col items-center gap-8 text-center max-w-5xl mx-auto px-6">
            <span class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-300">Created with tepak.id</span>
        </div>
    </footer>
</div>
