---
import { cn } from '../../lib/utils';

interface Props {
  title: string;
  items: {
    icon: string;
    title: string;
    description: string;
  }[];
}

const { title, items } = Astro.props;
---

<section class="py-24 bg-card">
  <div class="container px-4 mx-auto md:px-6">
    <div class="flex flex-col items-center gap-4 mb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tighter sm:text-4xl md:text-5xl font-outfit">
        {title}
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <div class="group p-8 transition-all border rounded-2xl bg-background hover:shadow-2xl hover:shadow-primary/5 hover:border-primary/20">
          <div class="flex items-center justify-center mb-6 w-12 h-12 rounded-xl bg-primary/5 group-hover:bg-primary/10 transition-colors">
            <!-- Icon placeholder - in reality, map string to HeroIcon -->
            <span class="text-2xl">{item.icon}</span>
          </div>
          <h3 class="mb-2 text-xl font-bold">{item.title}</h3>
          <p class="text-muted-foreground">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
