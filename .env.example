# ⚠️ SECURITY: Do not commit .env file to Git
# This file is a template. Copy to .env and fill in your actual values.
# Never share your API keys or secret credentials!

# =========================================
# Supabase Configuration (Public)
# =========================================
# Get these from: https://app.supabase.com/project/_/settings/api
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# =========================================
# Supabase Configuration (Secret)
# =========================================
# Get this from: https://app.supabase.com/project/_/settings/api
# ⚠️ KEEP THIS PRIVATE - Only for server-side use
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =========================================
# Database Configuration
# =========================================
DATABASE_URL=postgresql://user:password@host:6543/database?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/database

# =========================================
# DuitKu Payment Gateway
# =========================================
# Get these from: https://sandbox.duitku.com (sandbox) or https://duitku.com (production)
PUBLIC_DUITKU_MERCHANT_CODE=your_merchant_code
PUBLIC_DUITKU_MERCHANT_KEY=your_merchant_key
DUITKU_ENVIRONMENT=sandbox
# Callback URL where DuitKu will send payment updates
DUITKU_CALLBACK_URL=https://yourdomain.com/api/payments/duitku/webhook

# =========================================
# DuitKu Disbursement (Penarikan Dana / Transfer Bank)
# =========================================
# Get these from: Duitku Dashboard -> Disbursement API
# ⚠️ KEEP THESE PRIVATE - Separate credentials from Payment Gateway
# User ID untuk Disbursement API (integer, dari dashboard Duitku)
DUITKU_DISBURSEMENT_USER_ID=your_disbursement_user_id
# Secret Key untuk Disbursement API (untuk SHA256 signature)
DUITKU_DISBURSEMENT_KEY=your_disbursement_secret_key
# Email akun Duitku (wajib untuk signature Disbursement API)
DUITKU_DISBURSEMENT_EMAIL=your_email@example.com
# Webhook URL untuk callback status transfer dari Duitku
DUITKU_DISBURSEMENT_CALLBACK_URL=https://yourdomain.com/api/webhooks/duitku-disbursement

# =========================================
# Email Service (Resend)
# =========================================
# Get this from: https://resend.com/api-keys
# ⚠️ KEEP THIS PRIVATE - Only for sending emails
RESEND_API_KEY=re_your_api_key_here
# Sender email address (must be verified in Resend)
RESEND_SENDER_EMAIL=your_sender_email@example.com
# Optional sender name for email "From" field
RESEND_SENDER_NAME=Your Site Name

# Optional SMTP configuration (if using Resend SMTP instead of API)
# RESEND_SMTP_HOST=smtp.resend.com
# RESEND_SMTP_PORT=587
# RESEND_SMTP_USERNAME=resend
# RESEND_SMTP_PASSWORD=re_your_api_key_here

# =========================================
# Cloudflare Workers (if using Cloudflare for deployment)
# =========================================
# Set these in Cloudflare Workers dashboard under Environment Variables
# PUBLIC_SUPABASE_URL
# PUBLIC_SUPABASE_ANON_KEY
# PUBLIC_DUITKU_MERCHANT_CODE
# SUPABASE_SERVICE_ROLE_KEY (Secret)
# RESEND_API_KEY (Secret)
# DUITKU_CALLBACK_URL
# DUITKU_DISBURSEMENT_USER_ID (Secret)
# DUITKU_DISBURSEMENT_KEY (Secret)
# DUITKU_DISBURSEMENT_CALLBACK_URL

# =========================================
# Site Configuration
# =========================================
# Your main domain (used for email links, redirects, etc)
PUBLIC_SITE_URL=https://tepak.id

# =========================================
# Product Access Gate Configuration (Optional)
# =========================================
# Used for ProductAccessGate component - set these if you use that component
# Keep these values private if they're sensitive
PUBLIC_VALID_EMAIL=test@example.com
PUBLIC_VALID_TOKEN=your_secure_token_here
